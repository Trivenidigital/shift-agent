#!/usr/bin/env python3
"""Isolated quality smoke for Hermes Flyer Studio rendering."""
from __future__ import annotations

import argparse
import json
import os
import subprocess
from datetime import datetime, timezone
from pathlib import Path
import shutil
import sys
import tempfile

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))
sys.path.insert(0, str(SRC_ROOT))

from schemas import Config, FlyerConcept, FlyerProject, FlyerProjectStore, FlyerRequestFields  # noqa: E402
try:
    from flyer_render import build_asset_manifest, inspect_rendered_asset, render_concept_previews, render_final_package, validate_text_manifest_file  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.render import build_asset_manifest, inspect_rendered_asset, render_concept_previews, render_final_package, validate_text_manifest_file  # noqa: E402
try:
    from flyer_visual_qa import run_visual_qa, write_visual_qa_report  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.visual_qa import run_visual_qa, write_visual_qa_report  # noqa: E402


def _project() -> FlyerProject:
    return FlyerProject(
        project_id="F9001",
        status="generating_concepts",
        customer_phone="+19045550123",
        created_at=datetime.now(timezone.utc),
        updated_at=datetime.now(timezone.utc),
        original_message_id="smoke-quality",
        raw_request="Need flyer for Thursday Dosa Night Special. Non-veg combo $16.99. Contact +1 704 324 3322.",
        fields=FlyerRequestFields(
            event_or_business_name="Thursday Dosa Night Special",
            contact_info="+1 704 324 3322",
            venue_or_location="Triveni Pineville",
            notes="Veg dosas, non-veg dosas, kids combo. Non-veg combo $16.99.",
            style_preference="premium Indian restaurant special, polished food photography",
        ),
    )


def _load_config(path: Path) -> Config:
    try:
        from safe_io import load_yaml_model  # type: ignore
        return load_yaml_model(path, Config)
    except ModuleNotFoundError:
        import yaml
        return Config.model_validate(yaml.safe_load(path.read_text(encoding="utf-8")) or {})


_CI_ENV_VARS = ("GITHUB_ACTIONS", "CI", "BUILDKITE", "JENKINS_URL")


def _looks_like_ci() -> tuple[bool, str]:
    """Detect common CI markers so --real-model --allow-spend cannot accidentally
    run in a build pipeline. Tightens the existing --allow-spend gate; does NOT
    relax it. Returns (is_ci, first_matched_var).
    """
    for name in _CI_ENV_VARS:
        value = os.environ.get(name, "").strip().lower()
        if value and value not in ("0", "false", "no", ""):
            return True, name
    return False, ""


def _key_posture(name: str) -> dict:
    """Best-effort posture of a provider key for spend-mode output. Reports
    presence + which env source matched. Never returns the value itself."""
    process_value = os.environ.get(name, "").strip()
    if process_value:
        return {"present": "PLACEHOLDER" not in process_value.upper(), "source": "process_env"}
    for source, path_str in (
        ("hermes_env", os.environ.get("HERMES_ENV_PATH", "/root/.hermes/.env")),
        ("agent_env", os.environ.get("SHIFT_AGENT_ENV_PATH", "/opt/shift-agent/.env")),
    ):
        path = Path(path_str)
        if not path.exists():
            continue
        try:
            for line in path.read_text(encoding="utf-8").splitlines():
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, raw = line.split("=", 1)
                if key.strip() == name:
                    raw = raw.strip().strip('"').strip("'")
                    if raw:
                        return {"present": "PLACEHOLDER" not in raw.upper(), "source": source}
        except OSError:
            continue
    return {"present": False, "source": None}


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--output-dir", default="")
    parser.add_argument("--config-path", default="/opt/shift-agent/config.yaml")
    parser.add_argument("--real-model", action="store_true")
    parser.add_argument("--allow-spend", action="store_true")
    parser.add_argument("--keep-output", action="store_true")
    parser.add_argument("--final-package", action="store_true")
    args = parser.parse_args()

    if args.real_model and not args.allow_spend:
        print(json.dumps({"ok": False, "error": "--real-model requires --allow-spend"}))
        return 2

    # P0-7 belt-and-suspenders: refuse to spend in a CI/build pipeline even if
    # the operator passed --allow-spend. Most accidental spend events arise from
    # someone copying a working env into a build secret; the existing
    # FLYER_GOLDEN_ALLOW_SPEND env in pytest is one half of the gate, this is
    # the other. Operator can set ALLOW_SPEND_IN_CI=1 to override (documented
    # path; not the default).
    if args.real_model and args.allow_spend and os.environ.get("ALLOW_SPEND_IN_CI", "").lower() not in ("1", "true", "yes"):
        is_ci, var_name = _looks_like_ci()
        if is_ci:
            print(json.dumps({
                "ok": False,
                "error": f"refusing --real-model in CI environment ({var_name} is set)",
                "remedy": "unset CI markers, or set ALLOW_SPEND_IN_CI=1 if intentional",
            }))
            return 3

    temp_root = Path(args.output_dir) if args.output_dir else Path(tempfile.mkdtemp(prefix="flyer-quality-smoke-"))
    temp_root.mkdir(parents=True, exist_ok=True)
    os.environ["FLYER_STATE_ROOT"] = str(temp_root)
    asset_dir = temp_root / "assets"
    asset_dir.mkdir(parents=True, exist_ok=True)

    model = "deterministic-renderer"
    quality = "low"
    spend_mode = "none"
    posture = {
        "provider": "deterministic",
        "openrouter_key": {"present": False, "source": None},
        "openai_source_edit_key": {"present": False, "source": None},
    }
    if args.real_model:
        cfg = _load_config(Path(args.config_path))
        model = cfg.flyer.draft_image_model
        quality = cfg.flyer.draft_image_quality
        spend_mode = "real-model"
        posture = {
            "provider": "openrouter",
            "openrouter_key": _key_posture("OPENROUTER_API_KEY"),
            "openai_source_edit_key": _key_posture("OPENAI_API_KEY"),
        }

    try:
        project = _project()
        specs = render_concept_previews(project, asset_dir, model=model, quality=quality, concept_count=1)
        diagnostics = []
        ok = True
        for spec in specs:
            report = inspect_rendered_asset(spec.path, expected_width=spec.width, expected_height=spec.height, mime_type="image/png")
            text_report = validate_text_manifest_file(
                spec.path,
                project_id=project.project_id,
                project_version=project.version,
                output_format=spec.output_format,
            )
            diagnostics.append({
                "path": str(spec.path),
                "width": report.width,
                "height": report.height,
                "size_bytes": report.size_bytes,
                "blockers": report.blockers,
                "text_qa": {"ok": text_report.ok, "blockers": text_report.blockers},
            })
            ok = ok and report.ok and text_report.ok
        final_diagnostics = []
        send_dry_run = {"ok": True}
        stale_sidecar_check = {"ok": True}
        if args.final_package:
            preview_assets = build_asset_manifest(specs, first_asset_number=1, source="rendered", original_message_id="smoke-quality")
            concepts = [
                FlyerConcept(
                    concept_id="C1",
                    title="Best Design",
                    style_summary="Smoke concept",
                    preview_asset_id=preview_assets[0].asset_id,
                    prompt=project.raw_request,
                    created_at=datetime.now(timezone.utc),
                    selected_at=datetime.now(timezone.utc),
                )
            ]
            project = project.model_copy(update={
                "assets": preview_assets,
                "concepts": concepts,
                "selected_concept_id": "C1",
                "status": "finalizing_assets",
            })
            final_specs = render_final_package(project, temp_root / "finals", model=model, quality=quality)
            for spec in final_specs:
                mime = "application/pdf" if spec.path.suffix.lower() == ".pdf" else "image/png"
                report = inspect_rendered_asset(spec.path, expected_width=spec.width, expected_height=spec.height, mime_type=mime)
                text_report = validate_text_manifest_file(
                    spec.path,
                    project_id=project.project_id,
                    project_version=project.version,
                    output_format=spec.output_format,
                )
                final_diagnostics.append({
                    "path": str(spec.path),
                    "size_bytes": report.size_bytes,
                    "blockers": report.blockers,
                    "text_qa": {"ok": text_report.ok, "blockers": text_report.blockers},
                })
                ok = ok and report.ok and text_report.ok
            final_assets = build_asset_manifest(
                final_specs,
                first_asset_number=len(preview_assets) + 1,
                source="rendered",
                original_message_id="smoke-quality-approve",
            )
            for asset, spec in zip(final_assets, final_specs):
                (Path(str(spec.path) + ".ocr.txt")).write_text(
                    "Thursday Dosa Night Special Triveni Pineville +1 704 324 3322 Non-veg combo $16.99",
                    encoding="utf-8",
                )
                qa_report = run_visual_qa(
                    project,
                    spec.path,
                    output_format=spec.output_format,
                    asset_id=asset.asset_id,
                    allow_sidecar=True,
                )
                write_visual_qa_report(qa_report, spec.path)
            project = project.model_copy(update={
                "assets": [*preview_assets, *final_assets],
                "final_asset_ids": [asset.asset_id for asset in final_assets],
            })
            state_path = temp_root / "projects.json"
            log_path = temp_root / "decisions.log"
            state_path.write_text(FlyerProjectStore(projects=[project]).model_dump_json(indent=2), encoding="utf-8")
            send_script = Path(__file__).with_name("send-flyer-package")
            proc = subprocess.run(
                [
                    sys.executable,
                    str(send_script),
                    "--jid", "smoke@s.whatsapp.net",
                    "--project-id", project.project_id,
                    "--state-path", str(state_path),
                    "--log-path", str(log_path),
                    "--dry-run-bridge",
                    "--allow-sidecar-visual-qa",
                ],
                capture_output=True,
                text=True,
                timeout=60,
            )
            delivered_store = FlyerProjectStore.model_validate_json(state_path.read_text(encoding="utf-8"))
            delivered_project = delivered_store.projects[0]
            delivered = delivered_project.status == "delivered"
            all_final_assets_sent = all(
                asset.delivery_status == "sent" and asset.outbound_message_id
                for asset in delivered_project.assets
                if asset.asset_id in delivered_project.final_asset_ids
            )
            send_dry_run = {
                "ok": proc.returncode == 0 and delivered and all_final_assets_sent and log_path.exists(),
                "returncode": proc.returncode,
                "stdout": (proc.stdout or "").strip()[:500],
                "stderr": (proc.stderr or "").strip()[:500],
                "delivered": delivered,
                "all_final_assets_sent": all_final_assets_sent,
            }
            if proc.returncode != 0 and "No module named 'fcntl'" in (proc.stderr or ""):
                send_dry_run = {
                    "ok": True,
                    "skipped": "safe_io_fcntl_unavailable_on_windows",
                    "returncode": proc.returncode,
                    "stderr": (proc.stderr or "").strip()[:500],
                    "delivered": delivered,
                }
            ok = ok and bool(send_dry_run["ok"])
            stale_target = final_specs[0].path
            sidecar = Path(f"{stale_target}.text.json")
            doc = json.loads(sidecar.read_text(encoding="utf-8"))
            doc["project_version"] = doc["project_version"] + 1
            sidecar.write_text(json.dumps(doc), encoding="utf-8")
            stale = validate_text_manifest_file(
                stale_target,
                project_id=project.project_id,
                project_version=project.version,
                output_format=final_specs[0].output_format,
            )
            stale_sidecar_check = {"ok": not stale.ok, "blockers": stale.blockers}
            ok = ok and not stale.ok
        print(json.dumps({
            "ok": ok,
            "mode": spend_mode,
            "model": model,
            "quality": quality,
            "posture": posture,
            "concept_count": len(specs),
            "output_dir": str(temp_root),
            "assets": diagnostics,
            "final_assets": final_diagnostics,
            "send_dry_run": send_dry_run,
            "stale_sidecar_check": stale_sidecar_check,
        }))
        return 0 if ok else 1
    finally:
        if not args.keep_output and not args.output_dir:
            shutil.rmtree(temp_root, ignore_errors=True)


if __name__ == "__main__":
    raise SystemExit(main())
