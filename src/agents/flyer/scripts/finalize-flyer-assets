#!/usr/bin/env python3
"""Finalize Flyer Studio assets after exact customer APPROVE."""
from __future__ import annotations

import argparse
import json
from datetime import datetime, timezone
from pathlib import Path
import sys

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))

from schemas import Config, FlyerManualReview, FlyerProjectStore  # noqa: E402
from safe_io import FileLock, atomic_write_text, load_yaml_model  # noqa: E402
try:
    from flyer_render import build_asset_manifest, next_asset_number, render_final_package  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.render import build_asset_manifest, next_asset_number, render_final_package  # noqa: E402
try:
    from flyer_visual_qa import run_visual_qa, write_visual_qa_report  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.visual_qa import run_visual_qa, write_visual_qa_report  # noqa: E402
try:
    from flyer_manual_queue import make_manual_review  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.manual_queue import make_manual_review  # noqa: E402


STATE_PATH = Path("/opt/shift-agent/state/flyer/projects.json")
FINAL_DIR = Path("/opt/shift-agent/state/flyer/finals")
CONFIG_PATH = Path("/opt/shift-agent/config.yaml")


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--project-id", required=True)
    p.add_argument("--approved-message-id", required=True)
    p.add_argument("--state-path", default=str(STATE_PATH))
    p.add_argument("--final-dir", default=str(FINAL_DIR))
    p.add_argument("--config-path", default=str(CONFIG_PATH))
    args = p.parse_args()

    state_path = Path(args.state_path)
    cfg = load_yaml_model(Path(args.config_path), Config)
    with FileLock(Path(str(state_path) + ".lock")):
        store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
        for idx, project in enumerate(store.projects):
            if project.project_id != args.project_id:
                continue
            now = datetime.now(timezone.utc)
            if project.status != "finalizing_assets":
                raise SystemExit(f"project must be finalizing_assets, got {project.status}")
            final_provider = cfg.flyer.resolve_final_render_provider()
            specs = render_final_package(
                project,
                Path(args.final_dir),
                model=final_provider.model,
                quality=final_provider.quality,
            )
            assets = build_asset_manifest(
                specs,
                first_asset_number=next_asset_number(project),
                source="rendered",
                original_message_id=args.approved_message_id,
            )
            qa_reports = []
            for asset, spec in zip(assets, specs):
                report = run_visual_qa(
                    project,
                    spec.path,
                    output_format=spec.output_format,
                    asset_id=asset.asset_id,
                )
                write_visual_qa_report(report, spec.path)
                qa_reports.append(report)
            failed_qa = [report for report in qa_reports if report.status != "passed"]
            failed_core_qa = [
                report for report in failed_qa if report.output_format == "whatsapp_image"
            ]
            passed_asset_ids = [
                asset.asset_id
                for asset, report in zip(assets, qa_reports)
                if report.status == "passed"
            ]
            if failed_core_qa or not any(report.output_format == "whatsapp_image" for report in qa_reports if report.status == "passed"):
                manual = make_manual_review(
                    reason_code="visual_qa_failed",
                    detail="; ".join(blocker for report in failed_qa for blocker in report.blockers)[:500],
                    queued_at=now,
                )
                store.projects[idx] = project.model_copy(update={
                    "status": "manual_edit_required",
                    "approved_message_id": args.approved_message_id,
                    "assets": [*project.assets, *assets],
                    "qa_reports": [*project.qa_reports, *qa_reports],
                    "manual_review": manual,
                    "updated_at": now,
                })
                atomic_write_text(state_path, store.model_dump_json(indent=2))
                print(json.dumps({
                    "project_id": args.project_id,
                    "visual_qa_failed": [report.model_dump(mode="json") for report in failed_qa],
                }))
                return 2
            skipped_optional_qa = [
                report for report in failed_qa if report.output_format != "whatsapp_image"
            ]
            store.projects[idx] = project.model_copy(update={
                "status": "finalizing_assets",
                "approved_message_id": args.approved_message_id,
                "assets": [*project.assets, *assets],
                "qa_reports": [*project.qa_reports, *qa_reports],
                "final_asset_ids": passed_asset_ids,
                "updated_at": now,
            })
            atomic_write_text(state_path, store.model_dump_json(indent=2))
            print(json.dumps({
                "project_id": args.project_id,
                "final_asset_count": len(passed_asset_ids),
                "skipped_optional_final_asset_count": len(skipped_optional_qa),
                "skipped_optional_final_assets": [report.asset_id for report in skipped_optional_qa],
                "optional_visual_qa_failed": [report.model_dump(mode="json") for report in skipped_optional_qa],
            }))
            return 0
    raise SystemExit(f"project not found: {args.project_id}")


if __name__ == "__main__":
    raise SystemExit(main())
