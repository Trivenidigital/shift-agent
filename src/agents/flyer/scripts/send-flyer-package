#!/usr/bin/env python3
"""Send finalized flyer assets through the Hermes WhatsApp bridge."""
from __future__ import annotations

import argparse
import json
import os
from datetime import datetime, timezone
from pathlib import Path
import sys

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))
sys.path.insert(0, str(SRC_ROOT))

from schemas import FlyerAssetsDelivered, FlyerCustomerStore, FlyerDeliveryFailed, FlyerPlanTier, FlyerProjectStore, is_flyer_transition_allowed  # noqa: E402
try:
    from flyer_render import validate_text_manifest_file  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.render import validate_text_manifest_file  # noqa: E402
try:
    from flyer_visual_qa import validate_visual_qa_report  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.visual_qa import validate_visual_qa_report  # noqa: E402


STATE_PATH = Path("/opt/shift-agent/state/flyer/projects.json")
CUSTOMER_STATE_PATH = Path("/opt/shift-agent/state/flyer/customers.json")
LOG_PATH = Path("/opt/shift-agent/logs/decisions.log")
CREATE_ANOTHER_FLYER_LINK = "https://wa.me/918522041562?text=CREATE%20ANOTHER%20FLYER"
UPGRADE_PLAN_LINK = "https://wa.me/918522041562?text=UPGRADE%20PLAN%20-%20show%20Flyer%20Studio%20plans"
FINAL_KIND_TO_FORMAT = {
    "final_whatsapp_image": "whatsapp_image",
    "final_instagram_post": "instagram_post",
    "final_instagram_story": "instagram_story",
    "final_printable_pdf": "printable_pdf",
}
FINAL_KIND_TO_CAPTION = {
    "final_whatsapp_image": "WhatsApp flyer - ready to forward in WhatsApp.",
    "final_instagram_post": "Instagram post - square feed version.",
    "final_instagram_story": "Instagram story - vertical story/status version.",
    "final_printable_pdf": "Printable PDF - best for printing or sharing as a document.",
}


def _load_runtime_io():
    try:
        from safe_io import FileLock, atomic_write_text, bridge_post, bridge_send_media, ndjson_append  # type: ignore
    except ModuleNotFoundError:
        class FileLock:  # type: ignore[no-redef]
            def __init__(self, _path: Path) -> None:
                pass

            def __enter__(self) -> "FileLock":
                return self

            def __exit__(self, *_args: object) -> None:
                return None

        def atomic_write_text(path: Path, text: str) -> None:  # type: ignore[no-redef]
            path.parent.mkdir(parents=True, exist_ok=True)
            path.write_text(text, encoding="utf-8")

        def ndjson_append(path: Path, line: str) -> None:  # type: ignore[no-redef]
            path.parent.mkdir(parents=True, exist_ok=True)
            with path.open("a", encoding="utf-8") as fh:
                fh.write(line + "\n")

        def bridge_post(*_args, **_kwargs):  # type: ignore[no-redef]
            return False, "", "bridge unavailable", "bridge_unavailable"

        def bridge_send_media(*_args, **_kwargs):  # type: ignore[no-redef]
            return False, "", "bridge unavailable", "bridge_unavailable"
    return FileLock, atomic_write_text, bridge_post, bridge_send_media, ndjson_append


def _load_store(state_path: Path) -> FlyerProjectStore:
    return FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))


def _write_store(state_path: Path, store: FlyerProjectStore) -> None:
    try:
        from safe_io import atomic_write_text  # type: ignore
    except Exception:
        state_path.write_text(store.model_dump_json(indent=2), encoding="utf-8")
    else:
        atomic_write_text(state_path, store.model_dump_json(indent=2))


def _load_customer_store(path: Path) -> FlyerCustomerStore:
    if not path.exists():
        return FlyerCustomerStore()
    return FlyerCustomerStore.model_validate(json.loads(path.read_text(encoding="utf-8")))


def _trial_upsell_message(customer) -> str:
    remaining = customer.quota_remaining(FlyerPlanTier.default_tiers())
    if remaining is None:
        return ""
    if remaining <= 0:
        return (
            "Flyer Studio\n------------\n"
            "Your 3 free sample flyers are complete. To keep creating flyers, choose a plan: "
            "$49.99/month for 30, $69.99/month for 60, or $199/month unlimited.\n"
            f"Upgrade plan: {UPGRADE_PLAN_LINK}"
        )
    if remaining == 1:
        return (
            "Flyer Studio\n------------\n"
            "Second sample done. You have 1 free sample flyer left. "
            f"Create another flyer: {CREATE_ANOTHER_FLYER_LINK}\n"
            f"Upgrade plan: {UPGRADE_PLAN_LINK}"
        )
    return (
        "Flyer Studio\n------------\n"
        f"Your sample flyer is ready. You have {remaining} free sample flyers left.\n\n"
        f"Create another flyer: {CREATE_ANOTHER_FLYER_LINK}\n"
        f"Upgrade plan: {UPGRADE_PLAN_LINK}"
    )


def _trial_upsell_for_project(project, customer_state_path: Path) -> str:
    try:
        store = _load_customer_store(customer_state_path)
    except Exception:
        return ""
    customer = store.find_customer_by_phone(project.customer_phone)
    if customer is None or customer.status != "trial":
        return ""
    return _trial_upsell_message(customer)


def _caption_for_asset(asset, fallback: str = "") -> str:
    return FINAL_KIND_TO_CAPTION.get(getattr(asset, "kind", ""), fallback or "Your final flyer package is ready.")


def _resolve_project_assets(project):
    if project.status != "finalizing_assets":
        raise SystemExit(f"project must be finalizing_assets before delivery, got {project.status}")
    if not project.final_asset_ids:
        raise SystemExit("project has no final assets ready for delivery")
    if len(set(project.final_asset_ids)) != len(project.final_asset_ids):
        raise SystemExit("project final asset ids contain duplicates")
    by_id = {asset.asset_id: asset for asset in project.assets}
    missing_ids = [asset_id for asset_id in project.final_asset_ids if asset_id not in by_id]
    if missing_ids:
        raise SystemExit("missing final assets: " + ",".join(missing_ids))
    project_assets = [by_id[asset_id] for asset_id in project.final_asset_ids]
    kinds = {asset.kind for asset in project_assets}
    expected_kinds = set(FINAL_KIND_TO_FORMAT)
    if not kinds <= expected_kinds:
        raise SystemExit(f"final asset kinds mismatch: {sorted(kinds)}")
    if "final_whatsapp_image" not in kinds:
        raise SystemExit("final package must include final_whatsapp_image before delivery")
    return project_assets


def _pending_project_assets(project):
    project_assets = _resolve_project_assets(project)
    uncertain = [asset.asset_id for asset in project_assets if asset.delivery_status == "uncertain"]
    if uncertain:
        raise SystemExit("uncertain delivery requires operator reconciliation before retry: " + ",".join(uncertain))
    return [asset for asset in project_assets if asset.delivery_status != "sent"]


def audit_uncertain_delivery_block(log_path: Path, project, uncertain_assets, ndjson_append) -> None:
    for asset in uncertain_assets:
        ndjson_append(log_path, FlyerDeliveryFailed(
            type="flyer_delivery_failed",
            ts=datetime.now(timezone.utc),
            project_id=project.project_id,
            customer_phone=project.customer_phone,
            asset_id=asset.asset_id,
            status="uncertain",
            error="blocked retry: " + (asset.delivery_error or "delivery status uncertain"),
        ).model_dump_json())


def _pending_project_assets_or_audit_block(project, log_path: Path, ndjson_append):
    project_assets = _resolve_project_assets(project)
    uncertain_assets = [asset for asset in project_assets if asset.delivery_status == "uncertain"]
    if uncertain_assets:
        audit_uncertain_delivery_block(log_path, project, uncertain_assets, ndjson_append)
        raise SystemExit(
            "uncertain delivery requires operator reconciliation before retry: "
            + ",".join(asset.asset_id for asset in uncertain_assets)
        )
    return [asset for asset in project_assets if asset.delivery_status != "sent"]


def _record_asset_delivery(
    state_path: Path,
    project_id: str,
    asset_id: str,
    *,
    status: str,
    outbound_message_id: str = "",
    error: str = "",
) :
    store = _load_store(state_path)
    now = datetime.now(timezone.utc)
    for pidx, project in enumerate(store.projects):
        if project.project_id != project_id:
            continue
        updated_assets = []
        updated_project = project
        for asset in project.assets:
            if asset.asset_id != asset_id:
                updated_assets.append(asset)
                continue
            update = {
                "delivery_status": status,
                "delivery_attempt_count": asset.delivery_attempt_count + 1,
                "delivery_error": error,
            }
            if status == "sent":
                update["outbound_message_id"] = outbound_message_id
                update["delivered_at"] = now
            updated_assets.append(asset.model_copy(update=update))
        updated_project = project.model_copy(update={"assets": updated_assets, "updated_at": now})
        store.projects[pidx] = updated_project
        _write_store(state_path, store)
        return updated_project
    raise SystemExit(f"project not found: {project_id}")


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--jid", required=True)
    p.add_argument("--project-id", default="")
    p.add_argument("--state-path", default=str(STATE_PATH))
    p.add_argument("--customer-state-path", default=str(CUSTOMER_STATE_PATH))
    p.add_argument("--log-path", default=str(LOG_PATH))
    p.add_argument("--asset", action="append", default=[])
    p.add_argument("--caption", default="Your final flyer package is ready.")
    p.add_argument("--allow-unverified-asset", action="store_true")
    p.add_argument("--allow-sidecar-visual-qa", action="store_true")
    p.add_argument("--break-glass-reason", default="")
    p.add_argument("--dry-run-bridge", action="store_true")
    args = p.parse_args()
    FileLock, atomic_write_text, bridge_post, bridge_send_media, ndjson_append = _load_runtime_io()

    assets = [Path(asset) for asset in args.asset]
    project = None
    project_assets = []
    pending_project_assets = []
    project_snapshot = None
    state_path = Path(args.state_path)
    log_path = Path(args.log_path)
    if args.project_id:
        store = _load_store(state_path)
        project = next((p for p in store.projects if p.project_id == args.project_id), None)
        if project is None:
            raise SystemExit(f"project not found: {args.project_id}")
        project_assets = _resolve_project_assets(project)
        pending_project_assets = _pending_project_assets_or_audit_block(project, log_path, ndjson_append)
        project_snapshot = {
            "version": project.version,
            "status": project.status,
            "final_asset_ids": list(project.final_asset_ids),
        }
        assets.extend(Path(asset.path) for asset in pending_project_assets)
    if not assets:
        raise SystemExit("no assets to send; pass --asset or --project-id")
    if project is None and not args.allow_unverified_asset:
        raise SystemExit("direct --asset sends require --allow-unverified-asset and break-glass reason")
    if args.allow_sidecar_visual_qa and not args.dry_run_bridge:
        raise SystemExit("--allow-sidecar-visual-qa is only allowed with --dry-run-bridge")

    failures = []
    outbound_ids = []
    if args.allow_unverified_asset:
        if project is not None:
            raise SystemExit("--allow-unverified-asset is only for direct operator --asset sends")
        if os.environ.get("FLYER_TEXT_QA_BREAK_GLASS") != "1":
            raise SystemExit("break-glass requires FLYER_TEXT_QA_BREAK_GLASS=1")
        if not args.break_glass_reason.strip():
            raise SystemExit("break-glass requires --break-glass-reason")
        root = Path(os.environ.get("FLYER_STATE_ROOT", "/opt/shift-agent/state/flyer")).resolve()
        for asset in assets:
            try:
                asset.resolve().relative_to(root)
            except ValueError:
                raise SystemExit(f"break-glass asset outside Flyer state root: {asset}")
        print(json.dumps({
            "warning": "unverified_flyer_asset_break_glass",
            "reason": args.break_glass_reason.strip(),
            "asset_count": len(assets),
        }))
    else:
        expected_formats = {
            str(Path(asset.path)): FINAL_KIND_TO_FORMAT.get(asset.kind, "")
            for asset in pending_project_assets if project is not None
        }
        for asset in assets:
            expected_output_format = expected_formats.get(str(asset)) or None
            result = validate_text_manifest_file(
                asset,
                project_id=project.project_id if project is not None else None,
                project_version=project.version if project is not None else None,
                output_format=expected_output_format,
            )
            if not result.ok:
                if project is not None:
                    ndjson_append(log_path, FlyerDeliveryFailed(
                        type="flyer_delivery_failed",
                        ts=datetime.now(timezone.utc),
                        project_id=project.project_id,
                        customer_phone=project.customer_phone,
                        asset_id=asset.name,
                        status="blocked",
                        error="text_qa_failed: " + "; ".join(result.blockers),
                    ).model_dump_json())
                print(json.dumps({"text_qa_failed": str(asset), "blockers": result.blockers}))
                return 2
            if project is not None and expected_output_format:
                visual = validate_visual_qa_report(
                    asset,
                    project_id=project.project_id,
                    project_version=project.version,
                    output_format=expected_output_format,
                    allow_sidecar=args.allow_sidecar_visual_qa,
                )
                if not visual.ok:
                    project_asset = next((row for row in pending_project_assets if Path(row.path) == Path(asset)), None)
                    ndjson_append(log_path, FlyerDeliveryFailed(
                        type="flyer_delivery_failed",
                        ts=datetime.now(timezone.utc),
                        project_id=project.project_id,
                        customer_phone=project.customer_phone,
                        asset_id=project_asset.asset_id if project_asset is not None else asset.name,
                        status="blocked",
                        error="visual_qa_failed: " + "; ".join(visual.blockers),
                    ).model_dump_json())
                    print(json.dumps({"visual_qa_failed": str(asset), "blockers": visual.blockers}))
                    return 2
    path_to_project_asset = {str(Path(asset.path)): asset for asset in pending_project_assets} if project is not None else {}
    for asset in assets:
        if args.dry_run_bridge:
            ok, mid, err, status = True, f"dry-run:{asset.name}", "", 200
        else:
            project_asset = path_to_project_asset.get(str(asset)) if project is not None else None
            caption = _caption_for_asset(project_asset, args.caption) if project_asset is not None else args.caption
            ok, mid, err, status = bridge_send_media(args.jid, asset, caption=caption)
        if not ok:
            if project is not None and str(asset) in path_to_project_asset:
                delivery_status = "uncertain" if status == "send_uncertain" else "failed"
                _record_asset_delivery(
                    state_path,
                    project.project_id,
                    path_to_project_asset[str(asset)].asset_id,
                    status=delivery_status,
                    outbound_message_id="",
                    error=err,
                )
            failures.append({"asset": str(asset), "status": status, "error": err})
            if project is not None:
                ndjson_append(log_path, FlyerDeliveryFailed(
                    type="flyer_delivery_failed",
                    ts=datetime.now(timezone.utc),
                    project_id=project.project_id,
                    customer_phone=project.customer_phone,
                    asset_id=asset.name,
                    status=status,
                    error=err,
                ).model_dump_json())
        else:
            if project is not None and str(asset) in path_to_project_asset:
                _record_asset_delivery(
                    state_path,
                    project.project_id,
                    path_to_project_asset[str(asset)].asset_id,
                    status="sent",
                    outbound_message_id=mid,
                    error="",
                )
            outbound_ids.append(mid)
    if failures:
        print(json.dumps({"failures": failures, "sent_before_failure": outbound_ids}))
        return 2
    if project is not None:
        with FileLock(Path(str(state_path) + ".lock")):
            store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
            for idx, existing in enumerate(store.projects):
                if existing.project_id == project.project_id:
                    if (
                        project_snapshot is None
                        or existing.version != project_snapshot["version"]
                        or existing.status != project_snapshot["status"]
                        or list(existing.final_asset_ids) != project_snapshot["final_asset_ids"]
                    ):
                        ndjson_append(log_path, FlyerDeliveryFailed(
                            type="flyer_delivery_failed",
                            ts=datetime.now(timezone.utc),
                            project_id=project.project_id,
                            customer_phone=project.customer_phone,
                            asset_id="final_package",
                            status="blocked",
                            error="project changed during delivery; sent_message_ids=" + ",".join(outbound_ids),
                        ).model_dump_json())
                        print(json.dumps({"failure": "project_changed_during_delivery", "sent_before_failure": outbound_ids}))
                        return 2
                    if not is_flyer_transition_allowed(existing.status, "delivered"):
                        raise SystemExit(f"invalid transition {existing.status}->delivered")
                    store.projects[idx] = existing.model_copy(update={
                        "status": "delivered",
                        "updated_at": datetime.now(timezone.utc),
                    })
                    atomic_write_text(state_path, store.model_dump_json(indent=2))
                    break
        ndjson_append(log_path, FlyerAssetsDelivered(
            type="flyer_assets_delivered",
            ts=datetime.now(timezone.utc),
            project_id=project.project_id,
            customer_phone=project.customer_phone,
            asset_ids=[asset.asset_id for asset in project_assets],
            outbound_message_ids=outbound_ids,
        ).model_dump_json())
    trial_upsell_message_id = ""
    trial_upsell_error = ""
    if project is not None:
        message = _trial_upsell_for_project(project, Path(args.customer_state_path))
        if message:
            if args.dry_run_bridge:
                trial_upsell_message_id = "dry-run:trial-upsell"
            else:
                ok, mid, err, _status = bridge_post(args.jid, message)
                if ok:
                    trial_upsell_message_id = mid
                else:
                    trial_upsell_error = err
    print(json.dumps({
        "sent": len(assets),
        "message_ids": outbound_ids,
        "trial_upsell_message_id": trial_upsell_message_id,
        "trial_upsell_error": trial_upsell_error,
    }))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
