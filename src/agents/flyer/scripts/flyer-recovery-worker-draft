#!/usr/bin/env python3
"""Run a bounded Codex/Claude worker against one Flyer recovery bundle."""
from __future__ import annotations

import argparse
from datetime import datetime, timezone
import json
import os
from pathlib import Path
import shlex
import subprocess
import sys

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))

from schemas import FlyerRecoveryDeployGate  # noqa: E402


DEFAULT_ALLOWED_TOOLS = (
    "Read,Grep,Glob,Edit,Write,"
    "Bash(git *),Bash(python -m pytest *),Bash(python -m py_compile *),Bash(git diff *)"
)
DEFAULT_DISALLOWED_TOOLS = (
    "Bash(ssh *),Bash(scp *),Bash(curl *),Bash(wget *),Bash(systemctl *),"
    "Bash(journalctl *),Bash(npm publish *),Bash(git push --force *)"
)


def _load_bundle(path: Path) -> dict:
    try:
        doc = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise SystemExit(f"invalid bundle JSON: {path}: {e}") from e
    if not isinstance(doc, dict):
        raise SystemExit(f"bundle must be a JSON object: {path}")
    if not doc.get("incident_id"):
        raise SystemExit(f"bundle missing incident_id: {path}")
    return doc


def _worker_prompt(bundle_path: Path, bundle: dict) -> str:
    incident_id = str(bundle.get("incident_id") or "")
    failure_class = str(bundle.get("failure_class") or "")
    safety_contract = "\n".join(f"- {item}" for item in bundle.get("safety_contract", []))
    return f"""You are a bounded repair worker for SMB-Agents.

Incident: {incident_id}
Failure class: {failure_class}
Bundle path: {bundle_path}

Read the bundle first. Investigate only the local repository and copied fixtures.
Do not read, print, or modify credentials. Do not use SSH/SCP/curl/wget/systemctl.
Do not call the live WhatsApp bridge. The environment has FLYER_RECOVERY_NO_LIVE_SEND=1.
Do not deploy.

Safety contract:
{safety_contract}

Output requirements:
1. Root-cause hypothesis with file/function references.
2. Minimal patch summary, or say no patch is safe if evidence is insufficient.
3. Tests you ran and exact results.
4. Residual risks and required human/operator gate before deploy.
"""


def _codex_last_message_path(args: argparse.Namespace, incident_id: str) -> Path:
    out_dir = Path(args.out_dir).resolve() if args.out_dir else Path(args.bundle_path).resolve().parent / "worker_drafts"
    out_dir.mkdir(parents=True, exist_ok=True)
    return out_dir / f"{incident_id}-last-message.txt"


def _build_command(args: argparse.Namespace, prompt: str, incident_id: str) -> list[str]:
    if args.runner == "codex":
        return [
            args.codex_bin,
            "exec",
            "--cd",
            str(Path(args.repo_path).resolve()),
            "--model",
            args.model,
            "--sandbox",
            "danger-full-access",
            "--dangerously-bypass-approvals-and-sandbox",
            "--output-last-message",
            str(_codex_last_message_path(args, incident_id)),
            "-",
        ]
    return [
        args.claude_bin,
        "-p",
        prompt,
        "--model",
        args.model,
        "--permission-mode",
        "auto",
        "--allowedTools",
        args.allowed_tools,
        "--disallowedTools",
        args.disallowed_tools,
        "--max-budget-usd",
        str(args.max_budget_usd),
        "--output-format",
        "json",
    ]


def _append_audit(log_path: Path, entry) -> None:
    try:
        from safe_io import ndjson_append  # type: ignore
    except Exception:
        log_path.parent.mkdir(parents=True, exist_ok=True)
        with log_path.open("a", encoding="utf-8") as fh:
            fh.write(entry.model_dump_json() + "\n")
        return
    ndjson_append(log_path, entry.model_dump_json())


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--bundle-path", required=True)
    parser.add_argument("--repo-path", required=True)
    parser.add_argument("--out-dir", default="")
    parser.add_argument("--runner", choices=["codex", "claude"], default="codex")
    parser.add_argument("--codex-bin", default="codex")
    parser.add_argument("--claude-bin", default="claude")
    parser.add_argument("--model", default="gpt-5.3-codex")
    parser.add_argument("--max-budget-usd", type=float, default=2.0)
    parser.add_argument("--allowed-tools", default=DEFAULT_ALLOWED_TOOLS)
    parser.add_argument("--disallowed-tools", default=DEFAULT_DISALLOWED_TOOLS)
    parser.add_argument("--audit-log-path", default="/opt/shift-agent/logs/decisions.log")
    parser.add_argument("--allow-pr", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    bundle_path = Path(args.bundle_path).resolve()
    repo_path = Path(args.repo_path).resolve()
    if not bundle_path.exists():
        raise SystemExit(f"bundle not found: {bundle_path}")
    if not repo_path.exists() or not repo_path.is_dir():
        raise SystemExit(f"repo path not found: {repo_path}")
    bundle = _load_bundle(bundle_path)
    prompt = _worker_prompt(bundle_path, bundle)
    if args.allow_pr:
        prompt += "\nPR mode: you may prepare a branch and PR-ready summary, but still do not deploy.\n"
    incident_id = str(bundle.get("incident_id") or "incident")
    command = _build_command(args, prompt, incident_id)

    out_dir = Path(args.out_dir).resolve() if args.out_dir else bundle_path.parent / "worker_drafts"
    out_dir.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    out_path = out_dir / f"{incident_id}-{stamp}.json"

    summary = {
        "incident_id": incident_id,
        "bundle_path": str(bundle_path),
        "repo_path": str(repo_path),
        "runner": args.runner,
        "out_path": str(out_path),
        "command": " ".join(shlex.quote(part) for part in command),
        "prompt": prompt,
        "dry_run": args.dry_run,
    }
    if args.dry_run:
        print(json.dumps(summary, sort_keys=True) if args.json else summary["command"])
        return 0

    env = os.environ.copy()
    env["FLYER_RECOVERY_NO_LIVE_SEND"] = "1"
    if args.runner == "codex":
        result = subprocess.run(command, cwd=repo_path, env=env, input=prompt, capture_output=True, text=True, timeout=1800)
    else:
        result = subprocess.run(command, cwd=repo_path, env=env, capture_output=True, text=True, timeout=1800)
    payload = {
        **summary,
        "returncode": result.returncode,
        "stdout": result.stdout,
        "stderr": result.stderr,
    }
    out_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
    _append_audit(Path(args.audit_log_path), FlyerRecoveryDeployGate(
        type="flyer_recovery_deploy_gate",
        ts=datetime.now(timezone.utc),
        incident_id=incident_id,
        gate=f"worker_draft_{args.runner}",
        passed=result.returncode == 0,
        detail=f"returncode={result.returncode}; bundle_path={bundle_path}; out_path={out_path}",
    ))
    if args.json:
        print(json.dumps({"ok": result.returncode == 0, "out_path": str(out_path)}, sort_keys=True))
    else:
        print(f"ok={str(result.returncode == 0).lower()} out_path={out_path}")
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
