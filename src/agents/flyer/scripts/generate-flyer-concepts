#!/usr/bin/env python3
"""Generate one best concept record for Flyer Studio."""
from __future__ import annotations

import argparse
import json
from datetime import datetime, timezone
from pathlib import Path
import sys

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))

from schemas import Config, FlyerConcept, FlyerProjectStore  # noqa: E402
from safe_io import FileLock, atomic_write_text, load_yaml_model  # noqa: E402
try:
    from flyer_render import build_asset_manifest, next_asset_number, render_concept_previews  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.render import build_asset_manifest, next_asset_number, render_concept_previews  # noqa: E402


STATE_PATH = Path("/opt/shift-agent/state/flyer/projects.json")
ASSET_DIR = Path("/opt/shift-agent/state/flyer/assets")
CONFIG_PATH = Path("/opt/shift-agent/config.yaml")


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--project-id", required=True)
    p.add_argument("--state-path", default=str(STATE_PATH))
    p.add_argument("--asset-dir", default=str(ASSET_DIR))
    p.add_argument("--config-path", default=str(CONFIG_PATH))
    args = p.parse_args()

    state_path = Path(args.state_path)
    cfg = load_yaml_model(Path(args.config_path), Config)
    with FileLock(Path(str(state_path) + ".lock")):
        store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
        for idx, project in enumerate(store.projects):
            if project.project_id != args.project_id:
                continue
            now = datetime.now(timezone.utc)
            specs = render_concept_previews(
                project,
                Path(args.asset_dir),
                model=cfg.flyer.draft_image_model,
                quality=cfg.flyer.draft_image_quality,
                concept_count=cfg.flyer.concept_count,
            )
            assets = build_asset_manifest(
                specs,
                first_asset_number=next_asset_number(project),
                source="rendered",
                original_message_id=project.original_message_id,
            )
            concept_meta = [
                ("C1", "Best Design", "Best-quality flyer direction for this request"),
                ("C2", "Cultural Celebration", "Warm regional motifs with clean type"),
                ("C3", "Modern Social", "Instagram-first layout with crisp hierarchy"),
            ]
            concepts = [
                FlyerConcept(
                    concept_id=concept_id,
                    title=title,
                    style_summary=summary,
                    preview_asset_id=asset.asset_id,
                    prompt=project.raw_request,
                    created_at=now,
                )
                for asset, (concept_id, title, summary) in zip(assets, concept_meta)
            ]
            one_shot = len(concepts) == 1
            revisions = [
                revision.model_copy(update={
                    "applied": True,
                    "resulting_version": project.version,
                }) if not revision.applied else revision
                for revision in project.revisions
            ]
            store.projects[idx] = project.model_copy(update={
                "status": "awaiting_final_approval" if one_shot else "awaiting_concept_selection",
                "concepts": concepts,
                "selected_concept_id": "C1" if one_shot else None,
                "assets": [*project.assets, *assets],
                "revisions": revisions,
                "updated_at": now,
            })
            atomic_write_text(state_path, store.model_dump_json(indent=2))
            print(json.dumps({"project_id": args.project_id, "concept_count": len(concepts)}))
            return 0
    raise SystemExit(f"project not found: {args.project_id}")


if __name__ == "__main__":
    raise SystemExit(main())
