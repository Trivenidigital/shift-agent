REFERENCE_BLOCKING_ROLES = {"menu_reference", "old_flyer_reference", "source_edit_template", "unsupported"}
REFERENCE_BLOCKING_STATUSES = {"provider_unavailable", "unsupported", "low_confidence"}
REFERENCE_PENDING_ROLES = {"menu_reference", "old_flyer_reference", "source_edit_template"}


def _failed_required_reference_extractions(project) -> list:
    return [
        extraction
        for extraction in project.reference_extractions
        if extraction.role in REFERENCE_BLOCKING_ROLES and extraction.status in REFERENCE_BLOCKING_STATUSES
    ]


def _pending_required_reference_extractions(project) -> list:
    return [
        extraction
        for extraction in project.reference_extractions
        if extraction.role in REFERENCE_PENDING_ROLES and extraction.status == "not_run"
    ]


def _has_source_edit_template(project) -> bool:
    return any(
        extraction.role == "source_edit_template" and extraction.status == "ok"
        for extraction in project.reference_extractions
    )


def _asset_for_extraction(project, extraction):
    return next((asset for asset in project.assets if asset.asset_id == extraction.asset_id), None)


_DRAFT_RETRYABLE_TOKENS = (
    "timeout",
    "timed out",
    "502",
    "503",
    "504",
    "bad gateway",
    "service unavailable",
    "gateway timeout",
    "connection reset",
)

_DRAFT_EARLY_STATUSES = {
    "intake_started",
    "collecting_required_info",
    "awaiting_assets",
    "generating_concepts",
    "revising_design",
}


_VISUAL_QA_ERROR_TOKENS = (
    "quality check",
    "failed quality",
    "critical text facts do not fit",
    "text manifest validation failed",
    "missing critical text facts",
    "missing required flyer fields",
)

_DEPENDENCY_MISSING_ERROR_TOKENS = (
    "pillow is required",
    "pillow is unavailable",
    "modulenotfounderror",
    "no module named",
    "importerror",
)


def _draft_error_is_visual_qa(detail_lower: str) -> bool:
    return any(tok in detail_lower for tok in _VISUAL_QA_ERROR_TOKENS)


def _draft_error_is_dependency_missing(detail_lower: str) -> bool:
    return any(tok in detail_lower for tok in _DEPENDENCY_MISSING_ERROR_TOKENS)


def _draft_error_retryable(detail_lower: str) -> bool:
    return any(tok in detail_lower for tok in _DRAFT_RETRYABLE_TOKENS) or bool(
        re.search(r"\bhttp\s+5\d{2}\b|\b5\d{2}\b", detail_lower)
    )


def _source_edit_error_is_provider_unavailable(detail_lower: str) -> bool:
    key_or_config_tokens = (
        "api_key is missing",
        "api key is missing",
        "api_key missing",
        "api key missing",
        "missing api_key",
        "missing api key",
        "missing or placeholder",
        "placeholder api",
        "not configured",
        "manual review",
        "unsupported source edit provider",
    )
    return any(tok in detail_lower for tok in key_or_config_tokens)


def _mentions_saved_brand_assets(project) -> bool:
    text = f"{getattr(project, 'raw_request', '')} {getattr(getattr(project, 'fields', None), 'notes', '')}".casefold()
    return any(token in text for token in (
        "saved logo",
        "saved business name",
        "brand asset",
        "use logo",
        "use the logo",
    ))


def _qa_failed_missing_business_name(reports) -> bool:
    for report in reports:
        for blocker in getattr(report, "blockers", []) or []:
            if str(blocker).strip().casefold() == "missing required visible fact: business_name":
                return True
    return False


def _render_with_brand_assets_disabled(render_call):
    previous = os.environ.get("FLYER_DISABLE_BRAND_ASSETS")
    os.environ["FLYER_DISABLE_BRAND_ASSETS"] = "1"
    try:
        return render_call()
    finally:
        if previous is None:
            os.environ.pop("FLYER_DISABLE_BRAND_ASSETS", None)
        else:
            os.environ["FLYER_DISABLE_BRAND_ASSETS"] = previous


def _render_with_integrated_poster_disabled(render_call):
    previous = os.environ.get("FLYER_ALLOW_INTEGRATED_POSTER")
    os.environ["FLYER_ALLOW_INTEGRATED_POSTER"] = "0"
    try:
        return render_call()
    finally:
        if previous is None:
            os.environ.pop("FLYER_ALLOW_INTEGRATED_POSTER", None)
        else:
            os.environ["FLYER_ALLOW_INTEGRATED_POSTER"] = previous


_DETERMINISTIC_RENDERER_MODEL = "deterministic-renderer"


def _integrated_killswitch_active() -> bool:
    return os.environ.get("FLYER_INTEGRATED_KILLSWITCH") == "1"


def _effective_render_model(model: str) -> str:
    """4c kill-switch: when FLYER_INTEGRATED_KILLSWITCH=1 force the pure-Pillow
    deterministic renderer for every render in this script (draft + any final),
    short-circuiting the integrated/generative path. Reverts to byte-identical
    deterministic output as a panic switch. Otherwise the configured model is
    used unchanged."""
    if _integrated_killswitch_active():
        return _DETERMINISTIC_RENDERER_MODEL
    return model


def _qa_failed_exact_text_recoverable(reports) -> bool:
    blockers = [
        str(blocker or "").strip()
        for report in reports
        for blocker in getattr(report, "blockers", []) or []
        if str(blocker or "").strip()
    ]
    if not blockers:
        return False
    recoverable_prefixes = (
        "missing required visible fact:",
        "missing required visible item count:",
        "duplicate item visible:",
        "near-duplicate item visible:",
        "unverified phone number visible:",
        # 2026-06-14 (4a): fabrication block-tier blockers are recoverable via
        # the deterministic-overlay fallback — the overlay renders ONLY the exact
        # locked facts, so it cannot reproduce a fabricated price/offer claim.
        "fabricated price visible:",
        "fabricated offer claim visible:",
        # 2026-06-15: a generative model that paints food photos + prices but
        # drops most item NAMES ("inferred item not rendered: Idli/Vada/...") is
        # recoverable via the deterministic overlay, which renders EVERY item
        # name + the full schedule. Without this, ONE such blocker poisoned the
        # whole set → straight to manual (live F0157). Now eligible for the
        # content-miss corrective retry + deterministic-overlay fallback.
        "inferred item not rendered:",
    )
    return all(blocker.startswith(recoverable_prefixes) for blocker in blockers)


_FABRICATION_BLOCKER_PREFIXES = (
    "fabricated price visible:",
    "fabricated offer claim visible:",
)


def _qa_failed_is_fabrication_only(reports) -> bool:
    """4a retry-first gate: True when every failed-QA blocker is a fabrication
    block-tier blocker (and there is at least one). Used to scope the single
    corrective re-render to the fabrication-only case so it never entangles
    with the recovery.py autorepair loop."""
    blockers = [
        str(blocker or "").strip()
        for report in reports
        for blocker in getattr(report, "blockers", []) or []
        if str(blocker or "").strip()
    ]
    if not blockers:
        return False
    return all(blocker.startswith(_FABRICATION_BLOCKER_PREFIXES) for blocker in blockers)


def _qa_failed_has_fabrication(reports) -> bool:
    """§6 reason classifier: True when ANY failed-QA blocker is a fabrication
    block-tier blocker. Distinguishes a fabrication-bearing fallback (mixed
    recoverable set that bypassed the fabrication-only retry) from a purely
    non-fabrication recoverable fallback (e.g. missing-fact only)."""
    return any(
        str(blocker or "").strip().startswith(_FABRICATION_BLOCKER_PREFIXES)
        for report in reports
        for blocker in getattr(report, "blockers", []) or []
    )


def _qa_has_provider_unavailable(reports) -> bool:
    """4b gate: True when any failed-QA report's status is provider_unavailable
    (the referee/OCR could not verify the render). Distinct from a real QA
    failure — the render may be fine but is simply unverified."""
    return any(getattr(report, "status", "") == "provider_unavailable" for report in reports)


def _draft_manual_review_detail(exc: Exception, *, attempts: int, retryable_match: bool) -> str:
    payload = {
        "stage": "draft_render_concept_previews",
        "attempts": attempts,
        "retryable_match": bool(retryable_match),
        "error_class": exc.__class__.__name__,
        "error": str(exc)[:260],
    }
    encoded = json.dumps(payload, separators=(",", ":"), ensure_ascii=False)
    return encoded[:500]


def _sha256_hex(text: str) -> str:
    return hashlib.sha256((text or "").encode("utf-8", errors="replace")).hexdigest()


def _concept_prompt_metadata(project, *, concept_id: str, source_edit_requested: bool = False) -> str:
    if source_edit_requested:
        prompt = build_source_edit_generation_prompt(project)
    else:
        prompt = build_image_generation_prompt(
            project,
            concept_id=concept_id,
            output_format="concept_preview",
            size=(1080, 1350),
        )
    if len(prompt) <= 4000:
        return prompt
    suffix = "\n[truncated metadata; renderer used the full structured prompt]"
    return prompt[: 4000 - len(suffix)] + suffix


def _audit_append(path: Path, entry) -> None:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        with FileLock(Path(str(path) + ".lock")):
            ndjson_append(path, entry.model_dump_json())
    except Exception:
        # Audit rows must not block the existing manual-review fail-closed path.
        return


def _load_autorepair_store(path: Path) -> FlyerAutoRepairAttemptStore:
    if not path.exists():
        return FlyerAutoRepairAttemptStore()
    return FlyerAutoRepairAttemptStore.model_validate(json.loads(path.read_text(encoding="utf-8")))


def _write_autorepair_store(path: Path, store: FlyerAutoRepairAttemptStore) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    atomic_write_text(path, store.model_dump_json(indent=2))


def _render_artifact_candidates(spec) -> list[Path]:
    path = Path(spec.path)
    return [
        path,
        Path(str(path) + ".text.json"),
        Path(str(path) + ".qa.json"),
        Path(str(path) + ".ocr.txt"),
        path.with_name(f"{path.stem}.raw.png"),
        path.with_suffix(path.suffix + ".raw.png"),
    ]


def _cleanup_render_artifacts(specs, *, preserve_paths: set[Path] | None = None) -> None:
    preserve = {path.resolve() for path in (preserve_paths or set())}
    for spec in specs:
        for candidate in _render_artifact_candidates(spec):
            if candidate.resolve() in preserve:
                continue
            candidate.unlink(missing_ok=True)


def _attempt_budget_used(store: FlyerAutoRepairAttemptStore, *, project_id: str, project_version: int, qa_blocker_hash: str) -> int:
    return sum(
        1
        for attempt in store.attempts
        if attempt.project_id == project_id
        and attempt.project_version == project_version
        and attempt.qa_blocker_hash == qa_blocker_hash
        and attempt.mode == "hermes_regenerate"
        and attempt.status in {"attempted", "succeeded", "exhausted", "stale"}
    )


def _mark_stale_attempts(store: FlyerAutoRepairAttemptStore, *, now: datetime, stale_minutes: int) -> FlyerAutoRepairAttemptStore:
    cutoff = now - timedelta(minutes=stale_minutes)
    changed = False
    attempts = []
    for attempt in store.attempts:
        if attempt.status == "attempted" and attempt.started_at < cutoff:
            attempts.append(attempt.model_copy(update={
                "status": "stale",
                "completed_at": now,
                "detail": (attempt.detail or "attempt stale after process interruption")[:1000],
            }))
            changed = True
        else:
            attempts.append(attempt)
    return store.model_copy(update={"attempts": attempts}) if changed else store


def _append_attempt_status(store_path: Path, attempt: FlyerRepairAttempt) -> None:
    with FileLock(Path(str(store_path) + ".lock")):
        store = _load_autorepair_store(store_path)
        replaced = False
        for idx, existing in enumerate(store.attempts):
            if existing.attempt_id == attempt.attempt_id:
                store.attempts[idx] = attempt
                replaced = True
                break
        if not replaced:
            store.attempts.append(attempt)
        _write_autorepair_store(store_path, store)


# FLYER_QA_ALLOW_SIDECAR=1 is smoke/test-only â€” must not be enabled in production runtime.
def _write_sidecar_visual_qa_fixture(project, artifact_path: Path) -> None:
    if os.environ.get("FLYER_QA_ALLOW_SIDECAR") != "1":
        return
    sidecar = Path(str(artifact_path) + ".ocr.txt")
    if sidecar.exists():
        return
    lines: list[str] = []
    seen: set[str] = set()
    for fact in project.locked_facts:
        value = " ".join((fact.value or "").split())
        key = value.casefold()
        if not value or key in seen:
            continue
        seen.add(key)
        lines.append(value)
    if lines:
        atomic_write_text(sidecar, "\n".join(lines) + "\n")


def _manual_reason_for_reference_failure(extraction: FlyerReferenceExtraction) -> str:
    if extraction.role == "source_edit_template" and extraction.status == "provider_unavailable":
        return "source_edit_provider_unavailable"
    return f"reference_{extraction.status}"


def _emit_source_contract_extracted_audit(
    audit_log_path: Path,
    *,
    extraction: FlyerReferenceExtraction,
    project_id: str,
    asset_sha256: str,
    now: datetime,
) -> None:
    if extraction.role != "source_edit_template":
        return
    try:
        contract = extraction.source_contract
        entry = FlyerSourceContractExtracted(
            ts=now,
            project_id=project_id,
            asset_id=extraction.asset_id,
            asset_sha256=asset_sha256,
            role=extraction.role,
            status=extraction.status,
            headings_count=len(contract.required_headings) if contract else 0,
            sections_count=len(contract.sections) if contract else 0,
            replacements_count=len(contract.requested_replacements) if contract else 0,
            forbidden_substrings_count=len(contract.forbidden_substrings) if contract else 0,
            confidence=float(contract.confidence) if contract else 0.0,
            provider=extraction.provider,
        )
        audit_log_path.parent.mkdir(parents=True, exist_ok=True)
        with FileLock(Path(str(audit_log_path) + ".lock")):
            ndjson_append(audit_log_path, entry.model_dump_json())
    except Exception:
        # Audit is observability-only; do not block customer work on log I/O.
        pass


def _persist_reference_extraction_results(
    state_path: Path,
    project_id: str,
    extractions: list[FlyerReferenceExtraction],
    *,
    audit_log_path: Path,
):
    now = datetime.now(timezone.utc)
    with FileLock(Path(str(state_path) + ".lock")):
        store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
        for idx, current in enumerate(store.projects):
            if current.project_id != project_id:
                continue
            replacements = {extraction.asset_id: extraction for extraction in extractions}
            reference_extractions = [
                replacements.get(item.asset_id, item)
                for item in current.reference_extractions
            ]
            source_fact_lists = []
            for extraction in extractions:
                asset = _asset_for_extraction(current, extraction)
                if extraction.source_contract is not None and asset is not None:
                    _populate_forbidden_substrings(extraction.source_contract)
                    source_fact_lists.append(source_contract_locked_facts(
                        extraction.source_contract,
                        asset=asset,
                        message_id=current.original_message_id,
                    ))
                _emit_source_contract_extracted_audit(
                    audit_log_path,
                    extraction=extraction,
                    project_id=project_id,
                    asset_sha256=str(getattr(asset, "sha256", "") or "") if asset is not None else "",
                    now=now,
                )
            locked_facts = merge_locked_facts(
                current.locked_facts,
                *(extraction.extracted_facts for extraction in extractions),
                *source_fact_lists,
            )
            failed = [
                extraction
                for extraction in extractions
                if extraction.role in REFERENCE_BLOCKING_ROLES and extraction.status in REFERENCE_BLOCKING_STATUSES
            ]
            updates = {
                "reference_extractions": reference_extractions,
                "locked_facts": locked_facts,
                "updated_at": now,
            }
            if failed:
                first = failed[0]
                updates["status"] = "manual_edit_required"
                updates["manual_review"] = make_manual_review(
                    reason_code=_manual_reason_for_reference_failure(first),
                    detail=first.detail,
                    queued_at=now,
                )
            updated = current.model_copy(update=updates)
            store.projects[idx] = updated
            atomic_write_text(state_path, store.model_dump_json(indent=2))
            return updated, failed
    raise SystemExit(f"project not found while persisting reference extraction: {project_id}")


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--project-id", required=True)
    p.add_argument("--state-path", default=str(STATE_PATH))
    p.add_argument("--asset-dir", default=str(ASSET_DIR))
    p.add_argument("--config-path", default=str(CONFIG_PATH))
    p.add_argument("--audit-log-path", default=str(AUDIT_LOG_PATH))
    p.add_argument("--autorepair-state-path", default=str(AUTOREPAIR_STATE_PATH))
    args = p.parse_args()

    state_path = Path(args.state_path)
    audit_log_path = Path(args.audit_log_path)
    autorepair_state_path = Path(args.autorepair_state_path)
    cfg = load_yaml_model(Path(args.config_path), Config)
    with FileLock(Path(str(state_path) + ".lock")):
        store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
        project = None
        for idx, candidate in enumerate(store.projects):
            if candidate.project_id != args.project_id:
                continue
            project = candidate
            snapshot_idx = idx
            snapshot_version = candidate.version
            break
    if project is None:
        raise SystemExit(f"project not found: {args.project_id}")

    pending_reference_extractions = _pending_required_reference_extractions(project)
    if pending_reference_extractions:
        provider = build_reference_extraction_provider()
        extracted: list[FlyerReferenceExtraction] = []
        now = datetime.now(timezone.utc)
        for pending in pending_reference_extractions:
            asset = _asset_for_extraction(project, pending)
            if asset is None:
                extracted.append(FlyerReferenceExtraction(
                    asset_id=pending.asset_id,
                    role=pending.role,
                    provider="not_run",
                    status="provider_unavailable",
                    detail="reference asset is unavailable on this server",
                    extracted_at=now,
                ))
                continue
            extracted.append(extract_reference(asset, raw_request=project.raw_request, provider=provider))
        project, failed = _persist_reference_extraction_results(
            state_path,
            args.project_id,
            extracted,
            audit_log_path=audit_log_path,
        )
        if failed:
            print(json.dumps({
                "project_id": args.project_id,
                "reference_extraction_failed": [item.model_dump(mode="json") for item in failed],
            }))
            return 2

    failed_reference_extractions = _failed_required_reference_extractions(project)
    if failed_reference_extractions:
        now = datetime.now(timezone.utc)
        first = failed_reference_extractions[0]
        manual = make_manual_review(
            reason_code=_manual_reason_for_reference_failure(first),
            detail=first.detail,
            queued_at=now,
        )
        with FileLock(Path(str(state_path) + ".lock")):
            store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
            for idx, current in enumerate(store.projects):
                if current.project_id == args.project_id:
                    store.projects[idx] = current.model_copy(update={
                        "status": "manual_edit_required",
                        "manual_review": manual,
                        "updated_at": now,
                    })
                    break
            atomic_write_text(state_path, store.model_dump_json(indent=2))
        print(json.dumps({
            "project_id": args.project_id,
            "reference_extraction_failed": [item.model_dump(mode="json") for item in failed_reference_extractions],
        }))
        return 2

    asset_dir = Path(args.asset_dir)
    # Spec §6 integrated-path observability state. Defaults are safe for the
    # source-edit path (no integrated render → no integrated rows emitted).
    integrated_path_attempted = False
    integrated_attempt_count = 1
    integrated_fell_back_emitted = False
    integrated_passed_emitted = False
    with FileLock(asset_dir / f".{args.project_id}.generate.lock"):
        # P0-5: source-edit detection must require an explicit raw_request
        # marker OR (manual_edit_required AND a reference_image asset). The
        # bare `status == "manual_edit_required"` disjunct previously caught
        # projects queued for OTHER reasons (e.g. missing_required_facts
        # from S4) and pushed them down the source-edit renderer path, which
        # then failed inside `_source_edit_reference_asset` and rewrote
        # manual_review with a misleading provider/quality reason_code,
        # losing the original context.
        raw_lower = (project.raw_request or "").lower()
        has_source_edit_marker = (
            "edit uploaded flyer/source artwork" in raw_lower
            or "authorized flyer/source artwork update" in raw_lower
        )
        has_reference_image = any(
            getattr(asset, "kind", "") == "reference_image" for asset in (project.assets or [])
        )
        manual_reason_code = str(getattr(getattr(project, "manual_review", None), "reason_code", "") or "")
        visual_qa_retry_without_source_marker = (
            project.status == "manual_edit_required"
            and manual_reason_code == "visual_qa_failed"
            and not has_source_edit_marker
            and not _has_source_edit_template(project)
        )
        source_edit_requested = (
            has_source_edit_marker
            or _has_source_edit_template(project)
            or (
                project.status == "manual_edit_required"
                and has_reference_image
                and not visual_qa_retry_without_source_marker
            )
        )
        if source_edit_requested:
            # FIX 5: source-edit has NO deterministic renderer — render.py
            # dispatches source-edit by PROVIDER (OpenRouter/OpenAI) and would
            # call the API with model="deterministic-renderer", which errors.
            # When the integrated kill-switch is engaged, route the source-edit
            # straight to manual review (operator handles it) instead of
            # attempting a broken deterministic source-edit render.
            if _integrated_killswitch_active():
                now = datetime.now(timezone.utc)
                manual = make_manual_review(
                    reason_code="operator_request",
                    reason="killswitch_source_edit_manual",
                    detail="killswitch_source_edit_manual: integrated kill-switch active; "
                           "source-edit has no deterministic renderer — routed to manual review.",
                    queued_at=now,
                )
                with FileLock(Path(str(state_path) + ".lock")):
                    store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
                    for idx, current in enumerate(store.projects):
                        if current.project_id == args.project_id:
                            store.projects[idx] = current.model_copy(update={
                                "status": "manual_edit_required",
                                "manual_review": manual,
                                "updated_at": now,
                            })
                            break
                    atomic_write_text(state_path, store.model_dump_json(indent=2))
                print(json.dumps({
                    "project_id": args.project_id,
                    "source_edit_killswitch_manual": True,
                    "manual_review_reason_code": "operator_request",
                    "manual_review_reason": "killswitch_source_edit_manual",
                }))
                return 2
            # P0-5: render_source_edit_preview raises FlyerRenderError when the
            # provider key is missing or the image edit endpoint fails. The cf-
            # router preflight catches this at routing time, but operator CLI
            # invocations and retries bypass that gate. Catch here so the
            # project lands in manual_edit_required with the typed reason_code
            # instead of crashing the script (which would leave the project
            # mid-transition with no manual_review row).
            try:
                source_edit_provider = cfg.flyer.resolve_source_edit_render_provider()
                specs = [
                    render_source_edit_preview(
                        project,
                        asset_dir,
                        provider=source_edit_provider.provider,
                        model=_effective_render_model(source_edit_provider.model),
                        quality=source_edit_provider.quality,
                    )
                ]
            except FlyerRenderError as exc:
                now = datetime.now(timezone.utc)
                detail = str(exc)
                lower = detail.lower()
                # Quality-check failures are structural (wrong dimensions /
                # mime / corrupt bytes) â€” not transient. Map to
                # `visual_qa_failed` so operator triage doesn't waste time on
                # provider retries. Provider key / endpoint failures map to
                # `source_edit_provider_unavailable`. Transient HTTP/5xx and
                # timeout-shaped errors stay in `provider_timeout` even when
                # the provider name appears in the error text.
                if _draft_error_is_visual_qa(lower):
                    reason_code = "visual_qa_failed"
                elif _draft_error_is_dependency_missing(lower):
                    reason_code = "dependency_missing"
                elif _draft_error_retryable(lower):
                    reason_code = "provider_timeout"
                elif _source_edit_error_is_provider_unavailable(lower):
                    reason_code = "source_edit_provider_unavailable"
                else:
                    reason_code = "provider_timeout"
                manual = make_manual_review(
                    reason_code=reason_code,
                    detail=detail[:500],
                    queued_at=now,
                )
                with FileLock(Path(str(state_path) + ".lock")):
                    store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
                    for idx, current in enumerate(store.projects):
                        if current.project_id == args.project_id:
                            store.projects[idx] = current.model_copy(update={
                                "status": "manual_edit_required",
                                "manual_review": manual,
                                "updated_at": now,
                            })
                            break
                    atomic_write_text(state_path, store.model_dump_json(indent=2))
                print(json.dumps({
                    "project_id": args.project_id,
                    "source_edit_failed": detail[:500],
                    "manual_review_reason_code": reason_code,
                }))
                return 2
        else:
            draft_provider = cfg.flyer.resolve_draft_render_provider()
            # 4c kill-switch: resolve the effective draft model ONCE so every
            # render in this script (initial draft, brand-assets retry, autorepair
            # re-render, deterministic-overlay fallback) honors the panic switch.
            draft_model = _effective_render_model(draft_provider.model)
            # Spec §6 observability: an integrated concept render is being
            # attempted whenever the effective model is NOT the deterministic
            # renderer (i.e. the kill-switch is OFF). Emit once, up-front, so the
            # row counts as the denominator even if the render itself then fails.
            integrated_path_attempted = draft_model != _DETERMINISTIC_RENDERER_MODEL
            if integrated_path_attempted:
                _audit_append(audit_log_path, FlyerIntegratedAttempted(
                    ts=datetime.now(timezone.utc),
                    project_id=project.project_id,
                    project_version=project.version,
                ))
            specs = []
            retryable_match = False
            for attempt in range(2):
                try:
                    specs = render_concept_previews(
                        project,
                        asset_dir,
                        model=draft_model,
                        quality=draft_provider.quality,
                        concept_count=cfg.flyer.concept_count,
                    )
                    break
                except Exception as exc:
                    detail_lower = str(exc).lower()
                    retryable_match = _draft_error_retryable(detail_lower)
                    if attempt == 0 and retryable_match and not _draft_error_is_visual_qa(detail_lower):
                        time.sleep(0.35)
                        continue
                    now = datetime.now(timezone.utc)
                    if _draft_error_is_visual_qa(detail_lower):
                        reason_code = "visual_qa_failed"
                    elif _draft_error_is_dependency_missing(detail_lower):
                        reason_code = "dependency_missing"
                    else:
                        reason_code = "provider_timeout"
                    # FIX 7: a generation/provider error (API/transport failure —
                    # the provider_timeout class, NOT a visual_qa logic/validation
                    # failure nor a missing dependency) on the INITIAL integrated
                    # render should fall back to the pure deterministic renderer
                    # rather than going straight to manual. The deterministic
                    # renderer needs no provider, so it sidesteps the transient
                    # failure; downstream QA still verifies it. Only when the
                    # deterministic fallback ALSO fails do we route to manual.
                    # (dependency_missing is excluded — if Pillow is unavailable
                    # the deterministic renderer can't run either; visual_qa is
                    # excluded — it is a logic/validation failure, not generation.)
                    if (
                        integrated_path_attempted
                        and reason_code == "provider_timeout"
                    ):
                        try:
                            specs = render_concept_previews(
                                project,
                                asset_dir,
                                model=_effective_render_model(_DETERMINISTIC_RENDERER_MODEL),
                                quality=draft_provider.quality,
                                concept_count=cfg.flyer.concept_count,
                            )
                        except Exception:
                            specs = []
                        if specs:
                            # Deterministic fallback produced a render — emit the
                            # unified §6 fell-back counter (reason="generation_error")
                            # and continue into the normal post-render QA/persist
                            # flow, which verifies the deterministic output.
                            integrated_fell_back_emitted = True
                            _audit_append(audit_log_path, FlyerIntegratedFellBackDeterministic(
                                ts=now,
                                project_id=project.project_id,
                                project_version=project.version,
                                reason="generation_error",
                            ))
                            break
                    manual = make_manual_review(
                        reason_code=reason_code,
                        detail=_draft_manual_review_detail(exc, attempts=attempt + 1, retryable_match=retryable_match),
                        queued_at=now,
                    )
                    with FileLock(Path(str(state_path) + ".lock")):
                        store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
                        for idx, current in enumerate(store.projects):
                            if current.project_id != args.project_id:
                                continue
                            existing = current.manual_review
                            if getattr(existing, "status", "none") == "queued":
                                break
                            updates = {"manual_review": manual, "updated_at": now}
                            if current.status in _DRAFT_EARLY_STATUSES:
                                updates["status"] = "manual_edit_required"
                            store.projects[idx] = current.model_copy(update=updates)
                            break
                        atomic_write_text(state_path, store.model_dump_json(indent=2))
                    print(json.dumps({
                        "project_id": args.project_id,
                        "draft_render_failed": str(exc)[:260],
                        "manual_review_reason_code": reason_code,
                        "attempts": attempt + 1,
                        "retryable_match": bool(retryable_match),
                    }))
                    return 2

        with FileLock(Path(str(state_path) + ".lock")):
            store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
            current = store.projects[snapshot_idx]
            if current.project_id != args.project_id or current.version != snapshot_version:
                _cleanup_render_artifacts(specs)
                raise SystemExit("project changed while rendering; refusing to overwrite newer flyer state")

        now = datetime.now(timezone.utc)
        assets = build_asset_manifest(
            specs,
            first_asset_number=next_asset_number(current),
            source="rendered",
            original_message_id=current.original_message_id,
        )
        concept_meta = [
            ("C1", "Best Design", "Best-quality flyer direction for this request"),
            ("C2", "Cultural Celebration", "Warm regional motifs with clean type"),
            ("C3", "Modern Social", "Instagram-first layout with crisp hierarchy"),
        ]
        concepts = [
            FlyerConcept(
                concept_id=concept_id,
                title=title,
                style_summary=summary,
                preview_asset_id=asset.asset_id,
                prompt=_concept_prompt_metadata(
                    current,
                    concept_id=concept_id,
                    source_edit_requested=source_edit_requested,
                ),
                created_at=now,
            )
            for asset, (concept_id, title, summary) in zip(assets, concept_meta)
        ]
        one_shot = len(concepts) == 1
        qa_reports = []
        for asset, spec in zip(assets, specs):
            _write_sidecar_visual_qa_fixture(current, spec.path)
            report = run_visual_qa(
                current,
                spec.path,
                output_format=spec.output_format,
                asset_id=asset.asset_id,
            )
            write_visual_qa_report(report, spec.path)
            qa_reports.append(report)
        failed_qa = [report for report in qa_reports if report.status != "passed"]
        if (
            failed_qa
            and _qa_failed_missing_business_name(failed_qa)
            and _mentions_saved_brand_assets(current)
            and os.environ.get("FLYER_DISABLE_BRAND_ASSETS") != "1"
        ):
            _cleanup_render_artifacts(specs)
            specs = _render_with_brand_assets_disabled(lambda: render_concept_previews(
                current,
                asset_dir,
                model=draft_model,
                quality=draft_provider.quality,
                concept_count=cfg.flyer.concept_count,
            ))
            assets = build_asset_manifest(
                specs,
                first_asset_number=next_asset_number(current),
                source="rendered",
                original_message_id=current.original_message_id,
            )
            qa_reports = []
            for asset, spec in zip(assets, specs):
                _write_sidecar_visual_qa_fixture(current, spec.path)
                report = run_visual_qa(
                    current,
                    spec.path,
                    output_format=spec.output_format,
                    asset_id=asset.asset_id,
                )
                write_visual_qa_report(report, spec.path)
                qa_reports.append(report)
            failed_qa = [report for report in qa_reports if report.status != "passed"]
        pending_success_attempt = None
        pending_success_entry = None
        # FIX 4: never route a fabrication-bearing failure through the legacy
        # recovery.py autorepair loop. The legacy classifier marks a set eligible
        # if ANY missing-copy blocker appears, without rejecting accompanying
        # `fabricated ...` blockers — and its LLM repair_instruction is not
        # guaranteed to REMOVE a fabrication. So a mixed `missing fact +
        # fabricated offer` set must skip legacy autorepair and flow instead to
        # the fabrication-aware retry (when fabrication-only) or straight to the
        # deterministic-overlay fallback (when mixed), both of which are
        # safe-by-construction against fabrications.
        if (
            failed_qa
            and not source_edit_requested
            and not _qa_failed_has_fabrication(failed_qa)
        ):
            blockers = [blocker for report in failed_qa for blocker in report.blockers]
            blocker_hash = _sha256_hex("\n".join(blockers))
            decision = classify_flyer_qa_for_autorepair(blockers, current)
            skip_detail = ""
            if not cfg.flyer.recovery.auto_repair_enabled:
                skip_detail = "auto_repair_disabled"
            elif decision.decision != "hermes_plan_eligible":
                skip_detail = f"{decision.decision}:{decision.reason}"
            else:
                with FileLock(Path(str(autorepair_state_path) + ".lock")):
                    attempt_store = _load_autorepair_store(autorepair_state_path)
                    attempt_store = _mark_stale_attempts(
                        attempt_store,
                        now=now,
                        stale_minutes=cfg.flyer.recovery.auto_repair_attempt_stale_minutes,
                    )
                    _write_autorepair_store(autorepair_state_path, attempt_store)
                    used = _attempt_budget_used(
                        attempt_store,
                        project_id=current.project_id,
                        project_version=current.version,
                        qa_blocker_hash=blocker_hash,
                    )
                if used >= cfg.flyer.recovery.max_auto_repair_attempts:
                    skip_detail = "budget_exhausted"
            if skip_detail:
                _audit_append(audit_log_path, FlyerAutoRepairSkipped(
                    ts=now,
                    attempt_id=f"{current.project_id}-v{current.version}-skip-{int(now.timestamp())}",
                    project_id=current.project_id,
                    project_version=current.version,
                    qa_blocker_hash=blocker_hash,
                    repair_instruction_hash="0" * 64,
                    detail=skip_detail,
                    generated_asset_ids=[],
                ))
            else:
                rendered_text = "\n".join(getattr(report, "extracted_text", "") for report in failed_qa)
                plan = plan_flyer_autorepair(
                    project=current,
                    blockers=blockers,
                    rendered_text=rendered_text,
                    model=cfg.flyer.prompt_model
                    if cfg.flyer.prompt_model != "default_hermes_gateway"
                    else cfg.flyer.conversation_model,
                )
                repair_instruction = str(plan.get("repair_instruction") or "").strip()
                if plan.get("action") != "regenerate_with_instruction" or not repair_instruction:
                    _audit_append(audit_log_path, FlyerAutoRepairSkipped(
                        ts=now,
                        attempt_id=f"{current.project_id}-v{current.version}-skip-{int(now.timestamp())}",
                        project_id=current.project_id,
                        project_version=current.version,
                        qa_blocker_hash=blocker_hash,
                        repair_instruction_hash="0" * 64,
                        detail=str(plan.get("reason") or plan.get("action") or "planner_declined")[:1000],
                        generated_asset_ids=[],
                    ))
                elif not repair_instruction_is_safe(repair_instruction):
                    _audit_append(audit_log_path, FlyerAutoRepairSkipped(
                        ts=now,
                        attempt_id=f"{current.project_id}-v{current.version}-skip-{int(now.timestamp())}",
                        project_id=current.project_id,
                        project_version=current.version,
                        qa_blocker_hash=blocker_hash,
                        repair_instruction_hash=_sha256_hex(repair_instruction),
                        detail="planner_unsafe_or_empty_instruction",
                        generated_asset_ids=[],
                    ))
                else:
                    instruction_hash = _sha256_hex(repair_instruction)
                    attempt_id = f"{current.project_id}-v{current.version}-{blocker_hash[:12]}-1"
                    attempt = FlyerRepairAttempt(
                        attempt_id=attempt_id,
                        project_id=current.project_id,
                        project_version=current.version,
                        status="attempted",
                        qa_blocker_hash=blocker_hash,
                        repair_instruction_hash=instruction_hash,
                        repair_instruction=repair_instruction,
                        started_at=now,
                        detail="; ".join(blockers)[:1000],
                    )
                    _append_attempt_status(autorepair_state_path, attempt)
                    _audit_append(audit_log_path, FlyerAutoRepairAttempted(
                        ts=now,
                        attempt_id=attempt_id,
                        project_id=current.project_id,
                        project_version=current.version,
                        qa_blocker_hash=blocker_hash,
                        repair_instruction_hash=instruction_hash,
                        detail=attempt.detail,
                        generated_asset_ids=[],
                    ))
                    repair_specs = []
                    repair_assets = []
                    repair_qa_reports = []
                    repair_failed_qa = []
                    repair_error = ""
                    try:
                        repair_specs = render_concept_previews(
                            current,
                            asset_dir,
                            model=draft_model,
                            quality=draft_provider.quality,
                            concept_count=cfg.flyer.concept_count,
                            repair_instruction=repair_instruction,
                        )
                        repair_assets = build_asset_manifest(
                            repair_specs,
                            first_asset_number=next_asset_number(current),
                            source="rendered",
                            original_message_id=current.original_message_id,
                        )
                        for asset, spec in zip(repair_assets, repair_specs):
                            _write_sidecar_visual_qa_fixture(current, spec.path)
                            report = run_visual_qa(
                                current,
                                spec.path,
                                output_format=spec.output_format,
                                asset_id=asset.asset_id,
                            )
                            write_visual_qa_report(report, spec.path)
                            repair_qa_reports.append(report)
                        repair_failed_qa = [report for report in repair_qa_reports if report.status != "passed"]
                    except Exception as exc:
                        repair_error = f"{exc.__class__.__name__}: {str(exc)[:400]}"
                    completed = datetime.now(timezone.utc)
                    if repair_error or repair_failed_qa:
                        preserve_paths = {
                            candidate
                            for spec in specs
                            for candidate in _render_artifact_candidates(spec)
                        }
                        _cleanup_render_artifacts(repair_specs, preserve_paths=preserve_paths)
                        detail = repair_error or "; ".join(blocker for report in repair_failed_qa for blocker in report.blockers)[:1000]
                        exhausted = attempt.model_copy(update={
                            "status": "exhausted",
                            "completed_at": completed,
                            "detail": detail[:1000],
                        })
                        _append_attempt_status(autorepair_state_path, exhausted)
                        _audit_append(audit_log_path, FlyerAutoRepairExhausted(
                            ts=completed,
                            attempt_id=attempt_id,
                            project_id=current.project_id,
                            project_version=current.version,
                            qa_blocker_hash=blocker_hash,
                            repair_instruction_hash=instruction_hash,
                            detail=exhausted.detail,
                            generated_asset_ids=[],
                        ))
                    else:
                        pending_success_attempt = attempt.model_copy(update={
                            "status": "succeeded",
                            "completed_at": completed,
                            "generated_asset_ids": [asset.asset_id for asset in repair_assets],
                        })
                        pending_success_entry = FlyerAutoRepairSucceeded(
                            ts=completed,
                            attempt_id=attempt_id,
                            project_id=current.project_id,
                            project_version=current.version,
                            qa_blocker_hash=blocker_hash,
                            repair_instruction_hash=instruction_hash,
                            detail="repair_qa_passed",
                            generated_asset_ids=pending_success_attempt.generated_asset_ids,
                        )
                        preserve_paths = {
                            candidate
                            for repair_spec in repair_specs
                            for candidate in _render_artifact_candidates(repair_spec)
                        }
                        _cleanup_render_artifacts(specs, preserve_paths=preserve_paths)
                        specs = repair_specs
                        assets = repair_assets
                        qa_reports = repair_qa_reports
                        failed_qa = []
        # 4a (retry-first): if the ONLY remaining blockers are fabrication-type,
        # attempt up to TWO corrective re-renders with a two-sided repair
        # instruction (re-state authorized facts + remove fabricated claims)
        # before falling back to the deterministic overlay. Operator's locked
        # decision is x2 bounded attempts. Deliberately separate from the
        # recovery.py autorepair loop above: no attempt-store accounting, no
        # Hermes planner — a strictly-bounded best-effort pass. On success, keep
        # the corrected render and stop; on a render error or a non-fabrication
        # failure, stop retrying; if still fabrication-blocked after 2 attempts,
        # leave the ORIGINAL failed_qa intact so the deterministic-overlay
        # fallback (which fabrication blockers are now eligible for) handles it.
        _FABRICATION_MAX_CORRECTIVE_ATTEMPTS = 2
        # §6 fallback reason set by the fabrication retry loop (if it runs):
        # "" = no fallback needed (a retry passed); "retries_exhausted" /
        # "generation_error" = corrective attempts could not produce a passing
        # render. Default "" so non-fabrication paths leave it unset.
        fab_fallback_reason = ""
        if (
            failed_qa
            and not source_edit_requested
            and _qa_failed_is_fabrication_only(failed_qa)
        ):
            locked = {
                f.fact_id: f.value
                for f in current.locked_facts
                if getattr(f, "required", False)
            }
            # The blockers to repair against; refreshed from each failed attempt
            # so attempt 2 targets what attempt 1 still got wrong.
            current_fab_failed = failed_qa
            # §6 reason carried to the deterministic fallback if the retries do
            # not produce a passing render: "retries_exhausted" when all bounded
            # attempts still block, "generation_error" when a corrective render
            # raised. Set to "" once a retry passes (no fallback needed).
            fab_fallback_reason = "retries_exhausted"
            for fab_attempt in range(1, _FABRICATION_MAX_CORRECTIVE_ATTEMPTS + 1):
                fab_blockers = [blocker for report in current_fab_failed for blocker in report.blockers]
                fab_instruction = build_repair_instruction(fab_blockers, locked)
                fab_specs = []
                fab_assets = []
                fab_qa_reports = []
                fab_failed_qa = []
                fab_error = ""
                try:
                    fab_specs = render_concept_previews(
                        current,
                        asset_dir,
                        model=draft_model,
                        quality=draft_provider.quality,
                        concept_count=cfg.flyer.concept_count,
                        repair_instruction=fab_instruction,
                    )
                    fab_assets = build_asset_manifest(
                        fab_specs,
                        first_asset_number=next_asset_number(current),
                        source="rendered",
                        original_message_id=current.original_message_id,
                    )
                    for asset, spec in zip(fab_assets, fab_specs):
                        _write_sidecar_visual_qa_fixture(current, spec.path)
                        report = run_visual_qa(
                            current,
                            spec.path,
                            output_format=spec.output_format,
                            asset_id=asset.asset_id,
                        )
                        write_visual_qa_report(report, spec.path)
                        fab_qa_reports.append(report)
                    fab_failed_qa = [report for report in fab_qa_reports if report.status != "passed"]
                except Exception as exc:
                    fab_error = f"{exc.__class__.__name__}: {str(exc)[:400]}"
                if not fab_error and not fab_failed_qa:
                    # Retry passed QA — keep the corrected render and STOP.
                    preserve_paths = {
                        candidate
                        for spec in fab_specs
                        for candidate in _render_artifact_candidates(spec)
                    }
                    _cleanup_render_artifacts(specs, preserve_paths=preserve_paths)
                    specs = fab_specs
                    assets = fab_assets
                    qa_reports = fab_qa_reports
                    failed_qa = []
                    fab_fallback_reason = ""  # passed → no fallback
                    # Spec §6: integrated render passed after a corrective retry.
                    # attempts = 1 (initial) + number of corrective attempts run.
                    if integrated_path_attempted:
                        integrated_attempt_count = 1 + fab_attempt
                        integrated_passed_emitted = True
                        _audit_append(audit_log_path, FlyerIntegratedPassed(
                            ts=now,
                            project_id=current.project_id,
                            project_version=current.version,
                            attempts=integrated_attempt_count,
                        ))
                    break
                # Attempt failed: discard this attempt's artifacts (keep the
                # original specs intact for the downstream fallback).
                preserve_paths = {
                    candidate
                    for spec in specs
                    for candidate in _render_artifact_candidates(spec)
                }
                _cleanup_render_artifacts(fab_specs, preserve_paths=preserve_paths)
                if fab_error:
                    # A corrective render raised — further fabrication retries
                    # won't help. Stop; leave the ORIGINAL failed_qa for the
                    # deterministic-overlay fallback (reason: generation_error).
                    fab_fallback_reason = "generation_error"
                    break
                if not _qa_failed_is_fabrication_only(fab_failed_qa):
                    # The failure is no longer fabrication-only — retries can't
                    # help. Stop; leave the ORIGINAL failed_qa for the fallback.
                    fab_fallback_reason = "retries_exhausted"
                    break
                # Still fabrication-only-blocked: refresh the target blockers and
                # loop again (bounded by the range).
                current_fab_failed = fab_failed_qa
        # 2026-06-15 content-miss corrective retry (retry-first, ONCE): when the
        # integrated render is content-recoverable (every blocker is in the
        # recoverable set — e.g. dropped item NAMES + missing schedule, live
        # F0157) but is NOT a fabrication case, attempt ONE corrective re-render
        # that explicitly re-states every item name + the full schedule + the
        # required facts before falling back to the deterministic overlay. A
        # passing retry keeps the BEAUTIFUL integrated render; a still-blocked
        # retry leaves the ORIGINAL failed_qa for the deterministic-overlay
        # fallback below (now enabled for these blockers by the recoverable-set
        # change). Bounded to ONE attempt; deliberately separate from the
        # fabrication ×2 loop (which it must not disturb) and from the
        # recovery.py autorepair loop. Fabrication-bearing sets are excluded:
        # re-rendering a fabricating model risks re-fabricating, so those go
        # straight to the deterministic overlay (FIX 4 / fabrication path).
        content_fallback_reason = ""
        if (
            failed_qa
            and not source_edit_requested
            and not fab_fallback_reason
            and not _qa_has_provider_unavailable(failed_qa)
            and not _qa_failed_has_fabrication(failed_qa)
            and not _qa_failed_is_fabrication_only(failed_qa)
            and _qa_failed_exact_text_recoverable(failed_qa)
        ):
            # Repair dict: ALL item names + prices + every required fact. Item
            # NAMES are required=False today, so they are added explicitly here so
            # build_repair_instruction's "render ONLY these exact facts" clause
            # lists every item name and the full schedule the model must render.
            content_locked = {
                f.fact_id: f.value
                for f in current.locked_facts
                if getattr(f, "required", False)
                or f.fact_id.startswith("item:")
            }
            content_blockers = [blocker for report in failed_qa for blocker in report.blockers]
            content_instruction = build_repair_instruction(content_blockers, content_locked)
            content_specs = []
            content_assets = []
            content_qa_reports = []
            content_failed_qa = []
            content_error = ""
            content_fallback_reason = "retries_exhausted"
            try:
                content_specs = render_concept_previews(
                    current,
                    asset_dir,
                    model=draft_model,
                    quality=draft_provider.quality,
                    concept_count=cfg.flyer.concept_count,
                    repair_instruction=content_instruction,
                )
                content_assets = build_asset_manifest(
                    content_specs,
                    first_asset_number=next_asset_number(current),
                    source="rendered",
                    original_message_id=current.original_message_id,
                )
                for asset, spec in zip(content_assets, content_specs):
                    _write_sidecar_visual_qa_fixture(current, spec.path)
                    report = run_visual_qa(
                        current,
                        spec.path,
                        output_format=spec.output_format,
                        asset_id=asset.asset_id,
                    )
                    write_visual_qa_report(report, spec.path)
                    content_qa_reports.append(report)
                content_failed_qa = [report for report in content_qa_reports if report.status != "passed"]
            except Exception as exc:
                content_error = f"{exc.__class__.__name__}: {str(exc)[:400]}"
            if not content_error and not content_failed_qa:
                # Retry passed QA — keep the corrected (still-integrated) render.
                preserve_paths = {
                    candidate
                    for spec in content_specs
                    for candidate in _render_artifact_candidates(spec)
                }
                _cleanup_render_artifacts(specs, preserve_paths=preserve_paths)
                specs = content_specs
                assets = content_assets
                qa_reports = content_qa_reports
                failed_qa = []
                content_fallback_reason = ""  # passed → no fallback
                if integrated_path_attempted:
                    integrated_attempt_count = 2  # initial + 1 corrective
                    integrated_passed_emitted = True
                    _audit_append(audit_log_path, FlyerIntegratedPassed(
                        ts=now,
                        project_id=current.project_id,
                        project_version=current.version,
                        attempts=integrated_attempt_count,
                    ))
            else:
                # Retry failed (or raised): discard its artifacts, keep the
                # ORIGINAL specs for the downstream deterministic-overlay fallback.
                preserve_paths = {
                    candidate
                    for spec in specs
                    for candidate in _render_artifact_candidates(spec)
                }
                _cleanup_render_artifacts(content_specs, preserve_paths=preserve_paths)
        # 4b: when the referee could not verify the concept render
        # (status=provider_unavailable — OCR/vision down) route to the
        # deterministic-overlay fallback, which is safe-by-construction (overlay
        # draws EXACT locked text → cannot fabricate, so needs no OCR re-check).
        # Record the decision so the (otherwise silent) quality degradation is
        # observable: an audit row AND a note inside the persisted QA report.
        referee_unavailable_fallback = (
            bool(failed_qa)
            and not source_edit_requested
            and _qa_has_provider_unavailable(failed_qa)
        )
        # When we enter the fallback ONLY because the referee was unavailable, we
        # must never let the leftover UNVERIFIED integrated reports flow into the
        # downstream warn-tier delivery path (which would ship the unverified
        # integrated flyer). Track whether that case stays unresolved so the
        # final state machine can force manual review instead.
        referee_unavailable_unresolved = referee_unavailable_fallback
        # §6: resolve the single deterministic-fallback reason for this run.
        # Priority: referee-unavailable > fabrication-retry outcome > a residual
        # fabrication blocker that bypassed the fabrication-only retry (mixed
        # recoverable set) > content-miss retry outcome (dropped item names /
        # missing schedule). Non-fabrication recoverable fallbacks that did NOT
        # run the content retry are NOT a §6 integrated event → reason stays "".
        if referee_unavailable_fallback:
            integrated_fallback_reason = "referee_unavailable"
        elif fab_fallback_reason:
            integrated_fallback_reason = fab_fallback_reason
        elif bool(failed_qa) and not source_edit_requested and _qa_failed_has_fabrication(failed_qa):
            integrated_fallback_reason = "fabrication"
        elif content_fallback_reason:
            # Content-miss corrective retry ran and still blocked → the
            # deterministic overlay ships. Reuse "retries_exhausted" (no schema
            # change; semantically: the corrective retry was exhausted).
            integrated_fallback_reason = content_fallback_reason
        else:
            integrated_fallback_reason = ""
        if (
            failed_qa
            and not source_edit_requested
            and (
                _qa_failed_exact_text_recoverable(failed_qa)
                or referee_unavailable_fallback
            )
        ):
            fallback_specs = []
            fallback_assets = []
            fallback_qa_reports = []
            fallback_failed_qa = []
            fallback_error = ""
            try:
                if referee_unavailable_fallback:
                    # FIX 1: the referee is UNAVAILABLE — there is no QA to catch a
                    # hallucinated model background, so the fallback MUST be the PURE
                    # deterministic renderer (Pillow only, no model call). This is
                    # truly safe-by-construction and needs no QA. Route the model
                    # through _effective_render_model so the kill-switch stays a
                    # no-op-consistent override (it resolves to deterministic too).
                    fallback_specs = render_concept_previews(
                        current,
                        asset_dir,
                        model=_effective_render_model(_DETERMINISTIC_RENDERER_MODEL),
                        quality=draft_provider.quality,
                        concept_count=cfg.flyer.concept_count,
                    )
                else:
                    # Other fallback triggers (fabrication-retries-exhausted,
                    # generation_error, content-miss dropped-names/schedule) — the
                    # referee IS available, so a model-generated textless
                    # background + the deterministic overlay (which renders EVERY
                    # item name + the full schedule) is re-QA'd downstream and a
                    # hallucinated background is caught. Keep the existing
                    # background-only path.
                    fallback_specs = _render_with_integrated_poster_disabled(lambda: render_concept_previews(
                        current,
                        asset_dir,
                        model=draft_model,
                        quality=draft_provider.quality,
                        concept_count=cfg.flyer.concept_count,
                    ))
                fallback_assets = build_asset_manifest(
                    fallback_specs,
                    first_asset_number=next_asset_number(current),
                    source="rendered",
                    original_message_id=current.original_message_id,
                )
                for asset, spec in zip(fallback_assets, fallback_specs):
                    _write_sidecar_visual_qa_fixture(current, spec.path)
                    report = run_visual_qa(
                        current,
                        spec.path,
                        output_format=spec.output_format,
                        asset_id=asset.asset_id,
                    )
                    write_visual_qa_report(report, spec.path)
                    fallback_qa_reports.append(report)
                # 4b: when we routed here because the referee was UNAVAILABLE
                # (not because of a real QA failure), the deterministic overlay
                # is safe-by-construction — accept it even if the re-QA is also
                # provider_unavailable (still unverified). A genuine block-tier
                # 'failed' on the overlay still falls closed to manual.
                if referee_unavailable_fallback:
                    fallback_failed_qa = [
                        report
                        for report in fallback_qa_reports
                        if report.status not in ("passed", "provider_unavailable")
                    ]
                else:
                    fallback_failed_qa = [
                        report for report in fallback_qa_reports if report.status != "passed"
                    ]
            except Exception as exc:
                fallback_error = f"{exc.__class__.__name__}: {str(exc)[:400]}"
            if fallback_error or fallback_failed_qa:
                preserve_paths = {
                    candidate
                    for spec in specs
                    for candidate in _render_artifact_candidates(spec)
                }
                _cleanup_render_artifacts(fallback_specs, preserve_paths=preserve_paths)
            else:
                preserve_paths = {
                    candidate
                    for spec in fallback_specs
                    for candidate in _render_artifact_candidates(spec)
                }
                _cleanup_render_artifacts(specs, preserve_paths=preserve_paths)
                specs = fallback_specs
                assets = fallback_assets
                qa_reports = fallback_qa_reports
                failed_qa = []
                # Fallback shipped — the referee-unavailable case is resolved.
                referee_unavailable_unresolved = False
                # 4b observable marker (anti-silent): only when this fallback was
                # taken because the concept-path referee was UNAVAILABLE. Emit an
                # audit row AND stamp the note into the persisted QA reports so the
                # degradation shows up in qa_reports, per operator requirement.
                if referee_unavailable_fallback:
                    _MARKER = "integrated_referee_unavailable_fallback"
                    stamped = []
                    for report in qa_reports:
                        notes = list(getattr(report, "blockers", []) or [])
                        if _MARKER not in notes:
                            notes.append(_MARKER)
                        stamped.append(report.model_copy(update={"blockers": notes}))
                    qa_reports = stamped
                    _audit_append(audit_log_path, FlyerIntegratedRefereeUnavailableFallback(
                        ts=now,
                        project_id=current.project_id,
                        project_version=current.version,
                    ))
                # §6: the integrated render was abandoned and the deterministic
                # overlay shipped — emit the unified fell-back counter with the
                # resolved reason. Only for genuine integrated attempts (kill-
                # switch off) and recognized §6 reasons; a non-fabrication
                # recoverable fallback leaves integrated_fallback_reason "".
                # FIX 7: skip when a generation-error fell-back row was already
                # emitted at the initial-render handler (no double count).
                if (
                    integrated_path_attempted
                    and integrated_fallback_reason
                    and not integrated_fell_back_emitted
                ):
                    integrated_fell_back_emitted = True
                    _audit_append(audit_log_path, FlyerIntegratedFellBackDeterministic(
                        ts=now,
                        project_id=current.project_id,
                        project_version=current.version,
                        reason=integrated_fallback_reason,
                    ))
        revisions = [
            revision.model_copy(update={"applied": True})
            if (
                not revision.applied
                and revision.resulting_version is not None
                and revision.resulting_version <= current.version
            )
            else revision
            for revision in current.revisions
        ]
        with FileLock(Path(str(state_path) + ".lock")):
            store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
            latest = store.projects[snapshot_idx]
            if latest.project_id != args.project_id or latest.version != snapshot_version:
                if pending_success_attempt is not None:
                    stale = pending_success_attempt.model_copy(update={
                        "status": "stale",
                        "completed_at": datetime.now(timezone.utc),
                        "detail": "project changed before repaired assets could be committed",
                    })
                    _append_attempt_status(autorepair_state_path, stale)
                _cleanup_render_artifacts(specs)
                raise SystemExit("project changed while rendering; refusing to overwrite newer flyer state")
            if failed_qa:
                # P0 #2 — severity branch. Strict state-machine: severity label
                # → exactly one state-write + audit row. No conditional logic
                # beyond this map (Hermes-as-brain invariant).
                #   - Any report with severity == "block" → manual_edit_required
                #     (existing path; preserved bit-for-bit).
                #   - All failed reports severity == "warn" → delivered_with_warning
                #     (new path; cf-router drives the send via the post-subprocess
                #     branch in Commit 4).
                has_block_severity = any(
                    getattr(r, "severity", "block") == "block" for r in failed_qa
                )
                # 4b: an unresolved referee-unavailable case (deterministic
                # fallback could not ship) must go to manual — never warn-tier
                # delivery of the unverified integrated render.
                if referee_unavailable_unresolved:
                    has_block_severity = True
                if not has_block_severity:
                    if not is_flyer_transition_allowed(current.status, "delivered_with_warning"):
                        raise SystemExit(
                            f"warn-tier transition not allowed from {current.status} "
                            "to delivered_with_warning; refusing partial write"
                        )
                    all_blockers = [b for r in failed_qa for b in r.blockers]
                    # asset_id for the audit row must be non-empty (schema
                    # min_length=1). Use the first failed report's asset_id;
                    # fall back to a deterministic sentinel if absent.
                    warn_asset_id = ""
                    for r in failed_qa:
                        if r.asset_id:
                            warn_asset_id = r.asset_id
                            break
                    if not warn_asset_id:
                        warn_asset_id = "concept_preview_warn"
                    customer_text = build_warn_tier_customer_text(all_blockers, current)
                    customer_text_sha = hashlib.sha256(
                        customer_text.encode("utf-8")
                    ).hexdigest()
                    warning_payload = FlyerWarningSummary(
                        severity="warn",
                        blockers=all_blockers,
                        customer_text=customer_text,
                        customer_text_sha256=customer_text_sha,
                        delivered_at=now,
                        asset_id=warn_asset_id,
                    )
                    store.projects[snapshot_idx] = current.model_copy(update={
                        "status": "delivered_with_warning",
                        "assets": [*current.assets, *assets],
                        "qa_reports": [*current.qa_reports, *qa_reports],
                        "warning": warning_payload,
                        # P0 #2 — clear any stale manual_review payload that
                        # may have come in from a prior manual_edit_required
                        # → generating_concepts re-entry. cf-router's status
                        # formatters (actions.py:2103, 2182) still read
                        # manual_review on transitions; leaving stale data
                        # would leak operator-review copy onto the
                        # delivered_with_warning surface. Mirrors the existing
                        # pass-path reset below.
                        "manual_review": FlyerManualReview(),
                        "updated_at": now,
                    })
                    atomic_write_text(state_path, store.model_dump_json(indent=2))
                    _audit_append(audit_log_path, FlyerWarnTierDelivered(
                        ts=now,
                        project_id=args.project_id,
                        asset_id=warn_asset_id,
                        severity="warn",
                        blockers=all_blockers,
                        customer_text_sha256=customer_text_sha,
                    ))
                    print(json.dumps({
                        "project_id": args.project_id,
                        "delivered_with_warning": True,
                        "warning_blockers": all_blockers,
                    }))
                    return 0
                manual = make_manual_review(
                    reason_code="visual_qa_failed",
                    detail="; ".join(blocker for report in failed_qa for blocker in report.blockers)[:500],
                    queued_at=now,
                )
                store.projects[snapshot_idx] = current.model_copy(update={
                    "status": "manual_edit_required",
                    "assets": [*current.assets, *assets],
                    "qa_reports": [*current.qa_reports, *qa_reports],
                    "manual_review": manual,
                    "updated_at": now,
                })
                atomic_write_text(state_path, store.model_dump_json(indent=2))
                # §6: the concept-render path ended in manual review (no
                # integrated pass, no shippable deterministic fallback). Mirror
                # the reason_code written to state.
                if integrated_path_attempted:
                    _audit_append(audit_log_path, FlyerIntegratedManualReview(
                        ts=now,
                        project_id=current.project_id,
                        project_version=current.version,
                        reason_code=getattr(manual, "reason_code", "") or "visual_qa_failed",
                    ))
                print(json.dumps({
                    "project_id": args.project_id,
                    "visual_qa_failed": [report.model_dump(mode="json") for report in failed_qa],
                }))
                return 2
            store.projects[snapshot_idx] = current.model_copy(update={
                "status": "awaiting_final_approval" if one_shot else "awaiting_concept_selection",
                "concepts": concepts,
                "selected_concept_id": "C1" if one_shot else None,
                "assets": [*current.assets, *assets],
                "qa_reports": [*current.qa_reports, *qa_reports],
                "revisions": revisions,
                "manual_review": FlyerManualReview(),
                "updated_at": now,
            })
            atomic_write_text(state_path, store.model_dump_json(indent=2))
            if pending_success_attempt is not None and pending_success_entry is not None:
                _append_attempt_status(autorepair_state_path, pending_success_attempt)
                _audit_append(audit_log_path, pending_success_entry)
            # §6: integrated render reached the awaiting-approval terminal state.
            # Emit "passed" UNLESS this run shipped the deterministic fallback
            # (an integrated FELL-BACK row already covers that), or the
            # fabrication-retry success path already emitted it.
            if (
                integrated_path_attempted
                and not integrated_passed_emitted
                and not integrated_fell_back_emitted
            ):
                _audit_append(audit_log_path, FlyerIntegratedPassed(
                    ts=now,
                    project_id=current.project_id,
                    project_version=current.version,
                    attempts=integrated_attempt_count,
                ))
            print(json.dumps({"project_id": args.project_id, "concept_count": len(concepts)}))
            return 0


if __name__ == "__main__":
    raise SystemExit(main())
