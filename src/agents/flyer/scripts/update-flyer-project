#!/usr/bin/env python3
"""Update Flyer Studio project fields or status."""
from __future__ import annotations

import argparse
import json
from datetime import datetime, timezone
from pathlib import Path
import sys

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))

from schemas import (  # noqa: E402
    FlyerProjectStore,
    FlyerRequestFields,
    FlyerRevision,
    is_flyer_transition_allowed,
)
from safe_io import FileLock, atomic_write_text  # noqa: E402
try:
    from flyer_workflow import extract_revision_patch  # type: ignore  # noqa: E402
except ImportError:
    from agents.flyer.workflow import extract_revision_patch  # noqa: E402


STATE_PATH = Path("/opt/shift-agent/state/flyer/projects.json")


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--project-id", required=True)
    p.add_argument("--fields-json", default="")
    p.add_argument("--status", default="")
    p.add_argument("--select-concept", choices=["C1", "C2", "C3"], default="")
    p.add_argument("--revision-text", default="")
    p.add_argument("--message-id", default="")
    p.add_argument("--approve-message-id", default="")
    p.add_argument("--state-path", default=str(STATE_PATH))
    args = p.parse_args()

    state_path = Path(args.state_path)
    with FileLock(Path(str(state_path) + ".lock")):
        store = FlyerProjectStore.model_validate(json.loads(state_path.read_text(encoding="utf-8")))
        for idx, project in enumerate(store.projects):
            if project.project_id != args.project_id:
                continue
            updated = project
            if args.fields_json:
                fields = project.fields.model_copy(update=FlyerRequestFields.model_validate_json(args.fields_json).model_dump(exclude_none=True))
                updated = updated.model_copy(update={"fields": fields})
            if args.status:
                if not is_flyer_transition_allowed(updated.status, args.status):
                    raise SystemExit(f"invalid transition {updated.status}->{args.status}")
                updated = updated.model_copy(update={"status": args.status})
            if args.select_concept:
                concept_ids = {c.concept_id for c in updated.concepts}
                if args.select_concept not in concept_ids:
                    raise SystemExit(f"concept not found on project: {args.select_concept}")
                if not is_flyer_transition_allowed(updated.status, "revising_design"):
                    raise SystemExit(f"invalid transition {updated.status}->revising_design")
                now = datetime.now(timezone.utc)
                concepts = [
                    c.model_copy(update={"selected_at": now}) if c.concept_id == args.select_concept else c
                    for c in updated.concepts
                ]
                updated = updated.model_copy(update={
                    "selected_concept_id": args.select_concept,
                    "concepts": concepts,
                    "status": "revising_design",
                })
            if args.revision_text:
                if not args.message_id:
                    raise SystemExit("--message-id is required with --revision-text")
                target_status = "revising_design"
                if updated.status != target_status:
                    if not is_flyer_transition_allowed(updated.status, target_status):
                        raise SystemExit(f"invalid transition {updated.status}->{target_status}")
                    updated = updated.model_copy(update={"status": target_status})
                revision = FlyerRevision(
                    revision_id=f"R{len(updated.revisions) + 1:03d}",
                    message_id=args.message_id,
                    requested_at=datetime.now(timezone.utc),
                    request_text=args.revision_text,
                    applied=False,
                )
                patch = extract_revision_patch(updated, args.revision_text)
                revision_requires_clarification = patch.ambiguous or (not patch.changed and not patch.visual_only)
                if patch.field_updates or patch.notes_update is not None:
                    field_update = dict(patch.field_updates)
                    if patch.notes_update is not None:
                        field_update["notes"] = patch.notes_update
                    fields = updated.fields.model_copy(update=field_update)
                    updated = updated.model_copy(update={
                        "fields": fields,
                    })
                if patch.raw_request_update is not None:
                    updated = updated.model_copy(update={"raw_request": patch.raw_request_update})
                if patch.changed or patch.visual_only:
                    revision = revision.model_copy(update={"resulting_version": updated.version + 1})
                updated = updated.model_copy(update={
                    "concepts": [],
                    "selected_concept_id": None,
                    "final_asset_ids": [],
                })
                if revision_requires_clarification:
                    # Do not persist an unapplied no-op revision: it would block
                    # approval with no normal path to become applied.
                    updated = updated.model_copy(update={
                        "version": updated.version + 1,
                    })
                else:
                    updated = updated.model_copy(update={
                        "revisions": [*updated.revisions, revision],
                        "version": updated.version + 1,
                    })
            if args.approve_message_id:
                unapplied = [r.revision_id for r in updated.revisions if not r.applied]
                if unapplied:
                    raise SystemExit(f"cannot approve with unapplied revisions: {','.join(unapplied)}")
                if updated.status == "revising_design" and not updated.concepts:
                    raise SystemExit("cannot approve while revised design has not been regenerated")
                if not is_flyer_transition_allowed(updated.status, "awaiting_final_approval"):
                    if updated.status != "awaiting_final_approval":
                        raise SystemExit(f"project must be awaiting_final_approval before approval, got {updated.status}")
                if not is_flyer_transition_allowed("awaiting_final_approval", "finalizing_assets"):
                    raise SystemExit("schema transition awaiting_final_approval->finalizing_assets is unavailable")
                updated = updated.model_copy(update={
                    "status": "finalizing_assets",
                    "approved_message_id": args.approve_message_id,
                })
            updated = updated.model_copy(update={"updated_at": datetime.now(timezone.utc)})
            store.projects[idx] = updated
            atomic_write_text(state_path, store.model_dump_json(indent=2))
            payload = json.loads(updated.model_dump_json())
            if args.revision_text:
                payload = {
                    "project_id": updated.project_id,
                    "version": updated.version,
                    "revision_patch": patch.to_dict(),
                    "revision_requires_clarification": revision_requires_clarification,
                }
            print(json.dumps(payload))
            return 0
    raise SystemExit(f"project not found: {args.project_id}")


if __name__ == "__main__":
    raise SystemExit(main())
