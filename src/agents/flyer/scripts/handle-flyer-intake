#!/usr/bin/env python3
"""Handle Flyer Studio language/mode/guided intake."""
from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))
sys.path.insert(0, str(SRC_ROOT))

try:
    from agents.flyer.intake import handle_intake_message  # type: ignore  # noqa: E402
except ModuleNotFoundError:
    from flyer_intake import handle_intake_message  # type: ignore  # noqa: E402

try:
    from safe_io import FileLock  # type: ignore  # noqa: E402
except ModuleNotFoundError:
    class FileLock:  # type: ignore[no-redef]
        def __init__(self, _path: Path) -> None:
            pass

        def __enter__(self) -> "FileLock":
            return self

        def __exit__(self, *_args: object) -> None:
            return None


STATE_PATH = Path("/opt/shift-agent/state/flyer/customers.json")


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--chat-id", required=True)
    p.add_argument("--sender-phone", default="")
    p.add_argument("--message-id", required=True)
    p.add_argument("--text", default="")
    p.add_argument("--media-path", default="")
    p.add_argument("--start-source", default="")
    p.add_argument("--original-text", default="")
    p.add_argument("--state-path", default=str(STATE_PATH))
    args = p.parse_args()

    state_path = Path(args.state_path)
    with FileLock(Path(str(state_path) + ".lock")):
        try:
            result = handle_intake_message(
                state_path=state_path,
                chat_id=args.chat_id,
                sender_phone=args.sender_phone or None,
                message_id=args.message_id,
                text=args.text,
                media_path=args.media_path,
                start_source=args.start_source or None,
                original_text=args.original_text,
            )
        except Exception as e:  # noqa: BLE001 - structured CLI failure.
            print(json.dumps({
                "handled": True,
                "reply_text": "",
                "action": "error",
                "detail": f"{type(e).__name__}: {e}",
            }))
            return 2
    print(json.dumps({
        "handled": result.handled,
        "reply_text": result.reply_text,
        "action": result.action,
        "raw_request": result.raw_request,
        "source": result.source,
        "preferred_language": result.preferred_language,
        "creation_mode": result.creation_mode,
        "customer_id": result.customer_id,
        "reference_media_path": result.reference_media_path,
    }))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
