#!/usr/bin/env python3
"""Manage Flyer Studio payment-first guest orders."""
from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))
sys.path.insert(0, str(SRC_ROOT))

try:
    from agents.flyer.guest_order import (  # type: ignore  # noqa: E402
        activate_guest_order,
        consume_guest_order,
        find_paid_guest_order,
        find_reserved_guest_order,
        release_guest_order,
        reserve_guest_order,
        start_guest_order,
    )
except ModuleNotFoundError:
    from flyer_guest_order import (  # type: ignore  # noqa: E402
        activate_guest_order,
        consume_guest_order,
        find_paid_guest_order,
        find_reserved_guest_order,
        release_guest_order,
        reserve_guest_order,
        start_guest_order,
    )
from schemas import Config  # noqa: E402
try:
    from safe_io import FileLock, load_yaml_model  # type: ignore  # noqa: E402
except ModuleNotFoundError:
    class FileLock:  # type: ignore[no-redef]
        def __init__(self, _path: Path) -> None:
            pass

        def __enter__(self) -> "FileLock":
            return self

        def __exit__(self, *_args: object) -> None:
            return None

    def load_yaml_model(path: Path, model):  # type: ignore[no-redef]
        import yaml  # type: ignore
        return model.model_validate(yaml.safe_load(path.read_text(encoding="utf-8")) or {})


STATE_PATH = Path("/opt/shift-agent/state/flyer/guest_orders.json")
CONFIG_PATH = Path("/opt/shift-agent/config.yaml")


def _load_flyer_config(path: Path) -> tuple[int, str, str]:
    try:
        cfg = load_yaml_model(path, Config)
        return (
            cfg.flyer.quick_flyer_price_cents,
            cfg.flyer.quick_flyer_checkout_url_template,
            cfg.flyer.payment_checkout_url_template,
        )
    except Exception:
        return 400, "", ""


def _emit(result) -> int:
    print(json.dumps({
        "ok": result.ok,
        "handled": result.handled,
        "reply_text": result.reply_text,
        "order_id": result.order_id,
        "status": result.status,
        "payment_checkout_url": result.payment_checkout_url,
        "detail": result.detail,
    }))
    return 0 if result.ok else 2


def main() -> int:
    p = argparse.ArgumentParser()
    mode = p.add_mutually_exclusive_group(required=True)
    mode.add_argument("--start", action="store_true")
    mode.add_argument("--activate", action="store_true")
    mode.add_argument("--reserve", action="store_true")
    mode.add_argument("--release", action="store_true")
    mode.add_argument("--consume", action="store_true")
    mode.add_argument("--find-paid", action="store_true")
    mode.add_argument("--find-reserved", action="store_true")
    p.add_argument("--sender-phone", default="")
    p.add_argument("--chat-id", default="")
    p.add_argument("--message-id", default="")
    p.add_argument("--order-id", default="")
    p.add_argument("--payment-reference", default="")
    p.add_argument("--project-id", default="")
    p.add_argument("--state-path", default=str(STATE_PATH))
    p.add_argument("--config-path", default=str(CONFIG_PATH))
    args = p.parse_args()

    state_path = Path(args.state_path)
    price_cents, checkout_template, fallback_template = _load_flyer_config(Path(args.config_path))
    with FileLock(Path(str(state_path) + ".lock")):
        try:
            if args.start:
                result = start_guest_order(
                    state_path=state_path,
                    sender_phone=args.sender_phone,
                    chat_id=args.chat_id,
                    message_id=args.message_id,
                    checkout_url_template=checkout_template,
                    fallback_checkout_url_template=fallback_template,
                    unit_price_cents=price_cents,
                )
            elif args.activate:
                if not " ".join((args.payment_reference or "").split()):
                    print(json.dumps({
                        "ok": False,
                        "handled": True,
                        "reply_text": "",
                        "order_id": args.order_id,
                        "status": "",
                        "payment_checkout_url": "",
                        "detail": "payment_reference_required",
                    }))
                    return 2
                result = activate_guest_order(
                    state_path=state_path,
                    order_id=args.order_id,
                    sender_phone=args.sender_phone,
                    payment_reference=args.payment_reference,
                )
            elif args.reserve:
                result = reserve_guest_order(
                    state_path=state_path,
                    sender_phone=args.sender_phone,
                    chat_id=args.chat_id,
                    project_id=args.project_id,
                )
            elif args.release:
                result = release_guest_order(
                    state_path=state_path,
                    sender_phone=args.sender_phone,
                    chat_id=args.chat_id,
                    project_id=args.project_id,
                )
            elif args.consume:
                result = consume_guest_order(
                    state_path=state_path,
                    sender_phone=args.sender_phone,
                    chat_id=args.chat_id,
                    project_id=args.project_id,
                )
            elif args.find_paid:
                order = find_paid_guest_order(
                    state_path=state_path,
                    sender_phone=args.sender_phone,
                    chat_id=args.chat_id,
                )
                if order is None:
                    print(json.dumps({"ok": False, "handled": True, "paid_order": False}))
                    return 2
                print(json.dumps({
                    "ok": True,
                    "handled": True,
                    "paid_order": True,
                    "order_id": order.order_id,
                    "status": order.status,
                    "remaining": order.remaining(),
                }))
                return 0
            else:
                order = find_reserved_guest_order(
                    state_path=state_path,
                    sender_phone=args.sender_phone,
                    chat_id=args.chat_id,
                    project_id=args.project_id,
                )
                if order is None:
                    print(json.dumps({"ok": False, "handled": True, "reserved_order": False}))
                    return 2
                print(json.dumps({
                    "ok": True,
                    "handled": True,
                    "reserved_order": True,
                    "order_id": order.order_id,
                    "status": order.status,
                    "reserved_project_id": order.reserved_project_id,
                    "remaining": order.remaining(),
                }))
                return 0
        except Exception as e:  # noqa: BLE001 - CLI returns structured error.
            print(json.dumps({
                "ok": False,
                "handled": True,
                "reply_text": "",
                "order_id": "",
                "status": "",
                "payment_checkout_url": "",
                "detail": f"{type(e).__name__}: {e}",
            }))
            return 2
    return _emit(result)


if __name__ == "__main__":
    raise SystemExit(main())
