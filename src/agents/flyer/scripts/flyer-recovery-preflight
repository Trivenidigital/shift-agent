#!/usr/bin/env python3
"""Preflight checks for Flyer recovery side effects."""
from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import sys

import yaml

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))

from schemas import Config  # noqa: E402


CONFIG_PATH = Path("/opt/shift-agent/config.yaml")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--config-path", default=str(CONFIG_PATH))
    parser.add_argument("--state-root", default="/opt/shift-agent/state/flyer")
    parser.add_argument("--require-send-safe", action="store_true")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--text", action="store_true")
    args = parser.parse_args()

    cfg = Config.model_validate(yaml.safe_load(Path(args.config_path).read_text(encoding="utf-8")) or {})
    safe_io_candidates = [SRC_ROOT / "platform" / "safe_io.py", Path("/opt/shift-agent/safe_io.py")]
    safe_io_text = ""
    for safe_io_path in safe_io_candidates:
        if safe_io_path.exists():
            safe_io_text = safe_io_path.read_text(encoding="utf-8")
            break
    checks = {
        "flyer_enabled": cfg.flyer.enabled,
        "recovery_mode": cfg.flyer.recovery.mode,
        "recovery_timer_enabled": cfg.flyer.recovery.enable_timer,
        "no_live_send_guard": "FLYER_RECOVERY_NO_LIVE_SEND" in safe_io_text,
        "known_emitters": all(token in safe_io_text for token in ["bridge_post", "bridge_send_media"]),
        "state_root": str(Path(args.state_root)),
    }
    ok = bool(checks["no_live_send_guard"])
    if args.require_send_safe and not ok:
        rc = 3
    else:
        rc = 0
    if args.json:
        print(json.dumps({"ok": rc == 0, "checks": checks}, sort_keys=True))
    else:
        print(f"ok={str(rc == 0).lower()} mode={cfg.flyer.recovery.mode} FLYER_RECOVERY_NO_LIVE_SEND={os.environ.get('FLYER_RECOVERY_NO_LIVE_SEND', '')}")
    return rc


if __name__ == "__main__":
    raise SystemExit(main())
