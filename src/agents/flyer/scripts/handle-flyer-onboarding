#!/usr/bin/env python3
"""Advance WhatsApp-native Flyer Studio customer onboarding."""
from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys

SRC_ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(SRC_ROOT / "platform"))
sys.path.insert(0, str(SRC_ROOT))

try:
    from agents.flyer.onboarding import handle_onboarding_message  # type: ignore  # noqa: E402
except ModuleNotFoundError:
    from flyer_onboarding import handle_onboarding_message  # type: ignore  # noqa: E402
try:
    from safe_io import FileLock, atomic_write_text  # type: ignore  # noqa: E402
except ModuleNotFoundError:  # Windows unit-test fallback; VPS uses safe_io.
    class FileLock:  # type: ignore[no-redef]
        def __init__(self, _path: Path) -> None:
            pass

        def __enter__(self) -> "FileLock":
            return self

        def __exit__(self, *_args: object) -> None:
            return None

    def atomic_write_text(path: Path, text: str) -> None:  # type: ignore[no-redef]
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(text, encoding="utf-8")
from schemas import Config, FlyerCustomerCreated, FlyerCustomerStore, FlyerPlanTier  # noqa: E402
try:
    from safe_io import ndjson_append  # type: ignore  # noqa: E402
except Exception:  # noqa: BLE001
    ndjson_append = None  # type: ignore[assignment]


STATE_PATH = Path("/opt/shift-agent/state/flyer/customers.json")
CONFIG_PATH = Path("/opt/shift-agent/config.yaml")
AUDIT_LOG_PATH = Path("/opt/shift-agent/logs/decisions.log")


def _load_flyer_config(path: Path) -> tuple[list[FlyerPlanTier], str, str]:
    try:
        import yaml  # type: ignore

        doc = yaml.safe_load(path.read_text(encoding="utf-8")) or {}
        cfg = Config.model_validate(doc)
        return cfg.flyer.plan_tiers, cfg.flyer.payment_provider, cfg.flyer.payment_checkout_url_template
    except Exception:
        return FlyerPlanTier.default_tiers(), "manual", ""


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--chat-id", required=True)
    p.add_argument("--sender-phone", default="")
    p.add_argument("--message-id", required=True)
    p.add_argument("--text", required=True)
    p.add_argument("--state-path", default=str(STATE_PATH))
    p.add_argument("--config-path", default=str(CONFIG_PATH))
    p.add_argument("--audit-log-path", default=str(AUDIT_LOG_PATH))
    args = p.parse_args()

    state_path = Path(args.state_path)
    tiers, provider, checkout_template = _load_flyer_config(Path(args.config_path))
    with FileLock(Path(str(state_path) + ".lock")):
        result = handle_onboarding_message(
            state_path=state_path,
            chat_id=args.chat_id,
            sender_phone=args.sender_phone or None,
            message_id=args.message_id,
            text=args.text,
            plan_tiers=tiers,
            payment_provider=provider,
            payment_checkout_url_template=checkout_template,
        )
        # Static deploy invariant: this script owns state through FileLock and
        # atomic_write_text. The pure module writes the file directly under
        # this lock so tests can import it on Windows without fcntl.
        if state_path.exists():
            atomic_write_text(state_path, state_path.read_text(encoding="utf-8"))
        if result.customer_created and result.customer_id and result.next_status == "payment_pending" and ndjson_append is not None:
            try:
                store = FlyerCustomerStore.model_validate_json(state_path.read_text(encoding="utf-8"))
                customer = store.find_customer_by_id(result.customer_id)
                if customer:
                    ndjson_append(Path(args.audit_log_path), FlyerCustomerCreated(
                        type="flyer_customer_created",
                        ts=customer.created_at,
                        customer_id=customer.customer_id,
                        business_name=customer.business_name,
                        plan_id=customer.plan_id,
                        primary_chat_id=customer.primary_chat_id,
                    ).model_dump_json())
            except Exception:
                pass

    print(json.dumps({
        "handled": result.handled,
        "reply_text": result.reply_text,
        "next_status": result.next_status,
        "customer_id": result.customer_id,
        "customer_created": result.customer_created,
    }))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
