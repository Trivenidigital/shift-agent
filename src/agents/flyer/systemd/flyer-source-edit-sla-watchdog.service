[Unit]
Description=Flyer source-edit manual queue SLA watchdog
After=network-online.target
Wants=network-online.target
OnFailure=flyer-source-edit-sla-watchdog-failure.service

[Service]
Type=oneshot
User=shift-agent
Group=shift-agent
EnvironmentFile=/opt/shift-agent/.env
Environment=HOME=/opt/shift-agent
Environment=TZ=UTC
ExecStartPre=/usr/bin/test -x /usr/local/bin/flyer-source-edit-sla-watchdog
ExecStart=/usr/local/bin/flyer-source-edit-sla-watchdog --threshold-minutes 10 --repeat-minutes 60 --priority 2
StandardOutput=append:/opt/shift-agent/logs/flyer-source-edit-sla-watchdog.log
StandardError=append:/opt/shift-agent/logs/flyer-source-edit-sla-watchdog.log

NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/shift-agent
ProtectHome=read-only
PrivateTmp=true
RuntimeDirectory=shift-agent

[Install]
WantedBy=multi-user.target
