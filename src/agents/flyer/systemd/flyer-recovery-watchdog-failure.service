[Unit]
Description=Notify owner when Flyer recovery watchdog fails

[Service]
Type=oneshot
User=shift-agent
Group=shift-agent
EnvironmentFile=-/opt/shift-agent/.env
Environment=HOME=/opt/shift-agent
Environment=TZ=UTC
ExecStartPre=/usr/bin/test -x /usr/local/bin/shift-agent-notify-owner
ExecStart=/usr/local/bin/shift-agent-notify-owner --title "Flyer recovery watchdog failed" --priority 2 "The Flyer recovery watchdog failed. Check /opt/shift-agent/logs/flyer-recovery-watchdog.log and systemctl status flyer-recovery-watchdog.service."
SuccessExitStatus=5 6
StandardOutput=append:/opt/shift-agent/logs/flyer-recovery-watchdog.log
StandardError=append:/opt/shift-agent/logs/flyer-recovery-watchdog.log

NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/shift-agent
ProtectHome=read-only
PrivateTmp=true
