#!/usr/bin/env python3
"""
shift-agent-notify-owner — out-of-band owner notification.

Single chokepoint for sending messages to the owner when something needs attention:
  - dead-man alerts (gateway down)
  - send_failed notifications
  - kill-switch confirmations
  - agent-state-change notifications

Strategy:
  1. Pushover first (always-available, not dependent on WA bridge). This is the primary.
  2. If Pushover fails AND bridge is alive, try WhatsApp self-chat as fallback.
  3. If both fail, write to state/notify-failed.log and exit non-zero.

Usage:
  shift-agent-notify-owner "Agent offline — handle manually"
  shift-agent-notify-owner --title "Urgent" --priority high "Bridge disconnected"

Exit codes:
  0 — delivered via at least one channel
  6 — all channels failed
  5 — config invalid
"""

from __future__ import annotations
import argparse
import json
import os
import sys
import urllib.error
import urllib.parse  # P1-FIX: was missing; every Pushover call would have crashed with AttributeError
import urllib.request
from pathlib import Path
from datetime import datetime, timezone

sys.path.insert(0, "/opt/shift-agent")
from safe_io import customer_now, FileLock, ndjson_append  # noqa: E402
from schemas import Config, OwnerNotificationSuppressed, OwnerWellbeingConfig  # noqa: E402
from exit_codes import EXIT_OK, EXIT_DEPENDENCY_DOWN, EXIT_SCHEMA_VIOLATION  # noqa: E402
import yaml


CONFIG_PATH = Path("/opt/shift-agent/config.yaml")
STATE_DIR = Path("/opt/shift-agent/state")
NOTIFY_FAILED_LOG = STATE_DIR / "notify-failed.log"
DECISIONS_LOG_PATH = Path("/opt/shift-agent/logs/decisions.log")
# Module-level constants — extracted so tests can monkey-patch via
# `mod.PUSHOVER_URL = stub_url` after importlib.exec_module (R1-M5 design fix).
PUSHOVER_URL = "https://api.pushover.net/1/messages.json"
WHATSAPP_BRIDGE_URL = "http://127.0.0.1:3000/send"


def load_config() -> Config:
    with CONFIG_PATH.open() as f:
        raw = yaml.safe_load(f)
    return Config.model_validate(raw)


def pushover_send(cfg: Config, message: str, title: str, priority: int) -> tuple[bool, str]:
    """Send via Pushover. Returns (ok, detail)."""
    data = {
        "token": cfg.alerting.pushover_app_token,
        "user": cfg.alerting.pushover_user_key,
        "message": message[:1024],  # Pushover caps at 1024
        "title": title[:250],
        "priority": str(priority),
    }
    # priority 2 requires retry+expire
    if priority == 2:
        data["retry"] = "60"
        data["expire"] = "3600"
    # P1-FIX: use urlencode for correct form-encoding (spaces, &, = in values)
    body = urllib.parse.urlencode(data).encode()
    req = urllib.request.Request(
        PUSHOVER_URL,
        data=body,
        headers={"Content-Type": "application/x-www-form-urlencoded"},
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            raw = resp.read().decode()
            parsed = json.loads(raw)
            if parsed.get("status") == 1:
                return True, "ok"
            return False, f"pushover status={parsed.get('status')}: {parsed.get('errors')}"
    except urllib.error.URLError as e:
        return False, f"pushover URLError: {e}"
    except Exception as e:
        return False, f"pushover error: {e}"


def whatsapp_fallback(cfg: Config, message: str) -> tuple[bool, str]:
    """Try WhatsApp self-chat via bridge port 3000. Best-effort only."""
    self_chat_jid = cfg.owner.self_chat_jid
    if not self_chat_jid:
        return False, "self_chat_jid not configured"
    data = json.dumps({"jid": self_chat_jid, "text": message}).encode()
    req = urllib.request.Request(
        WHATSAPP_BRIDGE_URL,
        data=data,
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return resp.status == 200, f"bridge status={resp.status}"
    except Exception as e:
        return False, f"bridge error: {e}"


_SECRET_HINT_RE = None  # lazy-init


def _redact(s: str) -> str:
    """Replace any substring that looks like a Pushover token/key with <REDACTED>."""
    global _SECRET_HINT_RE
    if _SECRET_HINT_RE is None:
        import re
        _SECRET_HINT_RE = re.compile(r"[a-z0-9]{30,}", re.IGNORECASE)
    return _SECRET_HINT_RE.sub("<REDACTED>", s or "")


def _in_quiet_window(now_local: datetime, cfg: OwnerWellbeingConfig) -> bool:
    """Pure helper: is now_local inside the configured quiet window?

    Two branches:
    - Same-day window (start < end, e.g. 13:00-15:00): suppressed iff
      start <= now_time < end.
    - Cross-midnight window (start > end, e.g. 22:00-06:00): suppressed iff
      now_time >= start OR now_time < end.
    - start == end is rejected at config-validation time (zero-width
      window would silently never fire — see _reject_zero_width_window).

    Boundary semantics: now == start → suppressed; now == end → NOT
    suppressed (>= start, < end).

    Lexicographic string compare on "HH:MM" is correct because the regex
    `^([01]\\d|2[0-3]):[0-5]\\d$` enforces fixed-width 5-char zero-padded
    ASCII. If that regex ever loosens, this comparison will silently
    misorder times.

    DST: wall-clock semantics intentional. On spring-forward, the
    02:00-03:00 hour is skipped entirely; on fall-back the 01:00-02:00
    hour repeats. Both physical clocks map to the same HH:MM local string
    and produce the same suppression decision — desired for owner-facing
    quiet hours.
    """
    weekday = now_local.strftime("%a").lower()  # "mon", "tue", ...
    if weekday not in cfg.quiet_days:
        return False
    now_time = now_local.strftime("%H:%M")
    start = cfg.quiet_start
    end = cfg.quiet_end
    if start < end:
        # Same-day window
        return start <= now_time < end
    # Cross-midnight window (start > end is the only remaining case;
    # start == end is rejected at config validation).
    return now_time >= start or now_time < end


def _apply_quiet_hours_guard(
    cfg: Config, title: str, priority: int,
) -> tuple[bool, "OwnerNotificationSuppressed | None"]:
    """Return (suppress, audit_entry_or_None).

    Short-circuit when cfg.owner_wellbeing.enabled is False (the default
    state — guard is a no-op until the owner explicitly opts in).
    """
    ow = cfg.owner_wellbeing
    if not ow.enabled:
        return (False, None)
    if priority >= ow.critical_priority_threshold:
        return (False, None)
    now_local = customer_now(cfg.customer.timezone)
    if not _in_quiet_window(now_local, ow):
        return (False, None)
    entry = OwnerNotificationSuppressed(
        type="owner_notification_suppressed",
        ts=now_local,
        title=title[:250],
        priority=priority,
        quiet_start=ow.quiet_start,
        quiet_end=ow.quiet_end,
        quiet_days=list(ow.quiet_days),
        suppressed_at_local=now_local.strftime("%H:%M:%S"),
    )
    return (True, entry)


def append_notify_failed(message: str, results: list[tuple[str, bool, str]]) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    # Code-quality-M11 FIX: utcnow() deprecated in 3.12+, returns naive datetime; use timezone-aware
    entry = {
        "ts": datetime.now(timezone.utc).isoformat(),
        "message": message,
        # Security-H2 FIX: redact detail strings that might echo the Pushover token from API error responses
        "results": [{"channel": c, "ok": ok, "detail": _redact(d)} for c, ok, d in results],
    }
    with FileLock(NOTIFY_FAILED_LOG.with_suffix(".log.lock")):
        with NOTIFY_FAILED_LOG.open("a") as f:
            f.write(json.dumps(entry) + "\n")


def main():
    ap = argparse.ArgumentParser(description="Out-of-band owner notification")
    ap.add_argument("message", help="Message body")
    ap.add_argument("--title", default="Shift Agent", help="Alert title")
    ap.add_argument(
        "--priority",
        type=int,
        default=0,
        choices=[-2, -1, 0, 1, 2],
        help="Pushover priority: -2 silent, -1 quiet, 0 normal, 1 high, 2 emergency",
    )
    args = ap.parse_args()

    try:
        cfg = load_config()
    except Exception as e:
        print(f"FATAL: cannot load config: {e}", file=sys.stderr)
        # Still try to write to notify-failed log
        append_notify_failed(args.message, [("config_load", False, str(e))])
        return EXIT_SCHEMA_VIOLATION

    results: list[tuple[str, bool, str]] = []

    # Agent #41 v0.1 quiet-hours guard. No-op when cfg.owner_wellbeing.enabled is False.
    suppress, audit_entry = _apply_quiet_hours_guard(cfg, args.title, args.priority)
    if suppress:
        # Wrap ndjson_append in flock for inter-process safety. Multiple
        # shift-agent-notify-owner processes can fire simultaneously
        # (backup + health + watchdog) — O_APPEND alone is atomic only up to
        # PIPE_BUF/4096 bytes; OwnerNotificationSuppressed rows can interleave.
        # Mirrors send-daily-brief precedent.
        try:
            DECISIONS_LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
            with FileLock(DECISIONS_LOG_PATH.with_suffix(".log.lock")):
                ndjson_append(DECISIONS_LOG_PATH, audit_entry.model_dump_json())
        except Exception as e:
            # Audit failure must NOT prevent the success-skip return path —
            # the alternative is "alert was suppressed AND lost" which is
            # worse than "suppressed but no audit row." Pattern matches
            # cf-router/actions.py audit-emit conventions.
            print(
                f"WARN: audit emit failed for owner_notification_suppressed: {e}",
                file=sys.stderr,
            )
        return EXIT_OK

    # Primary: Pushover
    ok, detail = pushover_send(cfg, args.message, args.title, args.priority)
    results.append(("pushover", ok, detail))
    if ok:
        return EXIT_OK

    # Fallback: WhatsApp self-chat
    print(f"Pushover failed ({detail}); trying WhatsApp fallback", file=sys.stderr)
    ok, detail = whatsapp_fallback(cfg, f"[{args.title}] {args.message}")
    results.append(("whatsapp", ok, detail))
    if ok:
        return EXIT_OK

    # Both failed — log + exit
    append_notify_failed(args.message, results)
    print(f"ALL NOTIFICATION CHANNELS FAILED: {results}", file=sys.stderr)
    return EXIT_DEPENDENCY_DOWN


if __name__ == "__main__":
    sys.exit(main())
