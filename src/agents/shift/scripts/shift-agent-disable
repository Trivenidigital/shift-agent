#!/usr/bin/env bash
# shift-agent-disable — kill switch.
# Stops gateway + timers, sets disabled.flag, notifies owner via Pushover.
#
# Usage: shift-agent-disable [reason]
# Exit 0 on success; non-zero if notification fails (so operator sees).

set -euo pipefail

# P4-FIX: Security-C2 — allowlist-strip REASON to prevent NDJSON/shell injection.
# Previous version interpolated raw $REASON into a heredoc JSON body, which
# accepted double-quotes, newlines, and would have corrupted the audit log.
REASON_RAW="${1:-manual_kill}"
REASON="${REASON_RAW//[^a-zA-Z0-9_ .-]/}"
# Cap length so a huge input can't balloon the log line
REASON="${REASON:0:200}"
if [ -z "$REASON" ]; then
    REASON="manual_kill"
fi

# Stop services (don't fail if already stopped)
systemctl stop hermes-gateway || true
systemctl stop shift-agent-tail-logger.timer || true
systemctl stop shift-agent-tail-logger.service || true
systemctl stop shift-agent-health.timer || true

# Set disabled flag
touch /opt/shift-agent/state/disabled.flag

# Log the state change via log-decision-direct
TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
/usr/local/bin/log-decision-direct "$(cat <<JSON
{"type":"agent_state_change","ts":"$TS","to_state":"disabled","reason":"$REASON"}
JSON
)"

# Notify owner — fail loudly if notification fails
if ! /usr/local/bin/shift-agent-notify-owner \
    --title "Shift Agent DISABLED" \
    --priority 1 \
    "Agent offline. Reason: $REASON. Please handle sick-call coverage manually. Run 'shift-agent-enable' to restore."; then
    echo "ERROR: owner notification failed — agent IS disabled but owner may not know" >&2
    exit 1
fi

echo "Agent disabled. Reason: $REASON"
