[Unit]
Description=Hermes version-check monitor (read-only; reports upstream vs pinned baseline)
After=network-online.target hermes-gateway.service
Wants=network-online.target
OnFailure=hermes-version-check-failure.service

[Service]
Type=oneshot
User=shift-agent
Group=shift-agent
Environment=HOME=/opt/shift-agent
Environment=TZ=UTC
ExecStart=/usr/local/lib/hermes-agent/venv/bin/python /usr/local/bin/hermes-version-check --text
# stdout/stderr go to the journal; the script owns its report files
# (/opt/shift-agent/logs/hermes-version-check.{json,jsonl}). Do NOT point a
# StandardOutput=append:<file> at a script-written file — systemd creates that file
# as root and the shift-agent process then can't append to it.
StandardOutput=journal
StandardError=journal

# Read-only monitor: it never mutates Hermes, so confine writes to the report dir.
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/shift-agent
ProtectHome=read-only
PrivateTmp=true
