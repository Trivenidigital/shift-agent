[Unit]
Description=Shift Agent — health check probe
After=hermes-gateway.service

[Service]
Type=oneshot
User=shift-agent
Group=shift-agent
EnvironmentFile=/opt/shift-agent/.env
ExecStart=/usr/local/bin/shift-agent-health-check.sh
NoNewPrivileges=true
# Allow ss/systemctl/curl; don't restrict system access too aggressively here — this script NEEDS visibility
