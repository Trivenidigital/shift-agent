[Unit]
Description=Shift Agent — boot-time reconciler for crashed mid-send proposals
Before=hermes-gateway.service
# Note: runs at boot, NOT on a timer. Checks for stuck proposals + retries missed sends.

[Service]
Type=oneshot
User=shift-agent
Group=shift-agent
EnvironmentFile=/opt/shift-agent/.env
ExecStart=/usr/local/bin/shift-agent-reconcile.py
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
