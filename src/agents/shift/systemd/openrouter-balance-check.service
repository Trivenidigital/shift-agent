[Unit]
Description=OpenRouter account-balance threshold check (one-shot)
After=network-online.target
Wants=network-online.target
OnFailure=openrouter-balance-check-failure.service

[Service]
Type=oneshot
User=shift-agent
Group=shift-agent
# systemd (root) reads the EnvironmentFile before dropping to User=, so
# OPENROUTER_API_KEY reaches the process env even though shift-agent cannot
# read /root/.hermes/.env directly (the symlink target).
EnvironmentFile=/opt/shift-agent/.env
Environment=HOME=/opt/shift-agent
Environment=TZ=UTC

# ExecStartPre instead of ConditionPathIsExecutable: condition-failure produces
# systemd result "condition" which does NOT trigger OnFailure=; test-x failure
# produces "exit-code" which DOES (mirrors send-routing-accuracy-summary).
ExecStartPre=/usr/bin/test -x /usr/local/bin/check-openrouter-balance
ExecStartPre=/usr/bin/test -x /usr/local/bin/shift-agent-notify-owner
ExecStart=/usr/local/bin/check-openrouter-balance
StandardOutput=append:/opt/shift-agent/logs/openrouter-balance.log
StandardError=append:/opt/shift-agent/logs/openrouter-balance.log

# Security hardening (mirrors send-routing-accuracy-summary.service)
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/shift-agent
ProtectHome=read-only
PrivateTmp=true
RuntimeDirectory=shift-agent

[Install]
WantedBy=multi-user.target
