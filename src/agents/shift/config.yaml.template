# Shift Agent — per-customer configuration.
# Copy to /opt/shift-agent/config.yaml and fill in customer-specific values.
# Validated on every script invocation via schemas.py:Config.
# Missing REQUIRED fields will cause the agent to refuse to start.

schema_version: 1

customer:
  name: "Customer Name"
  location_id: "loc_xxx_01"
  timezone: "America/New_York"   # IANA timezone (validated by ZoneInfo)
  languages: ["en", "te", "hi"]  # ISO codes the skill actively supports

owner:
  name: "Owner Full Name"
  phone: "+19045550100"           # E.164 canonical — NO dashes
  self_chat_jid: ""               # leave empty; populated on first owner message

limits:
  max_outbound_per_day: 6         # heuristic: 2x typical daily absence rate (~10% of roster size)
  max_outbound_per_minute: 30     # Baileys-safe ceiling
  pending_proposal_ttl_hours: 4   # proposals unapproved longer → owner dead-man
  per_message_timeout_sec: 120    # LLM call timeout
  send_failure_retry_count: 1     # retry send once, then fail loudly
  # No-response escalation sweep (owner-experience review 2026-07-10): when a candidate hasn't
  # replied to a coverage request within candidate_response_ttl_minutes, mark the proposal
  # no_response_timeout and alert you the shift is still uncovered. Ships OFF — set enabled: true
  # to activate per-customer (takes effect within ~15 min; no redeploy, no restart).
  no_response_sweep_enabled: false
  candidate_response_ttl_minutes: 30
  # Owner-approval expiry (BL-SHIFT-04): the same sweep expires proposals you haven't
  # approved within pending_proposal_ttl_hours (above), marks them `expired`, and alerts
  # you — making the card's "expires 4h after creation" line true. Ships OFF — set
  # enabled: true to activate per-customer (takes effect within ~15 min; no redeploy).
  owner_approval_expiry_enabled: false

alerting:
  # REQUIRED — agent refuses to start if either is empty.
  # Create at pushover.net/api (5-minute signup, $5 one-time device fee).
  pushover_user_key: "REQUIRED_FILL_ME_IN"
  pushover_app_token: "REQUIRED_FILL_ME_IN"
  # Optional: free external heartbeat. Create at healthchecks.io.
  healthchecks_io_url: ""
  # Optional: email (secondary; not yet wired in v2).
  email: ""

backup:
  # GPG public key RECIPIENT — the private key must NEVER be on this VPS.
  gpg_recipient_email: "your-email@example.com"
  # Optional: S3 bucket for off-site copy. Requires aws CLI + creds.
  s3_bucket: ""
  retention_days: 30

operations:
  # Labels alert urgency. Agent runs 24/7 regardless.
  business_hours_local: "08:00-22:00"

# Agent #4 — Daily Brief. All fields optional; defaults shown.
# Brief fires every morning at brief_time in the customer timezone.
# If VPS was down at brief_time, catch-up window allows late delivery
# up to catchup_window_minutes; past that, owner gets a Pushover
# instead of a stale brief.
daily_brief:
  enabled: true
  brief_time: "07:00"          # HH:MM in customer.timezone (regex-validated)
  max_words: 150               # soft cap — renderer trims if exceeded
  sections:                    # at least one required
    - "yesterday"
    - "today_outlook"
    - "alerts"
  catchup_window_minutes: 180  # 3h grace period after brief_time

# Agent #5 — EOD Reconciliation. Snapshot of today's events at close time.
# Output is consumed by Daily Brief tomorrow morning + sent to owner via Pushover.
eod:
  enabled: true
  eod_time: "22:00"            # HH:MM in customer.timezone
  catchup_window_minutes: 120
  pushover_priority: 0         # -2..+2; auto-bumped to 1 if unresolved/failures exist
  pushover_only_if_unresolved: true  # quiet days: no Pushover

# Agent #3 — Multi-Location Coordinator. Single-location customers leave
# `locations: []` — Agent #3 self-disables. For multi-location operators
# (e.g. Triveni's 9 stores across TX/MD/NC/SC/OH/VA), populate the list
# below. Each location can override the global timezone.
multi_location:
  enabled: true
  require_owner_approval_for_transfers: true
  locations: []
  # Example for a multi-location operator:
  # locations:
  #   - id: "loc_jax_01"
  #     name: "Jacksonville"
  #     timezone: "America/New_York"
  #     address_short: "Jacksonville, FL"
  #   - id: "loc_dal_01"
  #     name: "Dallas"
  #     timezone: "America/Chicago"
  #     address_short: "Dallas, TX"

# Agent #2 — Catering Lead. Default OFF (opt-in). When enabled, customer
# catering inquiries flow through extract → owner approval → send-quote.
# v0.1: schemas + SKILL stubs only. Real classifier/extractor/drafter
# lands in v0.2 once a pilot customer onboards.
catering:
  enabled: false
  deposit_threshold_guests: 50      # require deposit for events >= N guests
  deposit_pct: 0.25                 # 25% deposit
  stale_after_hours: 336            # 14 days — silent leads move to STALE

# Agent #21 — Expense Bookkeeper. Default OFF (opt-in). v0.1 ships with
# mocked QBOClient; v0.2 will swap to real QBO OAuth + write API.
expense_bookkeeper:
  enabled: false
  cockpit_threshold_cents: 5000
  auto_categorize_threshold: 0.85
  require_owner_approval_for_personal_flag: true
  reversibility_window_hours: 24
  dedup_hash_distance_threshold: 4
  receipt_retention_days: 90
  proposal_ttl_hours: 72
  qbo_client_mode: mock
