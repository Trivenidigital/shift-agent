#!/usr/bin/env python3
"""send-daily-brief — Agent #4 morning summary to owner's WhatsApp self-chat.

Triggered by send-daily-brief.timer every 15 min. Self-gates on
cfg.daily_brief.brief_time in the customer's timezone.

Idempotency (3 layers):
  1. FileLock(state/last-brief-sent.json.lock) prevents concurrent runs
  2. Sentinel state/last-brief-sent.json (atomic) — fast "already sent today" check
  3. BriefAttempted log entry written BEFORE bridge POST — recovery anchor
     for crash-between-send-and-log scenario; if found within 30 min and no
     matching BriefSent, refuses to auto-resend (operator must verify).

CLI flags:
  --force         bypass self-gate window only; idempotency still applies
  --force-resend  bypass idempotency too (DANGEROUS, requires --force; for testing)
  --dry-run       run aggregation + render but skip bridge POST and log appends
"""
from __future__ import annotations

import argparse
import json
import os
import sys
import time
import urllib.error
import urllib.request
import uuid
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Optional

# sys.path bootstrap — prefer /opt/shift-agent (deployed) but accept src/platform for tests
sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent.parent / "platform"))

from safe_io import (  # noqa: E402
    FileLock, atomic_write_json, ndjson_append, customer_now, customer_today_str,
    safe_load_json, load_model, assert_local_disk, flock,
    notify_owner_with_fallback, self_gate_window_state,
    # Bridge POST + constants — extracted to safe_io 2026-05-04 (PR-Agent13 Commit 0).
    bridge_post, validate_bridge_url,
    BRIDGE_URL, BRIDGE_TIMEOUT_SEC, BRIDGE_RETRY_DELAY_SEC, ALLOW_REMOTE_BRIDGE,
)
from schemas import (  # noqa: E402
    Config, Roster, PendingStore,
    BriefAttempted, BriefSent, BriefSendFailed, BriefSkipped,
    CustomerBirthdayStore,
)
from log_source import get_log_sources  # noqa: E402
from exit_codes import (  # noqa: E402
    EXIT_OK, EXIT_GENERIC_ERROR, EXIT_INVALID_INPUT,
    EXIT_DEPENDENCY_DOWN, EXIT_SCHEMA_VIOLATION, EXIT_NOT_FOUND,
)
from pydantic import TypeAdapter  # noqa: E402

# ─────────────────────────────────────────────────────────────────
# Constants
# ─────────────────────────────────────────────────────────────────

CONFIG_PATH = Path(os.environ.get("SHIFT_AGENT_CONFIG_PATH", "/opt/shift-agent/config.yaml"))
ROSTER_PATH = Path(os.environ.get("SHIFT_AGENT_ROSTER_PATH", "/opt/shift-agent/roster.json"))
PENDING_PATH = Path(os.environ.get("SHIFT_AGENT_PENDING_PATH", "/opt/shift-agent/state/pending.json"))
DECISIONS_LOG = Path(os.environ.get("SHIFT_AGENT_DECISIONS_LOG_PATH", "/opt/shift-agent/logs/decisions.log"))
SENTINEL_PATH = Path(os.environ.get("SHIFT_AGENT_BRIEF_SENTINEL_PATH", "/opt/shift-agent/state/last-brief-sent.json"))
BIRTHDAYS_PATH = Path(os.environ.get("SHIFT_AGENT_BIRTHDAYS_PATH", "/opt/shift-agent/state/customer-birthdays.json"))
DISABLED_FLAG = Path(os.environ.get("SHIFT_AGENT_DISABLED_FLAG", "/opt/shift-agent/state/disabled.flag"))
TEMPLATES_DIR = Path(os.environ.get("SHIFT_AGENT_TEMPLATES_DIR", "/opt/shift-agent/templates"))
RENDER_TEMPLATE_BIN = os.environ.get("SHIFT_AGENT_RENDER_TEMPLATE_BIN", "/usr/local/bin/render-coverage-template")
# NOTIFY_OWNER_BIN + NOTIFY_FAILED_LOG removed 2026-04-30 — both env vars are
# now read by safe_io.notify_owner_with_fallback at its module-import time
# inside the same subprocess (see env-var compat note in helper docstring).

# BRIDGE_URL, BRIDGE_TIMEOUT_SEC, BRIDGE_RETRY_DELAY_SEC, ALLOW_REMOTE_BRIDGE
# all moved to safe_io 2026-05-04 (PR-Agent13 Commit 0); imported above.

SELF_GATE_WINDOW_MIN = 15  # must match send-daily-brief.timer OnUnitActiveSec
# Recovery window for orphaned BriefAttempted entries — set to catchup_window_minutes
# default (180 min) to prevent silent duplicate when an orphan is older than the
# old 30-min cutoff but the brief actually succeeded.
BRIEF_ATTEMPT_RECOVERY_WINDOW_MIN = 180

MAX_LOG_LINE_BYTES = 64 * 1024  # DoS guard for log iteration

# Watchdog: detects "weekly routing-accuracy cron stopped firing" via the
# timestamp file written by send-routing-accuracy-summary on every healthy run.
WATCHDOG_PATH = Path("/opt/shift-agent/state/routing-summary-last-run.json")
WATCHDOG_TIMER_UNIT = Path("/etc/systemd/system/send-routing-accuracy-summary.timer")
WATCHDOG_STALE_DAYS = 10
WATCHDOG_TS_KEY = "ts"

_LOG_ADAPTER_ATTEMPTED = TypeAdapter(BriefAttempted)
_LOG_ADAPTER_SENT = TypeAdapter(BriefSent)
_LOG_ADAPTER_FAILED = TypeAdapter(BriefSendFailed)
_LOG_ADAPTER_SKIPPED = TypeAdapter(BriefSkipped)

# ─────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────


def _now_override() -> Optional[datetime]:
    """Test hook: SHIFT_AGENT_NOW_OVERRIDE='2026-04-28T07:05:00-04:00' freezes time."""
    raw = os.environ.get("SHIFT_AGENT_NOW_OVERRIDE")
    if not raw:
        return None
    try:
        return datetime.fromisoformat(raw)
    except ValueError:
        return None


def _customer_now(tz: str) -> datetime:
    override = _now_override()
    if override is not None:
        return override
    return customer_now(tz)


def _check_disabled() -> bool:
    return DISABLED_FLAG.exists()


def _self_gate_state(now_local: datetime, brief_time_str: str, catchup_min: int) -> tuple[str, int]:
    """Return ('before' | 'in_window' | 'in_catchup' | 'past_catchup', minutes_late).

    Refactored 2026-04-30 to call shared safe_io.self_gate_window_state
    (was inline; deduplicated with eod-reconcile)."""
    return self_gate_window_state(
        now_local, brief_time_str,
        window_min=SELF_GATE_WINDOW_MIN, catchup_min=catchup_min,
    )


def _read_sentinel() -> Optional[dict]:
    """Return sentinel dict (or None if missing/invalid). Should be called under FileLock."""
    if not SENTINEL_PATH.exists():
        return None
    val, status = safe_load_json(SENTINEL_PATH, default=None)
    if status != "ok":
        return None
    return val if isinstance(val, dict) else None


def _scan_recent_brief_attempted(today_str: str, now_local: datetime) -> tuple[Optional[dict], bool]:
    """Return (orphan_entry_or_None, scan_failed).

    `scan_failed=True` means the log was unreadable — caller MUST treat as
    uncertain (refuse send) rather than assuming no orphan exists. Silently
    swallowing OSError + returning (None, False) was the bug that allowed
    duplicate brief sends on disk-error days.
    """
    if not DECISIONS_LOG.exists():
        return None, False
    cutoff = now_local - timedelta(minutes=BRIEF_ATTEMPT_RECOVERY_WINDOW_MIN)
    attempted_by_id: dict[str, dict] = {}
    sent_ids: set[str] = set()
    try:
        with open(DECISIONS_LOG, "r", encoding="utf-8", errors="replace") as f:
            while True:
                # Cap at MAX_LOG_LINE_BYTES to defend against malicious/corrupt
                # writers dropping a multi-MB line and OOMing the brief job.
                line = f.readline(MAX_LOG_LINE_BYTES + 1)
                if not line:
                    break
                if len(line.encode("utf-8", errors="replace")) > MAX_LOG_LINE_BYTES:
                    # Oversize line — count as parse failure but keep scanning
                    continue
                line = line.strip()
                if not line:
                    continue
                try:
                    e = json.loads(line)
                except json.JSONDecodeError:
                    continue
                t = e.get("type")
                if t == "brief_attempted" and e.get("brief_date") == today_str:
                    ts_str = e.get("ts", "")
                    try:
                        ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
                    except ValueError:
                        continue
                    if ts >= cutoff:
                        attempted_by_id[e.get("attempt_id", "")] = e
                elif t == "brief_sent" and e.get("brief_date") == today_str:
                    sent_ids.add(e.get("attempt_id", ""))
    except OSError as e:
        sys.stderr.write(f"WARN: scan recent BriefAttempted failed: {e}\n")
        return None, True  # FAIL CLOSED — caller treats as uncertain
    for aid, entry in attempted_by_id.items():
        if aid not in sent_ids:
            return entry, False
    return None, False


def _aggregate_yesterday(cfg: Config) -> tuple[dict, bool]:
    """Return (counts_dict, degraded_mode). Reads all registered LogSources for the
    customer-tz "yesterday" window."""
    tz = cfg.tz()
    now_local = _customer_now(cfg.customer.timezone)
    today = now_local.replace(hour=0, minute=0, second=0, microsecond=0)
    yesterday_start = today - timedelta(days=1)
    yesterday_end = today

    counts = {
        "sick_calls": 0,
        "proposals_created": 0,
        "proposals_accepted": 0,
        "proposals_declined": 0,
        "proposals_no_response": 0,
        "outbound_sent": 0,
        "outbound_send_failed": 0,
        "agent_state_changes": 0,
        "invariant_violations": 0,
    }
    degraded = False

    for source in get_log_sources():
        entries, stats = source.iter_entries(yesterday_start, yesterday_end)
        if stats.parse_failures > 0 or stats.oserror is not None or (stats.file_missing and source.agent_name == "shift"):
            # Shift's log is REQUIRED in v0.1; missing it = degraded mode
            degraded = True
        for e in entries:
            t = e.get("type")
            if t == "raw_inbound":
                counts["sick_calls"] += 1
            elif t == "proposal_created":
                counts["proposals_created"] += 1
            elif t == "proposal_status_change":
                to = e.get("to_status")
                if to == "accepted":
                    counts["proposals_accepted"] += 1
                elif to == "declined":
                    counts["proposals_declined"] += 1
                elif to == "no_response_timeout":
                    counts["proposals_no_response"] += 1
            elif t == "outbound_sent":
                counts["outbound_sent"] += 1
            elif t == "outbound_send_failed":
                counts["outbound_send_failed"] += 1
            elif t == "agent_state_change":
                counts["agent_state_changes"] += 1
            elif t == "invariant_violation":
                counts["invariant_violations"] += 1

    return counts, degraded


def _aggregate_today(cfg: Config) -> tuple[dict, bool]:
    """Return (today_dict, degraded_mode)."""
    today_str = customer_today_str(cfg.customer.timezone)
    out = {
        "today_date": today_str,
        "shifts_today": [],
        "pending_active_count": 0,
        "pending_send_failed_count": 0,
    }
    degraded = False

    # Roster: today's schedule
    try:
        roster, status = load_model(ROSTER_PATH, Roster)
        if status == "ok":
            day_entries = roster.schedule.get(today_str, [])
            out["shifts_today"] = [
                {"employee_id": s.employee_id, "shift": s.shift, "role": s.role}
                for s in day_entries
            ]
        else:
            degraded = True
    except Exception:
        degraded = True

    # Pending: counts of non-terminal proposals
    try:
        pending, status = load_model(PENDING_PATH, PendingStore)
        if status == "ok":
            for p in pending.proposals:
                if p.status in ("awaiting_owner_approval", "approved", "reconciling", "sent"):
                    out["pending_active_count"] += 1
                if p.status == "send_failed":
                    out["pending_send_failed_count"] += 1
        elif status == "missing" or status == "empty":
            pass  # zero counts is correct
        else:
            degraded = True
    except Exception:
        degraded = True

    return out, degraded


def _aggregate_birthdays(today_local: datetime) -> list[dict]:
    """Agent #33 v0.1: returns list of {phone, name} dicts for customers
    whose birthday matches today_local's MM-DD. Falls open on missing/
    corrupt file — returns [], emits stderr WARN. Matches
    _aggregate_yesterday's degraded-mode philosophy.

    Caller MUST gate on 'birthdays' in cfg.daily_brief.sections; this
    helper does not check the section opt-in itself.
    """
    if not BIRTHDAYS_PATH.exists():
        return []
    try:
        store, status = load_model(
            BIRTHDAYS_PATH, CustomerBirthdayStore,
            default=CustomerBirthdayStore(),
        )
        if not status.startswith("ok"):
            sys.stderr.write(
                f"WARN: customer-birthdays.json status={status!r}; "
                f"birthdays section degraded\n"
            )
            return []
    except Exception as e:
        sys.stderr.write(f"WARN: birthday load failed: {e}; section degraded\n")
        return []
    today_md = today_local.strftime("%m-%d")
    return [
        {"phone": c.customer_phone, "name": c.display_name}
        for c in store.customers
        if c.birthday == today_md
    ]


def _render_birthdays(birthdays_today: list[dict]) -> str:
    """Single-line summary. 'None today.' if empty; else
    'Suresh Patel (+15555550100), Priya Reddy (+15555550101)'."""
    if not birthdays_today:
        return "None today."
    return ", ".join(f"{b['name']} ({b['phone']})" for b in birthdays_today)


def _render_yesterday(counts: dict) -> str:
    """Format yesterday counts as a single-line bullet summary."""
    sc = counts["sick_calls"]
    pc = counts["proposals_created"]
    pa = counts["proposals_accepted"]
    pd_ = counts["proposals_declined"]
    pn = counts["proposals_no_response"]
    if sc == 0 and pc == 0:
        return "Quiet day — 0 sick calls, 0 proposals."
    parts = [f"{sc} sick call{'' if sc == 1 else 's'}"]
    if pc > 0:
        outcomes = []
        if pa > 0:
            outcomes.append(f"{pa} accepted")
        if pd_ > 0:
            outcomes.append(f"{pd_} declined")
        if pn > 0:
            outcomes.append(f"{pn} no-response")
        outcomes_s = f" ({', '.join(outcomes)})" if outcomes else ""
        parts.append(f"{pc} proposal{'' if pc == 1 else 's'}{outcomes_s}")
    return ", ".join(parts) + "."


def _render_today(today: dict) -> str:
    n = len(today["shifts_today"])
    pending = today["pending_active_count"]
    if n == 0 and pending == 0:
        return "No shifts scheduled, nothing pending."
    parts = [f"{n} scheduled shift{'' if n == 1 else 's'}"]
    if pending > 0:
        parts.append(f"{pending} pending proposal{'' if pending == 1 else 's'}")
    return ", ".join(parts) + "."


def _render_alerts(yesterday: dict, today: dict) -> str:
    alerts = []
    if yesterday["outbound_send_failed"] > 0:
        alerts.append(f"{yesterday['outbound_send_failed']} outbound send failed yesterday")
    if yesterday["invariant_violations"] > 0:
        alerts.append(f"{yesterday['invariant_violations']} invariant violation(s) yesterday")
    if today["pending_send_failed_count"] > 0:
        alerts.append(f"{today['pending_send_failed_count']} proposal stuck in send_failed")
    if not alerts:
        return "Nothing — all green."
    return "; ".join(alerts) + "."


def _render_brief_text(
    cfg: Config,
    today_str: str,
    yesterday_counts: dict,
    today_data: dict,
    degraded: bool,
    catchup_minutes_late: int,
) -> str:
    """Render the brief by interpolating into the template (no LLM in v0.1)."""
    template_path = TEMPLATES_DIR / "daily_brief.txt"
    template = template_path.read_text(encoding="utf-8")
    header = ""
    if degraded:
        header = "WARNING: DEGRADED BRIEF — some data sources unavailable. Outlook + alerts may be incomplete.\n\n"
    catchup_note = f" (catch-up: {catchup_minutes_late} min late)" if catchup_minutes_late > 0 else ""

    # Agent #33 v0.1: conditional render. Only include the birthdays line if
    # the section is in cfg.daily_brief.sections (R1-B1 fix from PR review —
    # prevents permanent "Birthdays today: None today." line for customers
    # who haven't opted in).
    if "birthdays" in cfg.daily_brief.sections:
        today_local = _customer_now(cfg.customer.timezone)
        birthdays_today = _aggregate_birthdays(today_local)
        # R2-M2 PR review fix: \n\n matches the blank-line spacing between
        # peer sections (see template: yesterday → today_outlook → alerts each
        # separated by blank lines). \n alone visually attaches birthdays
        # to the alerts line.
        birthdays_block = f"\n\n*Birthdays today:* {_render_birthdays(birthdays_today)}"
    else:
        birthdays_block = ""

    fields = {
        "header": header,
        "brief_date": today_str,
        "catchup_note": catchup_note,
        "yesterday_summary": _render_yesterday(yesterday_counts),
        "today_outlook": _render_today(today_data),
        "alerts_summary": _render_alerts(yesterday_counts, today_data),
        "birthdays_block": birthdays_block,
    }
    return template.format(**fields)


# _validate_bridge_url + _bridge_post moved to safe_io 2026-05-04 (PR-Agent13
# Commit 0); imported above as validate_bridge_url + bridge_post.


def _pushover_alert(title: str, message: str, priority: int = 1) -> bool:
    """Invoke shift-agent-notify-owner. Returns True on success.
    Refactored 2026-04-30 to call shared safe_io.notify_owner_with_fallback
    (was inline; deduplicated across Shift / Daily Brief / EOD)."""
    return notify_owner_with_fallback(
        title, message, priority, source="send-daily-brief",
    )


def _check_routing_watchdog(cfg: Config, dry_run: bool) -> None:
    """Alert owner if send-routing-accuracy-summary cron is stale.

    Contract: this function should not raise under any expected condition; the
    broad except Exception below provides the floor. The daily brief's reliability
    is the dominant invariant; a misbehaving watchdog must not block the brief.

    Silent-return cases (no Pushover, no error): dry_run, timer-unit missing on
    disk (partial-deploy guard), watchdog file missing (first-deploy grace),
    timestamp fresher than WATCHDOG_STALE_DAYS.

    Partial-deploy guard relies on WATCHDOG_TIMER_UNIT being installed at the
    canonical /etc/systemd/system/ path (shift-agent-deploy.sh's `install -m 644
    src/agents/shift/systemd/*.timer /etc/systemd/system/`). If a future deploy
    layout changes and units land in /lib/systemd/system/ instead, update the
    constant.

    Time semantics: uses _customer_now (the local alias that respects
    SHIFT_AGENT_NOW_OVERRIDE for tests), not safe_io.customer_now directly.
    """
    try:
        if dry_run:
            return
        if not WATCHDOG_TIMER_UNIT.exists():
            return
        if not WATCHDOG_PATH.exists():
            return
        data = json.loads(WATCHDOG_PATH.read_text(encoding="utf-8"))
        last_run = datetime.fromisoformat(data[WATCHDOG_TS_KEY])
        days_stale = (_customer_now(cfg.customer.timezone) - last_run).days
        if days_stale <= WATCHDOG_STALE_DAYS:
            return
        message = (
            f"send-routing-accuracy-summary hasn't run in {days_stale} days. "
            f"Check 'systemctl status send-routing-accuracy-summary.timer' on VPS."
        )
        try:
            _pushover_alert("Routing summary cron stale", message, priority=1)
        except Exception as e:  # noqa: BLE001 — invariant: never break the brief
            sys.stderr.write(f"watchdog pushover failed (non-fatal): {type(e).__name__}: {e}\n")
    except Exception as e:  # noqa: BLE001 — invariant: never break the brief
        sys.stderr.write(f"watchdog check failed (non-fatal): {type(e).__name__}: {e}\n")


def _log_entry(adapter: TypeAdapter, entry) -> None:
    """Append a Pydantic-validated entry to decisions.log under flock."""
    DECISIONS_LOG.parent.mkdir(parents=True, exist_ok=True)
    with flock(DECISIONS_LOG):
        ndjson_append(DECISIONS_LOG, adapter.dump_json(entry).decode("utf-8"))


def _write_sentinel(brief_date: str, attempt_id: str, msg_id: str, ts: datetime) -> None:
    """Atomic write — sentinel is the fast-path idempotency check (faster than scanning log)."""
    SENTINEL_PATH.parent.mkdir(parents=True, exist_ok=True)
    atomic_write_json(SENTINEL_PATH, {
        "brief_date": brief_date,
        "attempt_id": attempt_id,
        "outbound_message_id": msg_id,
        "ts": ts.isoformat(),
    })


# ─────────────────────────────────────────────────────────────────
# Main orchestration
# ─────────────────────────────────────────────────────────────────


def main() -> int:
    parser = argparse.ArgumentParser(description="Daily Brief — owner morning summary")
    parser.add_argument("--force", action="store_true",
                        help="bypass self-gate window (idempotency still applies)")
    parser.add_argument("--force-resend", action="store_true",
                        help="DANGEROUS — bypass idempotency. Requires --force.")
    parser.add_argument("--dry-run", action="store_true",
                        help="aggregate + render but don't send or log")
    args = parser.parse_args()

    if args.force_resend and not args.force:
        sys.stderr.write("--force-resend requires --force\n")
        return EXIT_INVALID_INPUT

    # Load config
    try:
        import yaml
        cfg_dict = yaml.safe_load(CONFIG_PATH.read_text(encoding="utf-8"))
        cfg = Config.model_validate(cfg_dict)
    except FileNotFoundError:
        sys.stderr.write(f"config not found: {CONFIG_PATH}\n")
        return EXIT_NOT_FOUND
    except Exception as e:
        sys.stderr.write(f"config load/validate failed: {e}\n")
        return EXIT_SCHEMA_VIOLATION

    if not cfg.daily_brief.enabled:
        return EXIT_OK  # silently disabled

    # NFS check FIRST — before any log write. flock on NFS is unreliable.
    try:
        assert_local_disk(SENTINEL_PATH.parent)
    except RuntimeError as e:
        sys.stderr.write(f"{e}\n")
        return EXIT_GENERIC_ERROR

    today_str = customer_today_str(cfg.customer.timezone)

    if _check_disabled():
        # Global Shift Agent disable flag — also silences brief
        if not args.dry_run:
            _log_entry(_LOG_ADAPTER_SKIPPED, BriefSkipped(
                type="brief_skipped", ts=_customer_now(cfg.customer.timezone),
                brief_date=today_str, reason="disabled",
            ))
        return EXIT_OK

    # Self-gate: skip silently if outside window UNLESS --force
    now_local = _customer_now(cfg.customer.timezone)
    state, minutes_late = _self_gate_state(
        now_local, cfg.daily_brief.brief_time, cfg.daily_brief.catchup_window_minutes,
    )
    if state == "before" and not args.force:
        return EXIT_OK  # silent — fires 95+ times/day outside window
    if state == "past_catchup" and not args.force:
        if not args.dry_run:
            _log_entry(_LOG_ADAPTER_SKIPPED, BriefSkipped(
                type="brief_skipped", ts=now_local,
                brief_date=today_str, reason="catchup_expired",
            ))
            _pushover_alert(
                "Daily Brief missed",
                f"Today's brief was not sent — VPS was down past catch-up window ({minutes_late} min late, max {cfg.daily_brief.catchup_window_minutes}).",
                priority=1,
            )
        return EXIT_OK

    # Idempotency check — under FileLock for the duration of the check (cheap).
    # Lock is RELEASED before the network call to avoid lock-pile-up under
    # bridge slowness (a stuck POST would block every subsequent timer fire).
    SENTINEL_PATH.parent.mkdir(parents=True, exist_ok=True)
    LOCK_PATH = SENTINEL_PATH.parent / "last-brief-sent.json.lock"
    attempt_id = uuid.uuid4().hex
    catchup_late = minutes_late if state == "in_catchup" else 0

    with FileLock(LOCK_PATH):
        # Watchdog: fires at most once per actual brief-window day (FileLock
        # serializes; self-gate ensures only one main() per day reaches here).
        # Position rationale:
        #   - INSIDE FileLock: concurrent --force can't double-fire
        #   - BEFORE sentinel check: still runs even when today's brief was
        #     already sent (single daily heartbeat)
        #   - Reached only by `in_window` and `in_catchup` states; `before` and
        #     `past_catchup` early-return earlier in main() via the
        #     _self_gate_state branches above.
        _check_routing_watchdog(cfg, args.dry_run)

        sentinel = _read_sentinel()
        if sentinel and sentinel.get("brief_date") == today_str and not args.force_resend:
            if not args.dry_run:
                _log_entry(_LOG_ADAPTER_SKIPPED, BriefSkipped(
                    type="brief_skipped", ts=now_local,
                    brief_date=today_str, reason="already_sent",
                ))
            return EXIT_OK

        # Recovery scan: orphaned BriefAttempted with no matching BriefSent.
        # If scan_failed=True (OSError reading log), FAIL CLOSED — treat as
        # uncertain rather than risking a duplicate.
        if not args.force_resend:
            uncertain, scan_failed = _scan_recent_brief_attempted(today_str, now_local)
            if scan_failed or uncertain:
                if not args.dry_run:
                    _log_entry(_LOG_ADAPTER_SKIPPED, BriefSkipped(
                        type="brief_skipped", ts=now_local,
                        brief_date=today_str, reason="send_uncertain",
                    ))
                    detail = (
                        f"Log scan failed (disk error?). Refusing to send to avoid duplicate. "
                        if scan_failed else
                        f"BriefAttempted {(uncertain or {}).get('attempt_id', '?')[:8]} found with no BriefSent. "
                    )
                    _pushover_alert(
                        "Daily Brief — uncertain delivery",
                        detail + "Verify in WhatsApp. If undelivered, run: send-daily-brief --force --force-resend",
                        priority=1,
                    )
                return EXIT_OK

        # Owner self-chat JID required for send
        if not cfg.owner.self_chat_jid:
            if not args.dry_run:
                _pushover_alert(
                    "Daily Brief — config incomplete",
                    "owner.self_chat_jid is empty. Owner must send at least one WhatsApp message to populate it.",
                    priority=1,
                )
            sys.stderr.write("owner.self_chat_jid empty — cannot send brief\n")
            return EXIT_NOT_FOUND

    # Aggregate + render OUTSIDE the FileLock (no shared state mutation here;
    # safe for parallel runs to attempt this in their own process).
    yesterday_counts, deg_y = _aggregate_yesterday(cfg)
    today_data, deg_t = _aggregate_today(cfg)
    degraded = deg_y or deg_t
    source_count = sum(yesterday_counts.values())

    try:
        brief_text = _render_brief_text(
            cfg, today_str, yesterday_counts, today_data, degraded, catchup_late,
        )
    except (KeyError, OSError) as e:
        sys.stderr.write(f"template render failed: {e}\n")
        if not args.dry_run:
            _pushover_alert("Daily Brief — render failed", f"{e}", priority=2)
        return EXIT_GENERIC_ERROR

    if args.dry_run:
        print(brief_text)
        return EXIT_OK

    word_count = len(brief_text.split())

    # PRE-log BriefAttempted (idempotency anchor) BEFORE bridge POST.
    # Re-acquire lock briefly for the log write to keep concurrent runs serialized
    # at the attempted-id level.
    with FileLock(LOCK_PATH):
        _log_entry(_LOG_ADAPTER_ATTEMPTED, BriefAttempted(
            type="brief_attempted", ts=now_local,
            brief_date=today_str, attempt_id=attempt_id,
            word_count=word_count,
            sections_included=list(cfg.daily_brief.sections),
            source_count=source_count, degraded_mode=degraded,
            catchup_minutes_late=catchup_late,
        ))

    # Network call OUTSIDE the lock — bridge slowness must not block the lock.
    retry_count = 0
    ok, msg_id, err, status = bridge_post(cfg.owner.self_chat_jid, brief_text)
    if not ok and status not in ("send_uncertain",):
        # Retry only on connect_failed / http_error / unknown_error.
        # Never retry on send_uncertain — bridge accepted but ack was unparseable;
        # message was likely delivered, retry would duplicate.
        time.sleep(BRIDGE_RETRY_DELAY_SEC)
        ok, msg_id, err, status = bridge_post(cfg.owner.self_chat_jid, brief_text)
        retry_count = 1

    # Re-acquire lock briefly for the post-send log write — keeps the
    # ndjson append + sentinel-write atomic from the caller's perspective.
    with FileLock(LOCK_PATH):
        if ok:
            _write_sentinel(today_str, attempt_id, msg_id, _customer_now(cfg.customer.timezone))
            _log_entry(_LOG_ADAPTER_SENT, BriefSent(
                type="brief_sent", ts=_customer_now(cfg.customer.timezone),
                brief_date=today_str, attempt_id=attempt_id,
                outbound_message_id=msg_id, self_chat_jid=cfg.owner.self_chat_jid,
            ))
            return EXIT_OK

        if status == "send_uncertain":
            # Bridge ACCEPTED but ack was unparseable — message likely sent.
            # Log uncertainty, alert owner, do NOT auto-resend (sentinel NOT written
            # so future runs see no "already_sent" — but they WILL see the
            # BriefAttempted orphan and refuse via the recovery scan.)
            _log_entry(_LOG_ADAPTER_SKIPPED, BriefSkipped(
                type="brief_skipped", ts=_customer_now(cfg.customer.timezone),
                brief_date=today_str, reason="send_uncertain",
            ))
            _pushover_alert(
                "Daily Brief — send uncertain",
                f"Bridge returned 2xx with bad ack ({err[:200]}). Message likely delivered. "
                "Verify in WhatsApp; if not received, run: send-daily-brief --force --force-resend",
                priority=1,
            )
            return EXIT_OK

        # Genuine failure (connect_failed / http_error / unknown_error)
        _log_entry(_LOG_ADAPTER_FAILED, BriefSendFailed(
            type="brief_send_failed", ts=_customer_now(cfg.customer.timezone),
            brief_date=today_str, attempt_id=attempt_id,
            error=err, retry_count=retry_count,
        ))
        _pushover_alert(
            "Daily Brief send failed",
            f"Bridge unreachable after retry: {err[:300]}",
            priority=1,
        )
        return EXIT_DEPENDENCY_DOWN


if __name__ == "__main__":
    sys.exit(main())
