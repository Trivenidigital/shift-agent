#!/usr/bin/env python3
"""create-catering-lead — Agent #2 lead writer.

Called by Kimi (via the parse_catering_inquiry SKILL) once the inquiry has
been classified as catering and key fields have been extracted. This script
is deterministic — it writes state and sends the owner approval card.

Usage:
  create-catering-lead \\
    --customer-phone "+19045551234" \\
    --customer-name "Priya Reddy" \\
    --raw-inquiry "Need catering for 50 people June 15 wedding reception" \\
    --message-id "3EB0F1A2E9" \\
    --fields-json '{"headcount": 50, "event_date": "2026-06-15", "menu_preferences": ["vegetarian"]}'

Idempotent on (customer_phone, message_id) — replays of the same inbound
event are a no-op (returns the existing lead's id+code).

Outputs JSON to stdout: {"lead_id": "L0007", "approval_code": "#A3F2X"}.

Exit codes:
  0  — created (or already-exists, idempotent replay)
  2  — invalid input
  3  — catering disabled (cfg.catering.enabled=False)
  5  — schema violation
  6  — bridge unreachable (approval card couldn't send; lead still saved)
"""
from __future__ import annotations

import argparse
import json
import secrets
import sys
import urllib.error
import urllib.request
import uuid
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional
from zoneinfo import ZoneInfoNotFoundError

sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent.parent / "platform"))

from safe_io import (  # noqa: E402
    FileLock, ndjson_append, atomic_write_json, customer_now,
    safe_load_json, load_model, flock,
)
from schemas import (  # noqa: E402
    Config, CateringLead, CateringLeadStore, CateringLeadExtractedFields,
    CateringLeadCreated, CateringLeadStatusChange, CateringLeadRejected,
    CateringOwnerApprovalRequested,
    # v0.3 audit classes
    CateringOwnerApprovalCardFailed, CateringOwnerApprovalCardSkipped,
    # v0.3 C3: idempotency anchor written before bridge POST in create flow
    CateringOwnerApprovalCardAttempted,
    InvariantViolation,
    assert_rejection_reason_complete,
    # v0.3 lifecycle sentinel — review M1 consolidation
    PRE_QUOTE_DRAFT_SENTINEL,
)
from exit_codes import (  # noqa: E402
    EXIT_OK, EXIT_INVALID_INPUT, EXIT_DISABLED,
    EXIT_SCHEMA_VIOLATION, EXIT_DEPENDENCY_DOWN,
)
import yaml  # noqa: E402  (pre-imported for narrow-except in main())
from pydantic import TypeAdapter, ValidationError  # noqa: E402

CONFIG_PATH = Path("/opt/shift-agent/config.yaml")
LEADS_PATH = Path("/opt/shift-agent/state/catering-leads.json")
LEADS_LOCK = Path("/opt/shift-agent/state/catering-leads.json.lock")
LOG_PATH = Path("/opt/shift-agent/logs/decisions.log")
TEMPLATE_DIR = Path("/opt/shift-agent/templates")
BRIDGE_URL = "http://127.0.0.1:3000/send"
BRIDGE_TIMEOUT = 10

# Off-menu render budget. Budget arithmetic:
# WhatsApp Cloud API caps text.body at ~4096 chars (per Meta's Cloud API
# messages reference). Allocations within that cap:
#   raw_inquiry         : 300 chars (template substitution slice)
#   template boilerplate: ~200 chars
#   other summary lines : ~200 chars typical
#   off_menu items join : ≤1500 chars (this constant)
#   safety margin       : ~1900 chars
# Schema caps off_menu_items at 20 items × 200 chars = 4000 chars worst-case
# (see CateringLeadExtractedFields.off_menu_items in src/platform/schemas.py
# for current bounds); without truncation, the message can blow the cap.
WHATSAPP_OFF_MENU_BUDGET = 1500

# Same alphabet as Shift's proposal codes — visually unambiguous uppercase + digits.
_CODE_ALPHA = "ABCDEFGHJKMNPQRSTUVWXYZ23456789"


def _generate_unique_code(store: CateringLeadStore) -> str:
    """Generate a 5-char approval code not currently in use among non-terminal leads."""
    active_codes = {
        l.owner_approval_code for l in store.leads
        if l.status not in {"NOT_CATERING", "OWNER_REJECTED", "CLOSED", "STALE"}
        and l.owner_approval_code
    }
    for _ in range(50):
        candidate = "#" + "".join(secrets.choice(_CODE_ALPHA) for _ in range(5))
        if candidate not in active_codes:
            return candidate
    raise RuntimeError("unable to generate unique catering approval code after 50 attempts")


def _next_lead_id(store: CateringLeadStore) -> str:
    """Lead IDs are L0001, L0002, ... incrementing across the lifetime of the store."""
    if not store.leads:
        return "L0001"
    last = max(int(l.lead_id.lstrip("L")) for l in store.leads if l.lead_id.startswith("L") and l.lead_id[1:].isdigit())
    return f"L{last + 1:04d}"


def _bridge_post_once(jid: str, message: str) -> tuple[bool, str]:
    """Single-attempt POST. Internal — callers use _bridge_post for retry."""
    payload = json.dumps({"chatId": jid, "message": message}).encode("utf-8")
    req = urllib.request.Request(
        BRIDGE_URL, data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=BRIDGE_TIMEOUT) as resp:
            body = resp.read().decode("utf-8", errors="replace")
            doc = json.loads(body)
            mid = doc.get("id") or doc.get("messageId") or ""
            if not mid:
                return False, f"empty messageId: {body[:200]}"
            return True, mid
    except (urllib.error.URLError, urllib.error.HTTPError, json.JSONDecodeError, OSError) as e:
        return False, f"{type(e).__name__}: {e}"


def _bridge_post(jid: str, message: str) -> tuple[bool, str]:
    """v0.3 C3: POST with one retry on connect-class failures.

    Mirror of `send-coverage-message`'s retry pattern. Retries ONLY on
    connect-side failures (URLError that wraps a ConnectionError /
    timeout-before-handshake). Does NOT retry on:
      - HTTPError (server returned a status code — likely deterministic)
      - JSONDecodeError (server returned non-JSON — deterministic)
      - empty messageId (server processed but returned bad shape)
    so we don't double-send a message that the bridge already accepted.

    Backoff: 0.5s between attempts. Total worst-case latency is
    BRIDGE_TIMEOUT*2 + 0.5s = ~20.5s, still well within Hermes's
    timeout budget for a SKILL invocation.
    """
    import time
    ok, err = _bridge_post_once(jid, message)
    if ok:
        return ok, err
    # Retry only on connect-class transient failures
    if err.startswith("URLError:") and (
        "Connection refused" in err
        or "timed out" in err
        or "Network is unreachable" in err
        or "Temporary failure" in err
    ):
        sys.stderr.write(
            f"INFO: bridge POST first attempt failed ({err}); retrying in 0.5s\n"
        )
        time.sleep(0.5)
        return _bridge_post_once(jid, message)
    return ok, err


def _render_approval_card(
    lead_id: str, approval_code: str, customer_phone: str, customer_name: Optional[str],
    raw: str, fields: CateringLeadExtractedFields,
) -> str:
    """Format the owner-facing approval card. Uses a template file with {field} substitution.

    Falls back to inline text if template missing — defensive for first deploy.
    """
    template_path = TEMPLATE_DIR / "catering_approval_card_to_owner.txt"
    summary_lines = []
    if fields.headcount is not None:
        summary_lines.append(f"  - Headcount: {fields.headcount}")
    if fields.event_date:
        ev = fields.event_date + (f" {fields.event_time}" if fields.event_time else "")
        summary_lines.append(f"  - Event: {ev}")
    if fields.menu_preferences:
        summary_lines.append(f"  - Menu: {', '.join(fields.menu_preferences)}")
    if fields.dietary_restrictions:
        summary_lines.append(f"  - Dietary: {', '.join(fields.dietary_restrictions)}")

    # Off-menu items (v3.1 C23): customer-intent data, clustered with the
    # what-they-want fields above. Defensive None handling — schema default is
    # `Field(default_factory=list)` so None should never arrive from valid
    # Pydantic instantiation, but a manually-edited leads.json or future schema
    # regression could produce it.
    items = fields.off_menu_items
    if items is None:
        sys.stderr.write(
            "WARN: off_menu_items unexpectedly None (schema default is empty list); "
            "treating as empty. Check leads.json for manually-edited entries.\n"
        )
        items = []
    if items:
        # Conservative truncation against WhatsApp limit per WHATSAPP_OFF_MENU_BUDGET.
        # Two regimes:
        #   (a) total joined exceeds budget → truncate item-list with "(and N more)"
        #   (b) FIRST item alone exceeds budget → truncate the item itself
        # Branch (b) is defensive — schema's per-item max_length=200 makes it
        # unreachable in practice; if max_length is ever relaxed, this branch
        # stays correct.
        joined = ", ".join(items)
        if len(joined) > WHATSAPP_OFF_MENU_BUDGET:
            running = 0
            cutoff = 0
            for i, item in enumerate(items):
                # v0.3 C6: separators only inserted between items, not before
                # the first one. Was: `running += len(item) + 2` always,
                # over-counting by 2 (joined.len = sum(item.len) + (n-1)*2).
                running += len(item) + (2 if i > 0 else 0)
                if running > WHATSAPP_OFF_MENU_BUDGET:
                    cutoff = i
                    break
            if cutoff == 0:
                # Single item alone exceeds budget — truncate the item itself.
                trunc_item = items[0][:WHATSAPP_OFF_MENU_BUDGET - 10] + "..."
                joined = trunc_item + (
                    f" (and {len(items) - 1} more)" if len(items) > 1 else ""
                )
                sys.stderr.write(
                    f"WARN: single off_menu_item exceeded budget "
                    f"({len(items[0])} chars); truncated.\n"
                )
            else:
                shown = items[:cutoff]
                joined = ", ".join(shown) + f" (and {len(items) - len(shown)} more)"
        summary_lines.append(f"  - Off-menu requests: {joined}")

    if fields.delivery_or_pickup:
        summary_lines.append(f"  - Delivery: {fields.delivery_or_pickup}")
    if fields.budget_hint_usd is not None:
        summary_lines.append(f"  - Budget hint: ${fields.budget_hint_usd}")

    # Top-of-card marker (mobile-preview-fold mitigation): MUST use
    # insert(0, ...) NOT append; the marker MUST appear at summary_lines[0]
    # so it lands above-the-fold in WhatsApp message previews. Only added
    # when off_menu_items is present so regular leads stay clean. ASCII-only
    # ("[!]" + " - " separator) — avoids unicode encoding fragility on
    # locale-dependent stderr/journald paths.
    if items:
        summary_lines.insert(0, "  [!] Off-menu requests detected - see below")

    summary = "\n".join(summary_lines) if summary_lines else "  (no structured fields extracted)"

    fields_dict = {
        "lead_id": lead_id,
        "approval_code": approval_code,
        "customer_phone": customer_phone,
        "customer_name": customer_name or "(unknown)",
        "raw_inquiry": raw[:300],
        "extracted_summary": summary,
    }
    if template_path.exists():
        try:
            tmpl = template_path.read_text(encoding="utf-8")
            return tmpl.format(**fields_dict)
        except (KeyError, OSError) as e:
            # Template render failure (missing key, encoding error, IO error) —
            # surface to journald via stderr instead of silently falling back.
            sys.stderr.write(
                f"WARN: template render fell back to inline (template_path={template_path}): "
                f"{type(e).__name__}: {e}\n"
            )
    # Inline fallback
    return (
        f"⚕ *Catering Agent*\n────────────\n"
        f"*New Catering Inquiry — {lead_id}*\n\n"
        f"From: {customer_name or '(unknown)'} ({customer_phone})\n\n"
        f"{raw[:300]}\n\n"
        f"Extracted:\n{summary}\n\n"
        f"*To approve, reply with:* `{approval_code} approve`\n"
        f"*To reject:* `{approval_code} reject`\n"
        f"*To edit:* `{approval_code} edit <your changes>`"
    )


# Maps CateringLeadRejected.reason → SKILL-readable stderr prefix.
# Any new reason returned by _validate_event_date (and added to the schema
# Literal) MUST also land here. The .get() fallback to "ERR_UNKNOWN_REJECTION"
# is defense-in-depth so SKILL parsers see a structured prefix rather than
# crashing on a None value when the helper/dict drift one step apart.
REASON_TO_ERR_PREFIX = {
    "event_date_past": "ERR_EVENT_DATE_PAST",
    "event_date_invalid_calendar": "ERR_EVENT_DATE_INVALID",
    "timezone_invalid": "ERR_TIMEZONE_INVALID",
    "message_id_phone_mismatch": "ERR_MESSAGE_ID_PHONE_MISMATCH",  # v0.3 C2
}


def _validate_event_date(
    fields: CateringLeadExtractedFields, tz_name: str
) -> tuple[Optional[str], Optional[str]]:
    """Returns (reason, detail) tuple. (None, None) means input is valid.

    `reason` values match the CateringLeadRejected schema Literal — pinned by
    Pydantic so a typo here raises ValidationError at log-write time.

    Why script-level vs schema-level (per design v2): Pydantic v2 *does* support
    model_validate(..., context={...}) and info.context access in validators,
    but plumbing tz context through every model_validate_json call site (the
    read path, replay tools, and the catering v3.1 C22 round-trip test that
    calls model_validate_json with no context) would couple the schema to
    runtime tz config. Keeping tz-aware checks at the script (write-path) layer
    leaves the schema stateless and read-path-safe.

    Why both invalid-calendar AND past-date here (not just past-date): schema
    pattern is format-only (4-2-2 digit groups); accepts 2026-13-45 etc.
    Past-date check needs strptime, which doubles as semantic validity check.
    Rejecting both at this site avoids garbage dates persisting downstream.
    """
    if not fields.event_date:
        return None, None  # No event_date → no check.

    try:
        ev = datetime.strptime(fields.event_date, "%Y-%m-%d").date()
    except ValueError:
        return "event_date_invalid_calendar", (
            f"event_date {fields.event_date!r} matches format but is not a valid calendar date"
        )

    # Narrow except (design-review HIGH-C + PR-review MEDIUM-1): catch
    # tz-resolution failures specifically. ZoneInfoNotFoundError covers the
    # tz-not-found case (it IS a KeyError subclass on 3.11+, but listing it
    # explicitly documents intent). ValueError covers malformed tzdata. We do
    # NOT catch KeyError or AttributeError/TypeError — those indicate
    # config-shape bugs (None tz, int tz, etc.) and should propagate as the
    # programming bugs they are, not be bucketed into ERR_TIMEZONE_INVALID.
    try:
        today = customer_now(tz_name).date()
    except (ZoneInfoNotFoundError, ValueError) as e:
        return "timezone_invalid", (
            f"cfg.customer.timezone {tz_name!r} could not be resolved: {type(e).__name__}: {e}"
        )

    if ev < today:
        return "event_date_past", (
            f"event_date {fields.event_date} is before today {today.isoformat()} ({tz_name})"
        )
    return None, None


def _log(adapter: TypeAdapter, entry) -> None:
    """Append a Pydantic-validated entry to decisions.log under flock."""
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with flock(LOG_PATH):
        ndjson_append(LOG_PATH, adapter.dump_json(entry).decode("utf-8"))


def _audit_best_effort(adapter: TypeAdapter, entry, *, context: str) -> None:
    """Best-effort audit write. Never raises.

    Guarantees the caller can always emit its structured stdout/stderr/exit-code
    contract regardless of audit durability (disk full, perms, NFS hiccup).

    Generalizes the design-review HIGH-A pattern uniformly to ALL audit writes
    in this script — previously only the rejection-path _log() was wrapped, so
    a success-path audit failure after atomic_write_json(LEADS_PATH) already
    persisted the lead would propagate as an uncaught traceback, stranding the
    lead with no audit AND no stdout JSON. With this wrapper, the operator gets
    a journald WARN line and the script still emits its contract.
    """
    try:
        _log(adapter, entry)
    except Exception as e:  # noqa: BLE001 — invariant: audit must not block flow
        sys.stderr.write(
            f"WARN: audit log failed (non-fatal, context={context}): "
            f"{type(e).__name__}: {e}\n"
        )


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--customer-phone", required=True)
    ap.add_argument("--customer-name", default=None)
    ap.add_argument("--raw-inquiry", required=True)
    ap.add_argument("--message-id", required=True, help="Meta WhatsApp message id (idempotency key)")
    ap.add_argument("--fields-json", required=True,
                    help='JSON dict matching CateringLeadExtractedFields')
    args = ap.parse_args()

    # v0.3 L4-CL: strip whitespace on idempotency-key-bearing args. Without
    # this, "msg_1 " (trailing space) creates a duplicate of "msg_1".
    args.message_id = args.message_id.strip()
    args.customer_phone = args.customer_phone.strip()

    # v0.3: assert rejection-reason dict matches schema Literal at startup.
    # Caught at import would block the whole module; doing it here at main()
    # entry surfaces drift as a clean structured error → EXIT_SCHEMA_VIOLATION.
    try:
        assert_rejection_reason_complete(REASON_TO_ERR_PREFIX)
    except RuntimeError as e:
        sys.stderr.write(f"REASON drift detected: {e}\n")
        return EXIT_SCHEMA_VIOLATION

    # v0.3 M1-CL: narrow config-load exceptions for accurate exit codes.
    try:
        cfg_dict = yaml.safe_load(CONFIG_PATH.read_text(encoding="utf-8"))
    except (FileNotFoundError, PermissionError, OSError) as e:
        sys.stderr.write(f"config file unreadable: {type(e).__name__}: {e}\n")
        return EXIT_DEPENDENCY_DOWN
    except yaml.YAMLError as e:
        sys.stderr.write(f"config YAML invalid: {e}\n")
        return EXIT_SCHEMA_VIOLATION
    try:
        cfg = Config.model_validate(cfg_dict)
    except ValidationError as e:
        sys.stderr.write(f"config schema invalid: {e}\n")
        return EXIT_SCHEMA_VIOLATION

    if not cfg.catering.enabled:
        sys.stderr.write("catering disabled (cfg.catering.enabled=false)\n")
        return EXIT_DISABLED

    # Validate extracted fields
    try:
        extracted = CateringLeadExtractedFields.model_validate_json(args.fields_json)
    except ValidationError as e:
        sys.stderr.write(f"fields_json validation failed: {e}\n")
        return EXIT_INVALID_INPUT

    LEADS_PATH.parent.mkdir(parents=True, exist_ok=True)
    with FileLock(LEADS_LOCK):
        # Load store (or empty default)
        store, status = load_model(LEADS_PATH, CateringLeadStore, default=CateringLeadStore())
        if status.startswith("corrupt"):
            sys.stderr.write(f"catering-leads.json corrupt: {status}\n")
            return EXIT_SCHEMA_VIOLATION

        # Idempotency: same message_id replays?
        # Runs BEFORE event-date validation (v3.1 C10): a lead created in the past
        # may have had a then-future event_date that is now-past; replay must
        # NOT reject — return the existing lead's id+code identically.
        existing = next(
            (l for l in store.leads if l.original_message_id == args.message_id),
            None,
        )
        if existing:
            # v0.3 C2: phone-mismatch on idempotency key. Compare canonicalized
            # phones; if mismatch, log InvariantViolation + Rejected audit but
            # RETURN existing lead's id+code (idempotent UX is preserved —
            # reject would crash a legitimate retry).
            try:
                from schemas import E164Phone
                incoming_canon = E164Phone.from_any(args.customer_phone)
            except Exception:
                # If incoming phone is malformed, the strict compare below will
                # surface this as the "real" issue.
                incoming_canon = args.customer_phone
            if existing.customer_phone != incoming_canon:
                _audit_best_effort(
                    TypeAdapter(InvariantViolation),
                    InvariantViolation(
                        type="invariant_violation",
                        ts=datetime.now(tz=timezone.utc),
                        check="catering_idempotency_phone_mismatch",
                        detail=(
                            f"message_id={args.message_id!r} stored on "
                            f"phone={existing.customer_phone!r} but retry came "
                            f"from phone={incoming_canon!r}"
                        ),
                    ),
                    context="phone_mismatch",
                )
                _audit_best_effort(
                    TypeAdapter(CateringLeadRejected),
                    CateringLeadRejected(
                        type="catering_lead_rejected",
                        ts=datetime.now(tz=timezone.utc),
                        customer_phone=args.customer_phone,
                        original_message_id=args.message_id,
                        reason="message_id_phone_mismatch",
                        detail=f"existing phone={existing.customer_phone}",
                        customer_tz=cfg.customer.timezone,
                    ),
                    context="rejected_phone_mismatch",
                )
                sys.stderr.write(
                    f"WARN: phone-mismatch idempotent replay; returning existing "
                    f"lead {existing.lead_id}. stored={existing.customer_phone!r} "
                    f"incoming={incoming_canon!r}\n"
                )
                # FALL THROUGH to idempotent return below — UX is preserved

            # Replay breadcrumb: when the existing lead has off_menu_items,
            # log a journald entry so a high-value booking whose original card
            # may have been lost (auto-archived, owner missed) leaves a trail
            # for post-hoc operator triage. Wording is honest about uncertainty —
            # the lead schema does not yet persist a card_sent flag, so we
            # cannot assert the original card was delivered.
            if existing.extracted.off_menu_items:
                sys.stderr.write(
                    f"INFO: idempotent_replay on lead {existing.lead_id} with "
                    f"non-empty off_menu_items={existing.extracted.off_menu_items!r}. "
                    f"Original card-send disposition unknown — verify in cockpit.\n"
                )
            print(json.dumps({
                "lead_id": existing.lead_id,
                "approval_code": existing.owner_approval_code,
                "idempotent_replay": True,
            }))
            return EXIT_OK

        # First-touch event-date validation (v3.1 C10).
        # Three failure modes → three reasons in CateringLeadRejected.
        # Order: log audit FIRST (durable), stderr SECOND (so SIGKILL between
        # them doesn't lose the audit entry — design-review MEDIUM-E).
        reason, detail = _validate_event_date(extracted, cfg.customer.timezone)
        if reason is not None:
            err_prefix = REASON_TO_ERR_PREFIX.get(reason, "ERR_UNKNOWN_REJECTION")
            # Audit ts is ALWAYS UTC (design-review MEDIUM-D — consistent ordering
            # for log-replay tools regardless of which failure mode fired).
            ts_utc = datetime.now(tz=timezone.utc)
            _audit_best_effort(
                TypeAdapter(CateringLeadRejected),
                CateringLeadRejected(
                    type="catering_lead_rejected",
                    ts=ts_utc,
                    customer_phone=args.customer_phone,
                    original_message_id=args.message_id,
                    reason=reason,
                    detail=detail[:500] if detail else "",
                    customer_tz=cfg.customer.timezone,
                    event_date=extracted.event_date,
                ),
                context="rejected",
            )
            sys.stderr.write(f"{err_prefix}: {detail}\n")
            # timezone_invalid is config-level (cfg.customer.timezone), not input-level
            # (customer-supplied event_date). Distinct exit code surfaces the difference.
            return EXIT_SCHEMA_VIOLATION if reason == "timezone_invalid" else EXIT_INVALID_INPUT

        # Mint new lead
        now = customer_now(cfg.customer.timezone)
        lead_id = _next_lead_id(store)
        try:
            approval_code = _generate_unique_code(store)
        except RuntimeError as e:
            # v0.3 M3-CL: code-generation collision exhaustion → structured
            # error rather than uncaught traceback.
            sys.stderr.write(f"code generation exhausted: {e}\n")
            return EXIT_DEPENDENCY_DOWN
        # v0.3 C1: catch ValidationError on lead construction (e.g. malformed
        # customer_phone) → structured EXIT_INVALID_INPUT instead of traceback.
        try:
            lead = CateringLead(
                lead_id=lead_id,
                status="AWAITING_OWNER_APPROVAL",
                customer_phone=args.customer_phone,
                customer_name=args.customer_name,
                raw_inquiry=args.raw_inquiry,
                original_message_id=args.message_id,
                created_at=now,
                updated_at=now,
                extracted=extracted,
                owner_approval_code=approval_code,
                # quote_text intentionally omitted — extractor stage does not
                # draft quote yet; status=AWAITING_OWNER_APPROVAL with empty
                # quote_text would fail v0.3 S1 invariant. Use sentinel until
                # v0.4 inline drafting lands. apply-script's Q1 fix populates
                # real quote_text on approve. (review M1 consolidation —
                # imported from schemas.PRE_QUOTE_DRAFT_SENTINEL).
                quote_text=PRE_QUOTE_DRAFT_SENTINEL,
            )
        except ValidationError as e:
            sys.stderr.write(f"lead construction failed: {e}\n")
            return EXIT_INVALID_INPUT
        store.leads.append(lead)

        # v0.3 M2-CL: removed wasteful model_validate(model_dump()) round-trip.
        # Pydantic's eager validation at CateringLead(...) construction above is
        # sufficient. Round-trip caught no real bugs and added latency.

        atomic_write_json(LEADS_PATH, store)

        # Audit: created → awaiting → approval-requested.
        # All writes are best-effort: if audit fails, lead is already persisted
        # (atomic_write_json above) and the SKILL must still get lead_id+code on
        # stdout. Operator gets a journald WARN line per failed write.
        _audit_best_effort(
            TypeAdapter(CateringLeadCreated),
            CateringLeadCreated(
                type="catering_lead_created", ts=now,
                lead_id=lead_id,
                customer_phone=args.customer_phone,
                original_message_id=args.message_id,
            ),
            context="created",
        )
        _audit_best_effort(
            TypeAdapter(CateringLeadStatusChange),
            CateringLeadStatusChange(
                type="catering_lead_status_change", ts=now,
                lead_id=lead_id, from_status="NEW", to_status="AWAITING_OWNER_APPROVAL",
                actor="system", reason="extractor_completed",
            ),
            context="status_change",
        )
        _audit_best_effort(
            TypeAdapter(CateringOwnerApprovalRequested),
            CateringOwnerApprovalRequested(
                type="catering_owner_approval_requested", ts=now,
                lead_id=lead_id, approval_code=approval_code,
            ),
            context="approval_requested",
        )

    # Send approval card to owner — outside the FileLock; bridge slowness shouldn't block.
    if not cfg.owner.self_chat_jid:
        # v0.3 C5: emit CateringOwnerApprovalCardSkipped audit (was: no audit;
        # CateringOwnerApprovalRequested was misleadingly logged). Return
        # EXIT_DEPENDENCY_DOWN (was: EXIT_OK) so SKILL caller routes to Pushover.
        _audit_best_effort(
            TypeAdapter(CateringOwnerApprovalCardSkipped),
            CateringOwnerApprovalCardSkipped(
                type="catering_owner_approval_card_skipped",
                ts=datetime.now(tz=timezone.utc),
                lead_id=lead_id,
                reason="self_chat_jid_empty",
            ),
            context="card_skipped",
        )
        sys.stderr.write("owner.self_chat_jid empty; lead saved but card not sent\n")
        print(json.dumps({"lead_id": lead_id, "approval_code": approval_code,
                          "card_sent": False, "reason": "self_chat_jid_empty"}))
        return EXIT_DEPENDENCY_DOWN

    card_text = _render_approval_card(
        lead_id, approval_code, args.customer_phone, args.customer_name,
        args.raw_inquiry, extracted,
    )
    # v0.3 C3: idempotency anchor. Mirror of CateringQuoteAttempted in
    # apply-script. Written BEFORE bridge POST so a crash mid-POST leaves
    # a durable trail that approve-card was attempted; operators use this
    # to manually resolve "lead in AWAITING but no card sent" cases.
    # Best-effort — bridge POST is the more important step.
    _audit_best_effort(
        TypeAdapter(CateringOwnerApprovalCardAttempted),
        CateringOwnerApprovalCardAttempted(
            type="catering_owner_approval_card_attempted",
            ts=datetime.now(tz=timezone.utc),
            lead_id=lead_id,
            original_message_id=args.message_id,
        ),
        context="card_attempted",
    )
    ok, mid_or_err = _bridge_post(cfg.owner.self_chat_jid, card_text)
    if not ok:
        # v0.3 C4: emit CateringOwnerApprovalCardFailed audit so post-mortem
        # can distinguish "card sent" from "card silently failed".
        _audit_best_effort(
            TypeAdapter(CateringOwnerApprovalCardFailed),
            CateringOwnerApprovalCardFailed(
                type="catering_owner_approval_card_failed",
                ts=datetime.now(tz=timezone.utc),
                lead_id=lead_id,
                reason="bridge_post_failed",
                bridge_error=mid_or_err[:2000] if mid_or_err else "",
            ),
            context="card_failed",
        )
        sys.stderr.write(f"bridge_post failed: {mid_or_err}\n")
        print(json.dumps({"lead_id": lead_id, "approval_code": approval_code,
                          "card_sent": False, "reason": mid_or_err}))
        return EXIT_DEPENDENCY_DOWN

    print(json.dumps({"lead_id": lead_id, "approval_code": approval_code,
                      "card_sent": True, "outbound_message_id": mid_or_err}))
    return EXIT_OK


if __name__ == "__main__":
    sys.exit(main())
