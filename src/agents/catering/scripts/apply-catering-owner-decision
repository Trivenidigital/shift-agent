#!/usr/bin/env python3
"""apply-catering-owner-decision — Agent #2 owner-approval state writer.

Called by Kimi (via the handle_catering_owner_approval SKILL) when the
owner has replied to a catering approval card with a code + verb. This
script is deterministic — it transitions the lead's status and, on
APPROVE, sends the quote to the customer.

Usage:
  apply-catering-owner-decision \\
    --code "#A3F2X" \\
    --decision approve

  apply-catering-owner-decision \\
    --code "#A3F2X" \\
    --decision edit \\
    --edit-text "make it $400 cap; add appetizer pricing"

  apply-catering-owner-decision \\
    --code "#A3F2X" \\
    --decision reject \\
    --reason "out of capacity that weekend"

Outputs JSON: {"lead_id": "L0007", "new_status": "SENT_TO_CUSTOMER",
               "outbound_message_id": "..."}.

Exit codes:
  0  — applied
  2  — invalid input
  4  — code not found among active leads
  5  — schema violation
  6  — bridge unreachable (state still updated; quote delivery uncertain)
  9  — illegal transition (lead in terminal/wrong status)
"""
from __future__ import annotations

import argparse
import json
import sys
import urllib.error
import urllib.request
from datetime import datetime
from pathlib import Path
from typing import Optional

sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent.parent / "platform"))

from safe_io import (  # noqa: E402
    FileLock, ndjson_append, atomic_write_json, customer_now,
    load_model, flock,
)
from schemas import (  # noqa: E402
    Config, CateringLeadStore, Menu, MenuItem,
    CateringLeadStatusChange, CateringOwnerDecision, CateringQuoteSent,
    # v0.3 (review M2): durable observability for render-failed approves
    CateringQuoteRenderFailed,
    # v0.3 (A1+A2): idempotency anchor for customer-quote send
    CateringQuoteAttempted,
    # v0.3 A9: code-collision audit row (was stderr-only)
    InvariantViolation,
)
from exit_codes import (  # noqa: E402
    EXIT_OK, EXIT_INVALID_INPUT, EXIT_NOT_FOUND,
    EXIT_SCHEMA_VIOLATION, EXIT_DEPENDENCY_DOWN, EXIT_ILLEGAL_TRANSITION,
)
from pydantic import TypeAdapter  # noqa: E402
from datetime import timezone  # noqa: E402  (UTC for audit ts on render-failure)

CONFIG_PATH = Path("/opt/shift-agent/config.yaml")
LEADS_PATH = Path("/opt/shift-agent/state/catering-leads.json")
LEADS_LOCK = Path("/opt/shift-agent/state/catering-leads.json.lock")
MENU_PATH = Path("/opt/shift-agent/state/catering-menu.json")
LOG_PATH = Path("/opt/shift-agent/logs/decisions.log")
TEMPLATE_DIR = Path("/opt/shift-agent/templates")
BRIDGE_URL = "http://127.0.0.1:3000/send"
BRIDGE_TIMEOUT = 10
MENU_ITEMS_IN_QUOTE = 12  # cap to keep WhatsApp message readable


def _bridge_post(jid: str, message: str) -> tuple[bool, str]:
    payload = json.dumps({"chatId": jid, "message": message}).encode("utf-8")
    req = urllib.request.Request(
        BRIDGE_URL, data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=BRIDGE_TIMEOUT) as resp:
            body = resp.read().decode("utf-8", errors="replace")
            doc = json.loads(body)
            mid = doc.get("id") or doc.get("messageId") or ""
            if not mid:
                return False, f"empty messageId: {body[:200]}"
            return True, mid
    except (urllib.error.URLError, urllib.error.HTTPError, json.JSONDecodeError, OSError) as e:
        return False, f"{type(e).__name__}: {e}"


_DIETARY_TAG_ALIASES = {
    "vegetarian": "veg", "veg": "veg",
    "non-vegetarian": "non-veg", "non-veg": "non-veg", "nonveg": "non-veg",
    "vegan": "vegan",
    "jain": "jain",
    "halal": "halal",
    "kosher": "kosher",
    "gluten-free": "gluten-free", "gf": "gluten-free", "gluten free": "gluten-free",
    "nut-free": "nut-free", "nut free": "nut-free",
    "dairy-free": "dairy-free", "dairy free": "dairy-free",
    "egg-free": "egg-free", "egg free": "egg-free", "no eggs": "egg-free",
}


def _normalize_dietary_tags(raw_tags: list[str]) -> tuple[set[str], list[str]]:
    """v0.3 A8: returns (recognized_tags, unknown_input_tags).

    Unknown tags surface in the customer message as a "we didn't recognize"
    note, instead of being silently dropped (which previously produced
    misleading "we don't have items matching X" copy that implied the
    restaurant doesn't do X — when really we just didn't tag for it).
    """
    recognized: set[str] = set()
    unknown: list[str] = []
    for r in raw_tags:
        if not isinstance(r, str):
            continue
        t = r.lower().strip()
        if t in _DIETARY_TAG_ALIASES:
            recognized.add(_DIETARY_TAG_ALIASES[t])
        else:
            unknown.append(r)  # preserve original casing for customer message
    return recognized, unknown


def _load_menu_filtered(dietary_restrictions: list[str]) -> tuple[list[MenuItem], int, str]:
    """Load the current menu and filter items by the customer's dietary requests.

    v0.3 (A3 fix): three-way return (items, total, error_kind) where:
      - "ok": menu loaded cleanly, items returned
      - "absent": MENU_PATH does not exist (legitimate first-run customer state)
      - "corrupt": JSON or schema validation failed
      - "io_error": filesystem/permission failure

    Approve flow MUST refuse on "corrupt"/"io_error" but proceed on "absent"
    (empty menu section is valid for first-run customers without an uploaded
    menu yet).
    """
    if not MENU_PATH.exists():
        return [], 0, "absent"
    try:
        menu, status = load_model(MENU_PATH, Menu)
    except (FileNotFoundError, PermissionError):
        return [], 0, "io_error"
    except OSError:
        return [], 0, "io_error"
    except RuntimeError:
        # safe_io's quarantine path — file was renamed to .corrupt-<epoch>
        return [], 0, "corrupt"
    except Exception:
        # Pydantic ValidationError or unexpected
        return [], 0, "corrupt"
    if status.startswith("corrupt"):
        return [], 0, "corrupt"
    if status != "ok":
        return [], 0, "io_error"
    items = [it for it in menu.items if it.available]
    if not dietary_restrictions:
        return items, len(menu.items), "ok"
    # v0.3 A8: route through the normalize helper so unknown tags can be
    # surfaced upstream (instead of silently dropped). The returned set is
    # the recognized-tag set; unknowns are tracked separately via
    # _normalize_dietary_tags and surfaced in _format_menu_section's caller.
    requested, _unknown = _normalize_dietary_tags(dietary_restrictions)
    if not requested:
        # All input tags were unknown — return ALL available items so the
        # customer at least sees what we offer. The "we didn't recognize"
        # note is added downstream.
        return items, len(menu.items), "ok"
    filtered = [it for it in items if any(tag in requested for tag in it.dietary_tags)]
    return filtered, len(menu.items), "ok"


def _format_menu_section(items: list[MenuItem], total: int, dietary_restrictions: list[str]) -> str:
    """Build the menu section that appears in the customer-facing quote."""
    if not items:
        if total == 0:
            return ""  # no menu configured at all — silently omit
        if dietary_restrictions:
            return (f"\n_(We didn't find items matching {', '.join(dietary_restrictions)} "
                    f"in our current menu. Reply with any specifics and we'll customize.)_\n")
        return ""
    by_cat: dict[str, list[MenuItem]] = {}
    for it in items:
        by_cat.setdefault(it.category, []).append(it)
    cat_order = ["package", "appetizer", "main", "side", "dessert", "beverage", "salad", "soup", "special"]
    lines = ["\n*Sample menu*"]
    if dietary_restrictions:
        lines[0] += f" ({', '.join(dietary_restrictions)})"
    lines[0] += ":"
    shown = 0
    for cat in cat_order:
        if cat not in by_cat or shown >= MENU_ITEMS_IN_QUOTE:
            continue
        for it in by_cat[cat][:max(1, MENU_ITEMS_IN_QUOTE // len(by_cat))]:
            if shown >= MENU_ITEMS_IN_QUOTE:
                break
            price = f" — ${it.price_usd:.0f}" if it.price_usd is not None else ""
            lines.append(f"  - {it.name}{price}")
            shown += 1
    leftover = len(items) - shown
    if leftover > 0:
        lines.append(f"  _...and {leftover} more options on request_")
    return "\n".join(lines) + "\n"


def _render_quote(lead, customer_name: str) -> tuple[str, str]:
    """Render the customer-facing quote.

    v0.3 (A3+A4+A5 fixes):
      - A3: three-way menu_load result; raises on "corrupt"/"io_error"
        (caller must refuse approve and emit InvariantViolation+Pushover)
      - A4: template format error is LOUD — no inline-stub fallback. Raises
        a ValueError that the caller maps to EXIT_DEPENDENCY_DOWN.
      - A5: off_menu_items rendered into customer quote (was owner-card-only)
      - Q1: caller MUST persist returned quote_text on the lead

    Returns (rendered_text, menu_status) where menu_status ∈ {"ok","absent","corrupt","io_error"}.
    Caller refuses approve on "corrupt"/"io_error".
    """
    template_path = TEMPLATE_DIR / "catering_quote_to_customer.txt"
    dietary = list(lead.extracted.dietary_restrictions or [])
    # v0.3 A8: track unknown dietary tags BEFORE filtering so we can surface
    # them in the customer message even when filtering succeeded against
    # OTHER (recognized) tags. Was: silent partial drop.
    _, unknown_tags = _normalize_dietary_tags(dietary)
    filtered_items, total, menu_status = _load_menu_filtered(dietary)
    menu_section = _format_menu_section(filtered_items, total, dietary)

    # A5: include off_menu_items in customer-facing quote
    off_menu_section = ""
    if lead.extracted.off_menu_items:
        items_list = "\n".join(f"  - {it}" for it in lead.extracted.off_menu_items)
        off_menu_section = f"\n*Custom requests we'll discuss:*\n{items_list}\n"

    # v0.3 A8: dietary-restriction note. When ANY input tag is unknown,
    # append a note (regardless of whether filtering matched OTHER tags) so
    # the customer can clarify. Avoids the misleading "we don't have items
    # matching X" copy that previously implied we don't serve X — when in
    # reality our menu just isn't tagged for X yet.
    dietary_note_section = ""
    if unknown_tags:
        joined_unknown = ", ".join(f"'{t}'" for t in unknown_tags)
        dietary_note_section = (
            f"\n_Note: we don't currently classify items by {joined_unknown}. "
            f"If that's a hard requirement, please confirm and we'll send "
            f"custom options._\n"
        )

    fields = {
        "lead_id": lead.lead_id,
        "customer_name": customer_name or "there",
        "headcount": lead.extracted.headcount or "[TBD]",
        "event_date": lead.extracted.event_date or "[TBD]",
        "event_time": lead.extracted.event_time or "[TBD]",
        "menu_section": menu_section,
        "off_menu_items_section": off_menu_section,
        "dietary_note_section": dietary_note_section,
    }
    if template_path.exists():
        try:
            tmpl = template_path.read_text(encoding="utf-8")
            return tmpl.format(**fields), menu_status
        except KeyError as e:
            raise ValueError(f"catering_quote_to_customer.txt missing key: {e}") from e
        except OSError as e:
            raise ValueError(f"catering_quote_to_customer.txt read failed: {e}") from e

    # No template installed — render via inline composition (this is NOT a
    # silent fallback for template-format errors; only for missing-template).
    return (
        f"⚕ *Catering Agent*\n────────────\n"
        f"Hi {fields['customer_name']}, thank you for the catering inquiry. "
        f"We can confirm — let's discuss details. Reply here when ready, or "
        f"reach us directly.{menu_section}{off_menu_section}{dietary_note_section}\n"
        f"(Ref: {lead.lead_id})"
    ), menu_status


def _log(adapter: TypeAdapter, entry) -> None:
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with flock(LOG_PATH):
        ndjson_append(LOG_PATH, adapter.dump_json(entry).decode("utf-8"))


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--code", required=True, help="approval code from owner reply, e.g. #A3F2X")
    ap.add_argument("--decision", required=True, choices=["approve", "reject", "edit"])
    ap.add_argument("--edit-text", default="", help="required when decision=edit")
    ap.add_argument("--reason", default="", help="optional rejection reason")
    args = ap.parse_args()

    if args.decision == "edit" and not args.edit_text.strip():
        sys.stderr.write("--edit-text required when decision=edit\n")
        return EXIT_INVALID_INPUT

    code = args.code.strip()
    if not code.startswith("#") or len(code) != 6:
        sys.stderr.write(f"invalid code format (expected #XXXXX): {code!r}\n")
        return EXIT_INVALID_INPUT

    # Load config
    try:
        import yaml
        cfg_dict = yaml.safe_load(CONFIG_PATH.read_text(encoding="utf-8"))
        cfg = Config.model_validate(cfg_dict)
    except Exception as e:
        sys.stderr.write(f"config load failed: {e}\n")
        return EXIT_SCHEMA_VIOLATION

    # Find + transition the lead under FileLock
    quote_text: Optional[str] = None
    target_jid: Optional[str] = None
    new_status_for_output: str = ""
    lead_id_for_output: str = ""

    with FileLock(LEADS_LOCK):
        store, status = load_model(LEADS_PATH, CateringLeadStore, default=CateringLeadStore())
        if status.startswith("corrupt"):
            sys.stderr.write(f"catering-leads.json corrupt: {status}\n")
            return EXIT_SCHEMA_VIOLATION

        # Match code among non-terminal leads only
        matches = [l for l in store.leads
                   if l.owner_approval_code == code
                   and l.status == "AWAITING_OWNER_APPROVAL"]
        if not matches:
            sys.stderr.write(f"no AWAITING_OWNER_APPROVAL lead with code {code}\n")
            # Did the code exist on a different status? (helpful for debugging)
            any_match = [l for l in store.leads if l.owner_approval_code == code]
            if any_match:
                sys.stderr.write(
                    f"  (code {code} exists on lead {any_match[0].lead_id} but in status {any_match[0].status})\n"
                )
            return EXIT_NOT_FOUND
        if len(matches) > 1:
            # v0.3 A9: code-collision should be impossible per
            # generate_unique_code's 50-attempt unique check, but if it
            # happens we want a durable audit row + Pushover alert, not
            # just stderr. Operator may need to intervene to clean up
            # the duplicate code.
            collision_lead_ids = [l.lead_id for l in matches]
            try:
                _log(TypeAdapter(InvariantViolation), InvariantViolation(
                    type="invariant_violation",
                    ts=datetime.now(tz=timezone.utc),
                    check="catering_code_collision",
                    detail=(
                        f"code={code!r} matches {len(matches)} active leads: "
                        f"{collision_lead_ids}. Refusing to apply decision; "
                        f"manual operator intervention required."
                    ),
                ))
            except Exception as audit_err:
                sys.stderr.write(
                    f"WARN: collision-audit write failed (non-fatal): "
                    f"{type(audit_err).__name__}: {audit_err}\n"
                )
            sys.stderr.write(
                f"BUG: {len(matches)} active leads share code {code}; "
                f"lead_ids={collision_lead_ids}; refusing.\n"
            )
            return EXIT_ILLEGAL_TRANSITION

        lead = matches[0]
        lead_id_for_output = lead.lead_id
        now = customer_now(cfg.customer.timezone)
        prev_status = lead.status

        # Apply transition
        decision_map = {
            "approve": "OWNER_APPROVED",
            "reject": "OWNER_REJECTED",
            "edit": "OWNER_EDITED",
        }
        new_status = decision_map[args.decision]
        new_status_for_output = new_status

        # Update lead in-place
        for i, l in enumerate(store.leads):
            if l.lead_id == lead.lead_id:
                store.leads[i] = l.model_copy(update={
                    "status": new_status,
                    "updated_at": now,
                })
                lead = store.leads[i]
                break

        # On approve, capture target JID and render quote BEFORE writing —
        # we'll send AFTER lock release. v0.3 Q1 fix: quote_text MUST be
        # persisted on the lead before atomic_write_json (currently empty
        # for all production leads — the data integrity bug discovered during
        # E2E audit).
        if args.decision == "approve":
            # target_jid is captured pre-mutation intentionally (review L5):
            # subsequent model_copy preserves customer_phone, but capturing
            # here makes the JID-vs-mutation invariant explicit at the
            # point of computation rather than implicit in the model_copy
            # contract.
            target_jid = f"{lead.customer_phone[1:]}@s.whatsapp.net"
            try:
                quote_text, menu_load_status = _render_quote(lead, lead.customer_name or "")
            except ValueError as render_err:
                # A4 fix: template format error is LOUD, NOT a silent inline fallback.
                # Review M2: also emit a durable audit row so operators see
                # the loop in decisions.log (was: stderr-only, retries showed
                # no audit trail — operator could not diagnose stuck approves).
                try:
                    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
                    with flock(LOG_PATH):
                        ndjson_append(
                            LOG_PATH,
                            TypeAdapter(CateringQuoteRenderFailed).dump_json(
                                CateringQuoteRenderFailed(
                                    type="catering_quote_render_failed",
                                    ts=datetime.now(tz=timezone.utc),
                                    lead_id=lead.lead_id,
                                    code=code,
                                    error_class=type(render_err).__name__,
                                    detail=str(render_err)[:2000],
                                ),
                            ).decode("utf-8"),
                        )
                except Exception as audit_err:
                    sys.stderr.write(
                        f"WARN: CateringQuoteRenderFailed audit-write failed "
                        f"(non-fatal): {type(audit_err).__name__}: {audit_err}\n"
                    )
                sys.stderr.write(
                    f"FATAL: catering quote template error: {render_err}\n"
                    f"  Owner approved lead {lead.lead_id} but customer quote could "
                    f"not be rendered. State left at AWAITING_OWNER_APPROVAL.\n"
                )
                return EXIT_DEPENDENCY_DOWN
            # A3 fix: refuse approve when menu load returned corrupt/io_error.
            # "absent" is OK — first-run customer with no menu uploaded yet.
            if menu_load_status in ("corrupt", "io_error"):
                sys.stderr.write(
                    f"FATAL: catering menu load failed (status={menu_load_status}). "
                    f"Refusing approve for {lead.lead_id}.\n"
                )
                return EXIT_DEPENDENCY_DOWN

            # Q1 fix: persist quote_text on the lead before atomic write.
            for i, l in enumerate(store.leads):
                if l.lead_id == lead.lead_id:
                    store.leads[i] = l.model_copy(update={
                        "quote_text": quote_text,
                        "quote_version": (l.quote_version or 0) + 1,
                    })
                    lead = store.leads[i]
                    break

            # v0.3 A1+A2: idempotency anchor written BEFORE state-write (within
            # same lock). On retry from a crashed run, presence of this audit
            # row is the durable signal that approve was attempted; operators
            # use it to manually resolve "lead in OWNER_APPROVED but no
            # CateringQuoteSent" cases. Best-effort: audit failure does NOT
            # block state-write (that's a different invariant), but the
            # WARN surfaces in journald.
            try:
                _log(TypeAdapter(CateringQuoteAttempted), CateringQuoteAttempted(
                    type="catering_quote_attempted",
                    ts=now,
                    lead_id=lead.lead_id,
                    original_message_id=lead.original_message_id,
                    code=code,
                ))
            except Exception as anchor_err:
                sys.stderr.write(
                    f"WARN: CateringQuoteAttempted audit-write failed "
                    f"(non-fatal, pre-state): "
                    f"{type(anchor_err).__name__}: {anchor_err}\n"
                )

        atomic_write_json(LEADS_PATH, store)

        # Audit trail (in lock to keep ordering with state write)
        _log(TypeAdapter(CateringLeadStatusChange), CateringLeadStatusChange(
            type="catering_lead_status_change", ts=now,
            lead_id=lead.lead_id, from_status=prev_status, to_status=new_status,
            actor="owner", reason=args.reason or args.edit_text[:100] or args.decision,
        ))
        _log(TypeAdapter(CateringOwnerDecision), CateringOwnerDecision(
            type="catering_owner_decision", ts=now,
            lead_id=lead.lead_id, decision=args.decision,
            edit_text=args.edit_text[:1000] if args.decision == "edit" else "",
        ))

    # Outside lock: handle outbound for approve
    if args.decision != "approve":
        print(json.dumps({"lead_id": lead_id_for_output, "new_status": new_status_for_output,
                          "outbound_sent": False}))
        return EXIT_OK

    if not target_jid or not quote_text:
        sys.stderr.write("BUG: approve path missing target_jid or quote_text\n")
        return EXIT_SCHEMA_VIOLATION

    ok, mid_or_err = _bridge_post(target_jid, quote_text)
    if not ok:
        sys.stderr.write(f"bridge_post to customer failed: {mid_or_err}\n")
        # State has already moved to OWNER_APPROVED; quote delivery uncertain.
        # Don't auto-transition to SENT_TO_CUSTOMER. Operator visibility via Pushover
        # is the caller's responsibility (Kimi can decide based on this exit code).
        print(json.dumps({"lead_id": lead_id_for_output, "new_status": new_status_for_output,
                          "outbound_sent": False, "error": mid_or_err}))
        return EXIT_DEPENDENCY_DOWN

    # Quote delivered — record SENT_TO_CUSTOMER + CateringQuoteSent
    with FileLock(LEADS_LOCK):
        store, _ = load_model(LEADS_PATH, CateringLeadStore, default=CateringLeadStore())
        for i, l in enumerate(store.leads):
            if l.lead_id == lead_id_for_output:
                store.leads[i] = l.model_copy(update={
                    "status": "SENT_TO_CUSTOMER",
                    "updated_at": customer_now(cfg.customer.timezone),
                })
                break
        atomic_write_json(LEADS_PATH, store)

        now2 = customer_now(cfg.customer.timezone)
        _log(TypeAdapter(CateringLeadStatusChange), CateringLeadStatusChange(
            type="catering_lead_status_change", ts=now2,
            lead_id=lead_id_for_output, from_status="OWNER_APPROVED",
            to_status="SENT_TO_CUSTOMER", actor="system",
            reason="customer_send_succeeded",
        ))
        _log(TypeAdapter(CateringQuoteSent), CateringQuoteSent(
            type="catering_quote_sent", ts=now2,
            lead_id=lead_id_for_output,
            customer_phone=store.leads[i].customer_phone,
            outbound_message_id=mid_or_err,
        ))

    print(json.dumps({"lead_id": lead_id_for_output, "new_status": "SENT_TO_CUSTOMER",
                      "outbound_sent": True, "outbound_message_id": mid_or_err}))
    return EXIT_OK


if __name__ == "__main__":
    sys.exit(main())
