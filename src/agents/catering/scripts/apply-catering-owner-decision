#!/usr/bin/env python3
"""apply-catering-owner-decision — Agent #2 owner-approval state writer.

Called by Kimi (via the handle_catering_owner_approval SKILL) when the
owner has replied to a catering approval card with a code + verb. This
script is deterministic — it transitions the lead's status and, on
APPROVE, sends the quote to the customer.

Usage:
  apply-catering-owner-decision \\
    --code "#A3F2X" \\
    --decision approve

  apply-catering-owner-decision \\
    --code "#A3F2X" \\
    --decision edit \\
    --edit-text "make it $400 cap; add appetizer pricing"

  apply-catering-owner-decision \\
    --code "#A3F2X" \\
    --decision reject \\
    --reason "out of capacity that weekend"

Outputs JSON: {"lead_id": "L0007", "new_status": "SENT_TO_CUSTOMER",
               "outbound_message_id": "..."}.

Exit codes:
  0  — applied
  2  — invalid input
  4  — code not found among active leads
  5  — schema violation
  6  — bridge unreachable (state still updated; quote delivery uncertain)
  9  — illegal transition (lead in terminal/wrong status)
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
import unicodedata
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

sys.path.insert(0, "/opt/shift-agent")
sys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent.parent / "platform"))

from safe_io import (  # noqa: E402
    FileLock, ndjson_append, atomic_write_json, customer_now,
    load_model, flock, assert_load_status_clean, LoadStatusError,
    load_yaml_model,
)
from safe_io import bridge_post_2tuple as _bridge_post  # noqa: E402  # PR-ε: chokepoint consolidation
from schemas import (  # noqa: E402
    Config, CateringLeadStore,
    CateringLeadStatusChange, CateringOwnerDecision, CateringQuoteSent,
    CateringQuoteAttempted,  # PR-D2 commit 3: anchor row schema (PR-D1)
    CateringQuoteSkillFailed,  # PR-B v3: SKILL handoff failure audit
)
from exit_codes import (  # noqa: E402
    EXIT_OK, EXIT_INVALID_INPUT, EXIT_NOT_FOUND,
    EXIT_SCHEMA_VIOLATION, EXIT_DEPENDENCY_DOWN, EXIT_ILLEGAL_TRANSITION,
    EXIT_TRUTH_GUARD_FAILED,  # PR-B v3 review fix: distinct from bridge-unreachable
    EXIT_PRIVILEGE_DENIED,
)
from audit_helpers import (  # noqa: E402
    log_config_load_failed_best_effort,
    log_quote_sent_lead_missing_best_effort,
)
from schemas import CateringQuoteSentLeadMissing  # noqa: E402  # PR-D2 commit 2
from pydantic import TypeAdapter, ValidationError  # noqa: E402

# PR-D2 commit 1: SHIFT_AGENT_CONFIG_PATH env var override (test-only;
# defaults to deployed location). Hides the override from operator-typo
# risk in normal usage; tests use monkeypatch.setenv.
CONFIG_PATH = Path(os.environ.get("SHIFT_AGENT_CONFIG_PATH", "/opt/shift-agent/config.yaml"))
LEADS_PATH = Path(os.environ.get("SHIFT_AGENT_LEADS_PATH", "/opt/shift-agent/state/catering-leads.json"))
LEADS_LOCK = Path(os.environ.get("SHIFT_AGENT_LEADS_LOCK", str(LEADS_PATH) + ".lock"))
LOG_PATH = Path(os.environ.get("SHIFT_AGENT_LOG_PATH", "/opt/shift-agent/logs/decisions.log"))
# PR-B: retained immutable quote-version ledger sidecar (own lock; additive).
LEDGER_PATH = Path(os.environ.get(
    "SHIFT_AGENT_CATERING_QUOTE_LEDGER_PATH",
    "/opt/shift-agent/state/catering-quote-ledger.json"))

# PR-B v3 — drafted-quote stdin caps and Unicode strip categories.
# 8KB stdin read cap is generous (LLM drafts run ~300-500 chars in practice);
# 4KB final-text cap rejects payloads that grow past sane limits during the
# read; 600-char output cap is the WhatsApp readability ceiling. Cc=control
# chars (NUL, BEL, ESC); Cf=format chars (RTL-override, zero-width, BOM, etc.)
# — both stripped except literal newlines.
_QUOTE_STDIN_READ_CAP = 8192
_QUOTE_TEXT_MAX_BYTES = 4096
_QUOTE_OUTPUT_CAP_CHARS = 600
_STRIP_UNICODE_CATEGORIES = frozenset({"Cc", "Cf", "Cs", "Co", "Cn"})
_MARKDOWN_DELIM_RE = re.compile(r"[*_~`]+")


def _normalize_quote_text(s: str) -> str:
    """PR-B v3 — strip control/format Unicode + markdown delimiters; cap length.

    NFC normalize, drop Cc/Cf/Cs/Co/Cn categories (control + format + surrogate
    + private + unassigned) except literal '\\n', strip markdown delimiters
    (`* _ ~ \\``), normalize CRLF→LF, cap to 600 chars. Defense against:
    - Prompt-injected RTL-override / zero-width chars in WhatsApp display
    - LLM emitting markdown when prompted for plain prose
    - Runaway output exceeding WhatsApp message limits
    """
    normalized = unicodedata.normalize("NFC", s).replace("\r\n", "\n").replace("\r", "\n")
    chars = []
    for ch in normalized:
        if ch == "\n":
            chars.append(ch)
            continue
        if unicodedata.category(ch) in _STRIP_UNICODE_CATEGORIES:
            continue
        chars.append(ch)
    out = "".join(chars)
    out = _MARKDOWN_DELIM_RE.sub("", out)
    return out[:_QUOTE_OUTPUT_CAP_CHARS]


def _render_quote_from_lead_state(lead) -> str:
    """PR-CF1c 2026-05-12: render a default quote text from lead state alone.

    Mirrors finalize-catering-menu's --auto-default shape — server-authoritative,
    no LLM composition, no hallucination surface. Same body shape used in the
    one-shot manual verification on L0005 (see tasks/hermes-v0-13-0-plugin-api-
    recon-2026-05-11.md Phase 9 §"verbatim jq spec"). The _truth_guard_check
    that follows this rendering will pass naturally because the rendered text
    contains the lead's headcount and event_date by construction.
    """
    customer_name = lead.customer_name or "(unknown)"
    customer_phone = lead.customer_phone or "(unknown)"
    items_lines: list[str] = []
    for it in (lead.selected_items or []):
        items_lines.append(f"- {it.name} x{it.qty} @ ${it.price_usd}")
    items_block = "\n".join(items_lines) if items_lines else "- (no items selected)"
    total = lead.quote_total_usd or 0
    event_date = (lead.extracted.event_date if lead.extracted else None) or "(TBD)"
    headcount = (lead.extracted.headcount if lead.extracted else None) or 0
    return (
        f"Quote for {lead.lead_id} ({customer_name} / {customer_phone}):\n"
        f"{items_block}\n\n"
        f"Total: ${total}\n"
        f"Event: {event_date} | Headcount: {headcount}"
    )


def _truth_guard_check(quote_text: str, lead) -> tuple[bool, str]:
    """PR-B v3 — minimum sanity check on LLM-drafted quote.

    Returns (passed, reason). Reason empty on pass; otherwise one of the
    CateringQuoteSkillFailed.reason Literals (specifically truth_guard_failed
    sub-reasons surfaced via `detail`).

    Two checks only (anti-hallucination minimum):
    - if lead.extracted.headcount is set: literal integer must appear in the
      drafted prose with a word boundary, NOT as a substring of a longer
      number (e.g. "50,000" doesn't pass the headcount=50 check)
    - if lead.extracted.event_date is set: literal ISO YYYY-MM-DD must
      appear (SKILL prompt instructs LLM to include `(YYYY-MM-DD)`
      parenthetical alongside any prose date — see SKILL.md)

    Wider checks (customer-name match, headcount-None hallucination scan,
    fuzzy date prose, menu-item / price hallucination) intentionally
    deferred to v0.5 per design v3 §1 Hermes-first checklist.
    """
    hc = lead.extracted.headcount
    if hc is not None:
        # \b{hc}\b with negative lookahead: rejects "50,000" / "50.5" etc.
        # Accepts "for 50, our buffet..." (comma-followed-by-space, not digit).
        if not re.search(rf"\b{re.escape(str(hc))}\b(?!\d|[,.]\d)", quote_text):
            return False, f"headcount={hc} not present"
    ed = lead.extracted.event_date
    if ed and ed not in quote_text:
        return False, f"event_date={ed!r} ISO not present"
    return True, ""


def _emit_quote_skill_failed_best_effort(lead_id: str, code: str,
                                          reason: str, detail: str = "") -> None:
    """PR-B v3 — write CateringQuoteSkillFailed audit row best-effort.

    Best-effort: failures during emission (lock contention, disk full,
    schema regression) write a stderr WARN but do NOT raise. Mirrors
    audit_helpers.log_quote_sent_lead_missing_best_effort pattern (PR-D2).

    Review-fix B1: pass model_dump_json (str) to ndjson_append, NOT
    json.loads of it (which produced a dict and silently AttributeError'd
    inside the bare except). Matches deployed pattern at line ~210
    (_append_log_with_outer_leadslock).
    Review-fix H3: wrap the append in flock(LOG_PATH) — every other
    LOG_PATH writer holds it; deployed-pattern drift caught at PR review.
    """
    try:
        ts = datetime.now(timezone.utc).isoformat()
        entry = CateringQuoteSkillFailed(
            type="catering_quote_skill_failed", ts=ts,
            lead_id=lead_id, code=code, reason=reason, detail=detail[:2000],
        )
        with flock(LOG_PATH):
            ndjson_append(LOG_PATH, entry.model_dump_json())
    except Exception as e:  # noqa: BLE001 — best-effort by contract
        sys.stderr.write(
            f"WARN: failed to emit CateringQuoteSkillFailed audit row: "
            f"{type(e).__name__}: {e}\n"
        )


def _append_quote_ledger_best_effort(lead, *, source: str, now) -> None:
    """PR-B: append the lead's committed quote state to the quote ledger AFTER the
    lead-store commit succeeded and LEADS_LOCK is released (leaf lock held alone).
    BEST-EFFORT — a ledger failure NEVER rolls back the lead write; it logs loudly.
    Used on the owner-EDIT path so each owner revision is a durable committed
    version. `lead` is the updated CateringLead model."""
    try:
        import catering_quote_ledger as _ql  # lazy; module is deployed flat
        selected = [{"name": it.name, "qty": it.qty, "price_usd": it.price_usd}
                    for it in (lead.selected_items or [])]
        res = _ql.append_version(
            lead_id=lead.lead_id, quote_text=lead.quote_text or "",
            quote_total_usd=lead.quote_total_usd or 0, selected_items=selected,
            source=source, approval_code=lead.owner_approval_code, created_at=now,
            data_path=LEDGER_PATH,
        )
        if not res.ok:
            sys.stderr.write(
                f"WARN: quote-ledger append failed (non-fatal) for {lead.lead_id} "
                f"source={source}: {res.reason}\n"
            )
    except Exception as e:  # noqa: BLE001 — ledger is a best-effort sidecar
        sys.stderr.write(
            f"WARN: quote-ledger append raised (non-fatal) for "
            f"{getattr(lead, 'lead_id', '?')}: {type(e).__name__}: {e}\n"
        )


def _append_log_with_outer_leadslock(adapter: TypeAdapter, entry) -> None:
    """PR-D2: rename of _log() with docstring pinning lock-acquisition order.

    Caller MUST hold LEADS_LOCK (outer). This helper acquires LOG_PATH flock
    (inner) for cross-script append safety with parse-menu-photo +
    apply-menu-update which hold DIFFERENT state locks but write the same
    LOG_PATH. Lock-acquisition order: outer LEADS_LOCK → inner LOG_PATH.
    Menu-side scripts hold no LEADS_LOCK so cannot deadlock against this
    nesting.

    Renamed from _log() per design v2 §9.2 R5-H2 (rename pin). All callsites
    in this file updated atomically in this commit.
    """
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with flock(LOG_PATH):
        ndjson_append(LOG_PATH, adapter.dump_json(entry).decode("utf-8"))


# Backwards-compat shim — keep `_log` as an alias so any local reference
# this commit might miss surfaces as a runtime error rather than silent
# fallback. Removed in a later commit once rename is verified clean.
_log = _append_log_with_outer_leadslock


def _tail_scan_anchor(
    log_path: Path,
    code: str,
    max_lines: int = 5000,
) -> Optional[CateringQuoteAttempted]:
    """PR-D2 commit 3 + design v2 §9.2 R1-H-2: scan back through decisions.log
    for the LATEST catering_quote_attempted row matching `code`. Returns None
    if no match within max_lines.

    No timestamp cutoff (R1-H-2 fix): trust file order, not server clock.
    Forward-read all rows, filter by code+type, return the LAST match
    (latest by file order). Tolerates NTP correction events.

    Tolerates concurrent menu-script appends to the same log; only
    catering_quote_attempted rows match. apply-decision is the sole writer
    of those rows so no race on filtered subset.

    On max_lines exhaustion: emits stderr line `tail_scan_truncated` so
    soak watchlist (deploy step 6) can grep for fleet-scale capacity drift.
    NDJSON variant deferred to PR-D3.
    """
    if not log_path.exists():
        return None
    matches: list[CateringQuoteAttempted] = []
    line_count = 0
    truncated = False
    adapter = TypeAdapter(CateringQuoteAttempted)
    with log_path.open("r", encoding="utf-8") as f:
        for line in f:
            line_count += 1
            if line_count > max_lines:
                truncated = True
                break
            line = line.strip()
            if not line or '"catering_quote_attempted"' not in line:
                continue
            try:
                row = json.loads(line)
            except json.JSONDecodeError:
                continue
            if row.get("type") != "catering_quote_attempted" or row.get("code") != code:
                continue
            try:
                entry = adapter.validate_python(row)
            except Exception:
                continue
            matches.append(entry)
    if truncated:
        sys.stderr.write(f"tail_scan_truncated kind=anchor code={code} max_lines={max_lines}\n")
    return matches[-1] if matches else None


def _tail_scan_quote_sent(
    log_path: Path,
    lead_id: str,
    max_lines: int = 5000,
) -> Optional[CateringQuoteSent]:
    """PR-D2 commit 3: mirror of _tail_scan_anchor for catering_quote_sent
    rows. Used by retry-state-machine (commit 4) to short-circuit on
    proven customer delivery."""
    if not log_path.exists():
        return None
    matches: list[CateringQuoteSent] = []
    line_count = 0
    truncated = False
    adapter = TypeAdapter(CateringQuoteSent)
    with log_path.open("r", encoding="utf-8") as f:
        for line in f:
            line_count += 1
            if line_count > max_lines:
                truncated = True
                break
            line = line.strip()
            if not line or '"catering_quote_sent"' not in line:
                continue
            try:
                row = json.loads(line)
            except json.JSONDecodeError:
                continue
            if row.get("type") != "catering_quote_sent" or row.get("lead_id") != lead_id:
                continue
            try:
                entry = adapter.validate_python(row)
            except Exception:
                continue
            matches.append(entry)
    if truncated:
        sys.stderr.write(f"tail_scan_truncated kind=quote_sent lead_id={lead_id} max_lines={max_lines}\n")
    return matches[-1] if matches else None


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--code", required=True, help="approval code from owner reply, e.g. #A3F2X")
    ap.add_argument("--decision", required=True, choices=["approve", "reject", "edit"])
    ap.add_argument("--edit-text", default="", help="required when decision=edit")
    ap.add_argument("--reason", default="", help="optional rejection reason")
    ap.add_argument(
        "--quote-text-stdin", action="store_true",
        help="PR-B v3: read drafted customer quote text from stdin (required "
             "for decision=approve UNLESS --quote-from-lead-state is set). "
             "Replaces the previous template-render path and the argv-based "
             "--quote-text (which was a shell-escape RCE surface). Stdin is "
             "read up to 8KB; final text capped at 4KB; output is "
             "normalize-stripped and capped at 600 chars.",
    )
    ap.add_argument(
        "--quote-from-lead-state", action="store_true",
        help="PR-CF1c 2026-05-12: render quote text server-side from the lead's "
             "selected_items + extracted fields (mirror of finalize-catering-menu's "
             "--auto-default shape). When set, --quote-text-stdin is NOT required "
             "for decision=approve. Designed for cf-router F8 path which has no "
             "LLM-composed quote text to pipe via stdin. Requires the lead to be "
             "in CUSTOMER_FINALIZED (or later) state with selected_items populated; "
             "otherwise returns EXIT_INVALID_INPUT.",
    )
    ap.add_argument(
        "--skip-finalize", action="store_true",
        help="PR-CF1: by default, approve refuses if the lead has no "
             "customer_finalized_at (i.e. customer hasn't run the finalize "
             "flow yet). Owner can override with --skip-finalize to approve "
             "based on the original inquiry alone. The default is a soft "
             "guard against owner approving speculatively — the customer "
             "may have made selections in conversation that the owner "
             "should see before approving.",
    )
    ap.add_argument(
        "--sender-role", required=True,
        choices=["owner", "employee", "customer", "unknown"],
        help="resolved sender role from identify-sender; must be 'owner' to mutate state. "
             "Defense-in-depth against a screenshot-forwarded #XXXXX code that the "
             "dispatcher's role-gate failed to catch upstream (B-021).",
    )
    args = ap.parse_args()

    # Privilege check: owner-only operation. Reject before any state read/lock
    # so an attacker-controlled --code can't be probed against the leads file.
    if args.sender_role != "owner":
        sys.stderr.write(
            f"privilege denied: catering owner approval is owner-only, "
            f"got sender_role={args.sender_role!r}\n"
        )
        return EXIT_PRIVILEGE_DENIED

    if args.decision == "edit" and not args.edit_text.strip():
        sys.stderr.write("--edit-text required when decision=edit\n")
        return EXIT_INVALID_INPUT

    code = args.code.strip()
    if not code.startswith("#") or len(code) != 6:
        sys.stderr.write(f"invalid code format (expected #XXXXX): {code!r}\n")
        return EXIT_INVALID_INPUT

    # Load config — PR-D2 commit 1: load_yaml_model + best-effort audit
    try:
        cfg = load_yaml_model(CONFIG_PATH, Config)
    except (FileNotFoundError, RuntimeError, ValidationError) as e:
        log_config_load_failed_best_effort(CONFIG_PATH, e, log_path=LOG_PATH)
        sys.stderr.write(f"config load failed: {type(e).__name__}: {e}\n")
        return EXIT_SCHEMA_VIOLATION

    # Find + transition the lead under FileLock
    quote_text: Optional[str] = None
    target_jid: Optional[str] = None
    new_status_for_output: str = ""
    lead_id_for_output: str = ""

    with FileLock(LEADS_LOCK):
        store, status = load_model(LEADS_PATH, CateringLeadStore, default=CateringLeadStore())
        try:
            assert_load_status_clean(LEADS_PATH, status, context="apply-decision initial load")
        except LoadStatusError as e:
            # Silent-failure-hunter NEW-1: oserror MUST NOT be silently masked
            # as no-such-lead. File-but-unreadable is a different operator
            # signal than missing.
            sys.stderr.write(f"{e}\n")
            return EXIT_SCHEMA_VIOLATION

        # PR-D2 commit 4: retry-state-machine via matcher widening + idempotent_replay short-circuit.
        # Decision tree (design v2 §4.6, 5 rows simplified into 3 branches):
        #   Row 1+2: tail-scan finds catering_quote_sent for the lead → customer
        #            already received quote → idempotent_replay short-circuit.
        #            Advance status if still OWNER_APPROVED.
        #   Row 3+4: code matches a lead in {AWAITING_OWNER_APPROVAL, OWNER_APPROVED}
        #            AND no quote_sent row → fresh attempt or resume.
        #            Anchor (if present) gets superseded by success/failed
        #            anchor written by the post-bridge sequence.
        #   Row 5:   no recoverable state → EXIT_NOT_FOUND.
        # OWNER_EDITED is NOT in the matcher (R2-H1 fix): owner sent edit, retry-
        # approve with same code would ship un-edited quote — money-moving correctness.
        #
        # R1 H-1 (PR-review) acknowledgement: design v2 Row 2 (anchor=success +
        # quote_sent missing) is intentionally NOT implemented as a separate
        # branch. Post-B-1 reorder writes CateringQuoteSent FIRST after bridge
        # POST, so anchor=success without quote_sent is unreachable in normal
        # flow. If it occurs (e.g. legacy row from pre-PR-D2 emission, or
        # journald rotation losing the quote_sent row), the retry would re-POST.
        # Policy: "delivered twice << never delivered". Synthetic retry probe
        # (canary minute 5 + 45) measures real-world frequency.

        # Match code: AWAITING_OWNER_APPROVAL (fresh) OR OWNER_APPROVED (retry/self-heal)
        # for approve decision. For reject/edit, only AWAITING_OWNER_APPROVAL.
        if args.decision == "approve":
            # PR-CF1: CUSTOMER_FINALIZED is the new "ready to approve" state.
            # AWAITING_OWNER_APPROVAL still allowed (legacy / non-finalized leads
            # via --skip-finalize override). OWNER_APPROVED retained for retry.
            matches = [l for l in store.leads
                       if l.owner_approval_code == code
                       and l.status in (
                           "AWAITING_OWNER_APPROVAL",
                           "CUSTOMER_FINALIZED",  # PR-CF1
                           "OWNER_APPROVED",
                       )]
        else:
            # PR-CF1: edit/reject also valid from CUSTOMER_FINALIZED (customer
            # finalized but owner wants to revise / decline).
            matches = [l for l in store.leads
                       if l.owner_approval_code == code
                       and l.status in (
                           "AWAITING_OWNER_APPROVAL",
                           "CUSTOMER_FINALIZED",  # PR-CF1
                       )]

        if not matches:
            sys.stderr.write(f"no recoverable lead with code {code}\n")
            any_match = [l for l in store.leads if l.owner_approval_code == code]
            if any_match:
                sys.stderr.write(
                    f"  (code {code} exists on lead {any_match[0].lead_id} but in status {any_match[0].status})\n"
                )
            return EXIT_NOT_FOUND
        if len(matches) > 1:
            sys.stderr.write(
                f"BUG: {len(matches)} active leads share code {code}; refusing\n"
            )
            return EXIT_ILLEGAL_TRANSITION

        lead = matches[0]
        lead_id_for_output = lead.lead_id

        # PR-CF1: owner-approve guard for non-finalized leads.
        # If customer hasn't run the finalize flow (customer_finalized_at is
        # None), approving sends a quote based on the original inquiry alone
        # — without seeing what the customer might have curated during
        # brainstorm. Soft-guard that the owner explicitly overrides via
        # --skip-finalize. Skip the guard for OWNER_APPROVED retries (the
        # idempotent_replay branch below handles those — the lead was already
        # past the gate).
        if (
            args.decision == "approve"
            and lead.status == "AWAITING_OWNER_APPROVAL"
            and lead.customer_finalized_at is None
            and not args.skip_finalize
        ):
            sys.stderr.write(
                f"PR-CF1: lead {lead.lead_id} {code} not customer-finalized "
                f"and --skip-finalize not set; refusing approve.\n"
            )
            # Audit (best-effort; ndjson_append used directly per deployed pattern)
            now_guard = customer_now(cfg.customer.timezone)
            try:
                ndjson_append(
                    LOG_PATH,
                    CateringQuoteSkillFailed(
                        type="catering_quote_skill_failed", ts=now_guard,
                        lead_id=lead.lead_id, code=code,
                        reason="owner_approve_without_customer_finalize",
                        detail=(
                            "owner sent #XXXXX approve without customer "
                            "finalize; --skip-finalize override required"
                        ),
                    ).model_dump_json(),
                )
            except Exception as e:
                sys.stderr.write(f"audit emit (cf1-guard) failed (non-fatal): {e}\n")
            # Reprompt the owner (best-effort; bridge failure is not blocking).
            # R2.H1 fix: do NOT instruct WhatsApp '#XXXXX approve --skip-finalize'.
            # The SKILL parser cannot reliably extract argparse flags from a
            # WhatsApp natural-language reply; that path would loop indefinitely.
            # Either wait for the customer to finalize, or override via cockpit
            # (the operator-tooling path that DOES forward --skip-finalize).
            if cfg.owner.self_chat_jid:
                reprompt = (
                    f"⚕ *Catering Agent*\n────────────\n"
                    f"Lead {lead.lead_id} {code}: customer hasn't finalized "
                    f"their menu selection yet. Either (a) wait for the customer "
                    f"to confirm their items, or (b) override via cockpit "
                    f"(operator action — sends the original inquiry as a quote "
                    f"without customer-curated items)."
                )
                try:
                    _bridge_post(cfg.owner.self_chat_jid, reprompt)
                except Exception as e:
                    sys.stderr.write(f"reprompt POST failed (non-fatal): {e}\n")
            return EXIT_TRUTH_GUARD_FAILED

        # ROW 1+2 (idempotent_replay): tail-scan for quote_sent of THIS lead.
        # If found, customer demonstrably received quote (post-B-1 reorder, this
        # row is written FIRST after bridge POST). Advance status under the
        # SAME LEADS_LOCK as the tail-scan (R2-H-2 pin).
        if args.decision == "approve":
            quote_sent_existing = _tail_scan_quote_sent(LOG_PATH, lead.lead_id)
            if quote_sent_existing is not None:
                now_replay = customer_now(cfg.customer.timezone)
                if lead.status == "OWNER_APPROVED":
                    matched_idx = next(
                        (i for i, l in enumerate(store.leads) if l.lead_id == lead.lead_id),
                        None,
                    )
                    if matched_idx is not None:
                        store.leads[matched_idx] = store.leads[matched_idx].model_copy(update={
                            "status": "SENT_TO_CUSTOMER",
                            "updated_at": now_replay,
                        })
                        atomic_write_json(LEADS_PATH, store)
                        _append_log_with_outer_leadslock(
                            TypeAdapter(CateringLeadStatusChange),
                            CateringLeadStatusChange(
                                type="catering_lead_status_change", ts=now_replay,
                                lead_id=lead.lead_id,
                                from_status="OWNER_APPROVED",
                                to_status="SENT_TO_CUSTOMER",
                                actor="system",
                                reason="idempotent_replay_recovered",
                            ),
                        )
                print(json.dumps({
                    "lead_id": lead.lead_id,
                    "new_status": "SENT_TO_CUSTOMER",
                    "outbound_sent": True,
                    "idempotent_replay": True,
                    "outbound_message_id": quote_sent_existing.outbound_message_id,
                }))
                return EXIT_OK

        now = customer_now(cfg.customer.timezone)
        prev_status = lead.status

        # Apply transition
        decision_map = {
            "approve": "OWNER_APPROVED",
            "reject": "OWNER_REJECTED",
            "edit": "OWNER_EDITED",
        }
        new_status = decision_map[args.decision]
        new_status_for_output = new_status

        # Update lead in-place
        for i, l in enumerate(store.leads):
            if l.lead_id == lead.lead_id:
                store.leads[i] = l.model_copy(update={
                    "status": new_status,
                    "updated_at": now,
                })
                lead = store.leads[i]
                break

        # On approve, capture target JID before writing — we'll send AFTER lock release
        customer_phone_pre_bridge: Optional[str] = None
        if args.decision == "approve":
            target_jid = f"{lead.customer_phone.lstrip('+')}@s.whatsapp.net"
            # PR-D2 commit 2: capture phone INSIDE the first LEADS_LOCK block,
            # before lock release. Used by post-bridge divergence audit
            # (CateringQuoteSentLeadMissing) if matched_idx returns None on
            # re-load. Captured here because store.leads[matched_idx] may not
            # exist post-bridge.
            customer_phone_pre_bridge = lead.customer_phone

            # PR-B v3: read LLM-drafted quote from stdin (replaces _render_quote
            # template path). Truth-guard checks headcount integer + ISO event_date
            # are present in drafted prose; normalize strips control/format Unicode
            # + markdown delimiters + caps length.
            # PR-CF1c 2026-05-12: --quote-from-lead-state renders server-side
            # from lead state and bypasses the stdin requirement.
            if args.quote_from_lead_state:
                if not lead.selected_items:
                    _emit_quote_skill_failed_best_effort(
                        lead.lead_id, code, "missing_quote_text",
                        "--quote-from-lead-state set but lead has no selected_items "
                        "(customer hasn't finalized yet)",
                    )
                    sys.stderr.write(
                        "PR-CF1c: --quote-from-lead-state requires CUSTOMER_FINALIZED "
                        "lead with non-empty selected_items\n"
                    )
                    return EXIT_INVALID_INPUT
                raw_quote = _render_quote_from_lead_state(lead)
            else:
                if not args.quote_text_stdin:
                    _emit_quote_skill_failed_best_effort(
                        lead.lead_id, code, "missing_quote_text",
                        "--quote-text-stdin flag not provided in approve decision",
                    )
                    sys.stderr.write(
                        "PR-B v3: --quote-text-stdin required for decision=approve "
                        "(or pass --quote-from-lead-state for server-rendered)\n"
                    )
                    return EXIT_INVALID_INPUT
                raw_quote = sys.stdin.read(_QUOTE_STDIN_READ_CAP)
                if len(raw_quote.encode("utf-8")) > _QUOTE_TEXT_MAX_BYTES:
                    _emit_quote_skill_failed_best_effort(
                        lead.lead_id, code, "missing_quote_text",
                        f"stdin payload {len(raw_quote.encode('utf-8'))}B exceeds "
                        f"{_QUOTE_TEXT_MAX_BYTES}B cap",
                    )
                    sys.stderr.write(
                        f"PR-B v3: stdin > {_QUOTE_TEXT_MAX_BYTES}B; refusing\n"
                    )
                    return EXIT_INVALID_INPUT
                if not raw_quote.strip():
                    _emit_quote_skill_failed_best_effort(
                        lead.lead_id, code, "missing_quote_text",
                        "stdin empty / whitespace-only",
                    )
                    sys.stderr.write("PR-B v3: stdin empty\n")
                    return EXIT_INVALID_INPUT
            quote_text = _normalize_quote_text(raw_quote)
            passed, fail_detail = _truth_guard_check(quote_text, lead)
            if not passed:
                _emit_quote_skill_failed_best_effort(
                    lead.lead_id, code, "truth_guard_failed", fail_detail,
                )
                sys.stderr.write(
                    f"PR-B v3: truth_guard rejected drafted quote: {fail_detail}\n"
                )
                # Review-fix HIGH-1: use EXIT_TRUTH_GUARD_FAILED (=11), NOT
                # EXIT_DEPENDENCY_DOWN (=6, "bridge unreachable"). The two
                # failures need DIFFERENT operator responses: bridge-unreachable
                # is a retryable transient that PR-D2 retry-state-machine
                # handles; truth-guard fail needs a re-DRAFT (only the SKILL
                # can do that). Collision would silently misroute retry logic.
                return EXIT_TRUTH_GUARD_FAILED

        atomic_write_json(LEADS_PATH, store)

        # Audit trail (in lock to keep ordering with state write)
        _append_log_with_outer_leadslock(TypeAdapter(CateringLeadStatusChange), CateringLeadStatusChange(
            type="catering_lead_status_change", ts=now,
            lead_id=lead.lead_id, from_status=prev_status, to_status=new_status,
            actor="owner", reason=args.reason or args.edit_text[:100] or args.decision,
        ))
        _append_log_with_outer_leadslock(TypeAdapter(CateringOwnerDecision), CateringOwnerDecision(
            type="catering_owner_decision", ts=now,
            lead_id=lead.lead_id, decision=args.decision,
            edit_text=args.edit_text[:1000] if args.decision == "edit" else "",
        ))

        # PR-D2 commit 3: anchor BEFORE bridge POST. Two-step write contract:
        #   1. Write anchor with bridge_post_outcome="unknown" here, BEFORE
        #      releasing LEADS_LOCK and POSTing.
        #   2. After bridge returns, second anchor row written with
        #      outcome="success" or "failed" (supersedes step-1 row via
        #      tail-scan picking LAST match by file order).
        # If process dies between this write and the bridge POST, retry's
        # tail-scan finds anchor=unknown → re-attempts bridge (Case C row 3
        # in commit 4's retry-state-machine).
        if args.decision == "approve":
            _append_log_with_outer_leadslock(
                TypeAdapter(CateringQuoteAttempted),
                CateringQuoteAttempted(
                    type="catering_quote_attempted", ts=now,
                    lead_id=lead.lead_id,
                    original_message_id=f"_no_inbound_msg_{lead.lead_id}",  # R5 BLOCKER fix: min_length=1
                    code=code,
                    bridge_post_outcome="unknown",
                ),
            )

    # PR-B: on owner EDIT, commit a new immutable quote version to the ledger.
    # Done here — AFTER the LEADS_LOCK block released — so the ledger's own lock is
    # held ALONE (leaf lock). Best-effort: never rolls back the OWNER_EDITED write.
    # (approve does NOT append here: the finalize path already ledgered the version
    # the owner is approving; reject leaves the quote unchanged.)
    if args.decision == "edit":
        _append_quote_ledger_best_effort(lead, source="owner_edit", now=now)

    # Outside lock: handle outbound for approve
    if args.decision != "approve":
        print(json.dumps({"lead_id": lead_id_for_output, "new_status": new_status_for_output,
                          "outbound_sent": False}))
        return EXIT_OK

    if not target_jid or not quote_text:
        sys.stderr.write("BUG: approve path missing target_jid or quote_text\n")
        return EXIT_SCHEMA_VIOLATION

    # F1 fix 2026-05-01: prepend the bridge `template_bypass` prefix so the
    # WhatsApp bridge's outbound filter (defense-in-depth against LLM
    # internal monologue) doesn't drop the customer quote as `announcement`.
    # See bridge.js:133 — messages matching the regex
    #   /^⚕ \*[A-Za-z][A-Za-z ]*\*\n[─\-]+\n/
    # bypass the filter. Without this, LLM-drafted quotes starting with
    # "Thanks", "I", "We're confirming", etc. are silently filtered out.
    # The prefix is added AFTER normalize (which strips markdown delimiters
    # — applied to the LLM body, not this server-side header). Order matters:
    # _normalize_quote_text → _truth_guard_check → prepend prefix → bridge POST.
    quote_text_with_prefix = f"⚕ *Catering Agent*\n────────────\n{quote_text}"

    ok, mid_or_err = _bridge_post(target_jid, quote_text_with_prefix)
    if not ok:
        sys.stderr.write(f"bridge_post to customer failed: {mid_or_err}\n")
        # State has already moved to OWNER_APPROVED; quote delivery uncertain.
        # PR-D2 commit 3: write second anchor row with outcome="failed" so
        # retry knows to re-attempt bridge POST (Case C row 3 in commit 4).
        # Acquire LEADS_LOCK briefly to keep the second-anchor write under
        # the same lock-acquisition convention as the first.
        try:
            with FileLock(LEADS_LOCK):
                _append_log_with_outer_leadslock(
                    TypeAdapter(CateringQuoteAttempted),
                    CateringQuoteAttempted(
                        type="catering_quote_attempted",
                        ts=customer_now(cfg.customer.timezone),
                        lead_id=lead_id_for_output,
                        original_message_id=f"_no_inbound_msg_{lead_id_for_output}",  # R5 BLOCKER fix
                        code=code,
                        bridge_post_outcome="failed",
                    ),
                )
        except Exception as _e:  # noqa: BLE001 — best-effort audit
            sys.stderr.write(f"WARN: failed-anchor write best-effort: {_e}\n")
        print(json.dumps({"lead_id": lead_id_for_output, "new_status": new_status_for_output,
                          "outbound_sent": False, "error": mid_or_err}))
        return EXIT_DEPENDENCY_DOWN

    # Quote delivered — record SENT_TO_CUSTOMER + CateringQuoteSent
    with FileLock(LEADS_LOCK):
        store, status = load_model(LEADS_PATH, CateringLeadStore, default=CateringLeadStore())
        if status != "ok":
            # POST-BRIDGE re-load is stricter: missing/empty/corrupt/oserror
            # here means leads.json disappeared or became unreadable between
            # our two locks, AFTER we already POSTed the customer. State +
            # outbound diverge — operator must reconcile manually.
            #
            # atomic_write uses os.replace (atomic) so readers never see
            # missing/empty during a benign in-flight write. Likely real
            # causes: operator deleted leads.json | filesystem unmounted |
            # writer crashed mid-create before first os.replace landed |
            # quota/EIO at the writer's tmpfile step.
            #
            # PR #33 review-R5 fix: send Pushover priority=2 because
            # state-vs-outbound divergence is the single highest-stakes
            # silent-failure surface in the catering flow. journald-only
            # signaling is too quiet for this branch.
            divergence_msg = (
                f"BUG: leads.json status={status!r} on post-bridge re-load "
                f"(lead {lead_id_for_output}); customer received quote but "
                f"SENT_TO_CUSTOMER not persisted."
            )
            sys.stderr.write(divergence_msg + "\n")
            try:
                import subprocess as _sp
                _sp.run(
                    ["/usr/local/bin/shift-agent-notify-owner",
                     "--priority", "2",
                     "--title", f"BUG state-outbound divergence (lead {lead_id_for_output})",
                     divergence_msg],
                    check=False, timeout=10,
                )
            except Exception as e:  # noqa: BLE001 — notify is best-effort
                sys.stderr.write(
                    f"WARN: shift-agent-notify-owner failed (non-fatal): "
                    f"{type(e).__name__}: {e}\n"
                )
            return EXIT_SCHEMA_VIOLATION
        # PR-D2 commit 2: matched_idx via next() — eliminates the for-loop
        # index leak (line 397 of pre-PR-D2 code referenced store.leads[i].
        # customer_phone where i retained its last-iteration value if no
        # match was found). If matched_idx is None, customer received quote
        # but lead vanished from re-loaded store — emit divergence audit
        # via best-effort helper + Pushover P2 + EXIT_SCHEMA_VIOLATION.
        matched_idx = next(
            (i for i, l in enumerate(store.leads) if l.lead_id == lead_id_for_output),
            None,
        )
        if matched_idx is None:
            divergence_msg = (
                f"BUG: lead {lead_id_for_output} absent from re-loaded store "
                f"after bridge POST succeeded; customer received quote but "
                f"SENT_TO_CUSTOMER not persisted."
            )
            sys.stderr.write(divergence_msg + "\n")
            log_quote_sent_lead_missing_best_effort(
                lead_id=lead_id_for_output,
                original_message_id=f"_no_inbound_msg_{lead_id_for_output}",  # R5 BLOCKER fix
                customer_phone_at_approve=customer_phone_pre_bridge or "",
                outbound_message_id=mid_or_err,
                detail=divergence_msg[:500],
                log_path=LOG_PATH,
            )
            try:
                import subprocess as _sp
                _sp.run(
                    ["/usr/local/bin/shift-agent-notify-owner",
                     "--priority", "2",
                     "--title", f"BUG state-outbound divergence (lead {lead_id_for_output})",
                     divergence_msg],
                    check=False, timeout=10,
                )
            except Exception as e:  # noqa: BLE001
                sys.stderr.write(
                    f"WARN: shift-agent-notify-owner failed (non-fatal): "
                    f"{type(e).__name__}: {e}\n"
                )
            return EXIT_SCHEMA_VIOLATION

        # PR-D2 commit 3 / design v2 §4.4 / B-1 BLOCKER fix:
        # POST-BRIDGE WRITE ORDER. Append-only NDJSON; CateringQuoteSent is
        # written FIRST because it's the only retry-defeating signal for
        # the idempotent_replay short-circuit (commit 4 row 1). If process
        # dies AFTER this row but BEFORE state mutation, retry's tail-scan
        # finds the row → idempotent advance (no duplicate quote).
        now2 = customer_now(cfg.customer.timezone)

        # Step 1: CateringQuoteSent FIRST.
        _append_log_with_outer_leadslock(
            TypeAdapter(CateringQuoteSent),
            CateringQuoteSent(
                type="catering_quote_sent", ts=now2,
                lead_id=lead_id_for_output,
                customer_phone=store.leads[matched_idx].customer_phone,
                outbound_message_id=mid_or_err,
            ),
        )

        # Step 2: success-anchor SECOND (supersedes step-from-first-lock anchor=unknown).
        _append_log_with_outer_leadslock(
            TypeAdapter(CateringQuoteAttempted),
            CateringQuoteAttempted(
                type="catering_quote_attempted", ts=now2,
                lead_id=lead_id_for_output,
                original_message_id=f"_no_inbound_msg_{lead_id_for_output}",  # R5 BLOCKER fix
                code=code,
                bridge_post_outcome="success",
            ),
        )

        # Step 3: state mutation THIRD.
        store.leads[matched_idx] = store.leads[matched_idx].model_copy(update={
            "status": "SENT_TO_CUSTOMER",
            "updated_at": now2,
        })
        atomic_write_json(LEADS_PATH, store)

        # Step 4: status_change audit LAST.
        _append_log_with_outer_leadslock(
            TypeAdapter(CateringLeadStatusChange),
            CateringLeadStatusChange(
                type="catering_lead_status_change", ts=now2,
                lead_id=lead_id_for_output, from_status="OWNER_APPROVED",
                to_status="SENT_TO_CUSTOMER", actor="system",
                reason="customer_send_succeeded",
            ),
        )

    # Slice-2 catering deposit caller (PR feat/commerce-slice2-catering-deposit-caller).
    # Hook fires AFTER LEADS_LOCK releases (above `with FileLock(LEADS_LOCK):`
    # block dedented at line 875) — critical: subprocess MUST NOT run inside
    # parent flock or it self-deadlocks re-acquiring the same lock
    # (Reviewer A BLOCKER-1 fix from design review).
    #
    # The hook is best-effort: a deposit failure NEVER rolls back the quote
    # send. Customer has the quote; deposit link is a follow-up.
    # See tasks/hermes-commerce-slice2-catering-deposit-caller-design.md §2.
    _maybe_invoke_deposit_hook(
        cfg=cfg,
        lead=store.leads[matched_idx],
        lead_id=lead_id_for_output,
    )

    print(json.dumps({"lead_id": lead_id_for_output, "new_status": "SENT_TO_CUSTOMER",
                      "outbound_sent": True, "outbound_message_id": mid_or_err}))
    return EXIT_OK


def _maybe_invoke_deposit_hook(cfg, lead, lead_id: str) -> None:
    """Slice-2 post-send hook: if the lead crosses the deposit threshold,
    subprocess-invoke catering-mint-deposit. NEVER raises; failures are
    journald-logged and best-effort audited.

    Imports the threshold predicate from src/agents/catering/deposit.py.
    Resolves the deposit script via /usr/local/bin (deployed path) with a
    fallback to the repo path for in-place test runs.
    """
    import subprocess
    # Try /opt/shift-agent (deployed VPS layout — deploy script installs
    # deposit.py there) then fall back to the repo path for in-place test
    # runs. The /opt/shift-agent path is already on sys.path (line 47 above).
    try:
        from deposit import _should_mint_deposit  # type: ignore
    except ImportError:
        # Fallback for in-repo test invocations: walk to src/agents/catering
        try:
            _repo_root = Path(__file__).resolve().parent.parent.parent.parent.parent
            sys.path.insert(0, str(_repo_root / "src" / "agents" / "catering"))
            from deposit import _should_mint_deposit  # type: ignore
        except ImportError as e:
            sys.stderr.write(
                f"WARN: catering deposit helper import failed (non-fatal); "
                f"skipping deposit hook for {lead_id}: {e}\n"
            )
            return
    if not _should_mint_deposit(cfg, lead):
        return
    script_paths = [
        Path("/usr/local/bin/catering-mint-deposit"),
        Path(__file__).resolve().parent / "catering-mint-deposit",
    ]
    script_path = next((p for p in script_paths if p.exists()), None)
    if script_path is None:
        sys.stderr.write(
            f"WARN: catering-mint-deposit binary not found in any of "
            f"{[str(p) for p in script_paths]}; skipping deposit for {lead_id}\n"
        )
        return
    try:
        result = subprocess.run(
            [sys.executable, str(script_path), "--lead-id", lead_id],
            capture_output=True, text=True, timeout=30,
            check=False,
        )
        if result.returncode != 0:
            sys.stderr.write(
                f"catering-mint-deposit lead_id={lead_id} exit={result.returncode} "
                f"stderr={result.stderr[:500]}\n"
            )
    except subprocess.TimeoutExpired:
        sys.stderr.write(
            f"catering-mint-deposit lead_id={lead_id} TIMED OUT after 30s; "
            f"deposit will need operator re-invocation\n"
        )
    except Exception as e:  # noqa: BLE001 — hook is best-effort
        sys.stderr.write(
            f"WARN: catering-mint-deposit hook failed (non-fatal): "
            f"{type(e).__name__}: {e}\n"
        )


if __name__ == "__main__":
    sys.exit(main())
