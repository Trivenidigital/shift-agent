#!/usr/bin/env python3
"""catering-owner-action-watchdog — F8 2026-05-01.

Companion to catering-dispatcher-watchdog (F7). Same root cause: Hermes
WhatsApp adapter has no `auto_skill` channel-binding, so the LLM may
bypass the dispatcher SKILL on chat turns 2+. F7 covers customer-inbound
missed-dispatch (the inquiry → lead path); F8 covers owner-inbound
missed-dispatch (the `#XXXXX approve|reject|edit` → apply-decision path).

WHEN THIS FIRES
---------------

Owner sends `#XXXXX approve` (or reject/edit) in their self-chat.
Dispatcher SKILL would normally route to handle_catering_owner_approval
SKILL → apply-catering-owner-decision script. If LLM bypasses the
dispatcher (turn 2+) the owner's command is silently absorbed by the
gateway's LLM monologue and gets dropped by the bridge filter — the lead
stays at AWAITING_OWNER_APPROVAL forever.

Tonight's evidence: owner's `#993HY approve` at 03:02 UTC produced a
generic "Got it. Take care, we'll handle the shift." reply (the shift
agent's stock sick-call ack from LLM history) and L0015 stayed
AWAITING_OWNER_APPROVAL.

WORST-CASE FALLBACK BEHAVIOR
----------------------------

For approve: build a deterministic minimal customer quote text using
the lead's extracted headcount + event_date (truth-guard requires both
to be non-null and parseable). If either is null → SUPPRESS (don't
auto-approve; owner can use cockpit). False-positive cost: customer
gets a generic "your inquiry is confirmed, detailed pricing follows
shortly" rather than a fully-priced quote — recoverable via owner's
follow-up edit.

For reject: pass through with reason="watchdog_owner_fallback".
For edit: SUPPRESS (need owner's edit text — no safe fallback).

DETERMINISM
-----------

No LLM. Regex-matches the owner's text, looks up the lead by code,
shells out to apply-catering-owner-decision (existing deterministic
Python with truth-guard).

Audit via CateringOwnerActionWatchdogFired / CateringOwnerActionWatchdogSuppressed.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

import yaml

sys.path.insert(0, "/opt/shift-agent")

# Deferred imports for cross-platform --text test mode
_audit_imports_loaded = False
_ndjson_append = None
_CateringOwnerActionWatchdogFired = None
_CateringOwnerActionWatchdogSuppressed = None


def _ensure_audit_imports() -> None:
    global _audit_imports_loaded, _ndjson_append
    global _CateringOwnerActionWatchdogFired, _CateringOwnerActionWatchdogSuppressed
    if _audit_imports_loaded:
        return
    from safe_io import ndjson_append
    from schemas import (
        CateringOwnerActionWatchdogFired, CateringOwnerActionWatchdogSuppressed,
    )
    _ndjson_append = ndjson_append
    _CateringOwnerActionWatchdogFired = CateringOwnerActionWatchdogFired
    _CateringOwnerActionWatchdogSuppressed = CateringOwnerActionWatchdogSuppressed
    _audit_imports_loaded = True


# Paths
BRIDGE_LOG = Path("/root/.hermes/whatsapp/bridge.log")
# F12 2026-05-01: see catering-dispatcher-watchdog for the same fix.
GATEWAY_LOG = Path("/root/.hermes/logs/agent.log")
DECISIONS_LOG = Path("/opt/shift-agent/logs/decisions.log")
LEADS_PATH = Path("/opt/shift-agent/state/catering-leads.json")
CONFIG_PATH = Path("/opt/shift-agent/config.yaml")

# Tunables
WATCHDOG_TIMEOUT_SECS = 30
POLL_INTERVAL_SECS = 5
APPLY_DECISION_BIN = "/usr/local/bin/apply-catering-owner-decision"

# Owner-action regex — same alphabet as generate_unique_code (#XXXXX, no I/O/0/1)
_OWNER_ACTION = re.compile(
    r"#([A-HJ-NP-Z2-9]{5})\s+(approve|approved|reject|rejected|"
    r"edit|wait|waiting)\b(?:\s+(.+))?",
    re.IGNORECASE,
)


def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def _safe_unrepr(s: str) -> str:
    """Unquote a Python repr()-style string literal safely (no code execution).

    Handles: 'text', "text", 'text with \\n escapes', etc. Falls back to the
    raw string if unquoting fails.
    """
    s = s.strip()
    if len(s) < 2:
        return s
    quote = s[0]
    if quote not in ("'", '"') or s[-1] != quote:
        return s
    inner = s[1:-1]
    # Decode common Python string escapes
    try:
        # Use json.loads with quoting normalization for safe escape handling
        return json.loads('"' + inner.replace('"', '\\"').replace("\\'", "'") + '"')
    except (ValueError, json.JSONDecodeError):
        return inner


def parse_owner_action(text: str) -> Optional[tuple[str, str, str]]:
    """Return (approval_code, normalized_action, trailing_text) or None."""
    if not text:
        return None
    m = _OWNER_ACTION.search(text)
    if not m:
        return None
    code = "#" + m.group(1).upper()
    raw_action = m.group(2).lower()
    trailing = (m.group(3) or "").strip()
    if raw_action in {"approve", "approved"}:
        action = "approve"
    elif raw_action.startswith("reject"):
        action = "reject"
    elif raw_action == "edit":
        action = "edit"
    elif raw_action.startswith("wait"):
        action = "wait"
    else:
        return None
    return code, action, trailing


def find_dispatcher_routed_for(chat_id: str, since_ts: float) -> bool:
    if not DECISIONS_LOG.exists():
        return False
    chat_lid_only = chat_id.split("@", 1)[0] if "@" in chat_id else chat_id
    try:
        with DECISIONS_LOG.open("r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line or "dispatcher_routed" not in line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if entry.get("type") != "dispatcher_routed":
                    continue
                ts_str = entry.get("ts", "")
                try:
                    ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00")).timestamp()
                except (ValueError, AttributeError):
                    continue
                if ts < since_ts - 5:
                    continue
                sender_lid = entry.get("sender_lid") or ""
                sender_phone = entry.get("sender_phone") or ""
                if chat_lid_only in sender_lid or chat_lid_only in (sender_phone or "").lstrip("+"):
                    return True
    except OSError:
        pass
    return False


def find_inbound_text_for(chat_id: str) -> Optional[str]:
    if not GATEWAY_LOG.exists():
        return None
    chat_lid_only = chat_id.split("@", 1)[0] if "@" in chat_id else chat_id
    pattern = re.compile(
        r"inbound message: platform=\S+ user=\S+ chat=(\S+) msg=([^\n]+)$"
    )
    matches: list[str] = []
    try:
        with GATEWAY_LOG.open("r", encoding="utf-8", errors="replace") as f:
            for line in f:
                m = pattern.search(line)
                if not m:
                    continue
                line_chat = m.group(1)
                line_chat_lid = line_chat.split("@", 1)[0] if "@" in line_chat else line_chat
                if chat_lid_only != line_chat_lid:
                    continue
                msg_repr = m.group(2).strip()
                msg = _safe_unrepr(msg_repr)
                matches.append(str(msg))
    except OSError:
        return None
    return matches[-1] if matches else None


def lookup_lead_by_code(code: str) -> Optional[dict]:
    if not LEADS_PATH.exists():
        return None
    try:
        with LEADS_PATH.open("r", encoding="utf-8") as f:
            store = json.load(f)
    except (OSError, json.JSONDecodeError):
        return None
    for lead in store.get("leads", []):
        if lead.get("owner_approval_code") == code:
            return lead
    return None


def get_owner_self_chat_jid() -> Optional[str]:
    try:
        with CONFIG_PATH.open("r", encoding="utf-8") as f:
            cfg = yaml.safe_load(f) or {}
        return (cfg.get("owner") or {}).get("self_chat_jid")
    except (OSError, yaml.YAMLError):
        return None


def emit_audit(entry_obj) -> None:
    _ensure_audit_imports()
    try:
        _ndjson_append(DECISIONS_LOG, entry_obj.model_dump_json())
    except Exception as e:
        sys.stderr.write(f"audit emit failed (non-fatal): {e}\n")


def _make_fired(**kwargs):
    _ensure_audit_imports()
    return _CateringOwnerActionWatchdogFired(**kwargs)


def _make_suppressed(**kwargs):
    _ensure_audit_imports()
    return _CateringOwnerActionWatchdogSuppressed(**kwargs)


def build_fallback_quote_text(lead: dict) -> Optional[str]:
    """Build a minimal truth-guard-compliant quote text.

    apply-catering-owner-decision's truth-guard requires the rendered text
    to contain BOTH integer headcount AND ISO event_date.
    """
    extracted = lead.get("extracted") or {}
    headcount = extracted.get("headcount")
    event_date = extracted.get("event_date")
    if headcount is None or not event_date:
        return None
    return (
        f"Your catering inquiry for {headcount} people on {event_date} "
        f"is confirmed. We'll send detailed pricing within 24 hours. "
        f"Reply YES to confirm, or call us if you have questions about "
        f"menu, dietary needs, or delivery."
    )


def trigger_apply_decision(
    code: str, decision: str, lead: dict, edit_text: str = "", reason: str = "",
) -> tuple[bool, str]:
    cmd = [APPLY_DECISION_BIN, "--code", code, "--decision", decision]
    stdin_data: Optional[str] = None

    if decision == "approve":
        quote_text = build_fallback_quote_text(lead)
        if quote_text is None:
            return False, "fallback_quote_unavailable_null_extracted_fields"
        cmd.append("--quote-text-stdin")
        stdin_data = quote_text
    elif decision == "reject":
        cmd.extend(["--reason", reason or "watchdog_owner_fallback"])
    elif decision == "edit":
        return False, "edit_path_requires_owner_text_no_safe_fallback"
    elif decision == "wait":
        return False, "wait_action_no_state_change_needed"
    else:
        return False, f"unsupported_decision:{decision}"

    try:
        result = subprocess.run(
            cmd, input=stdin_data, capture_output=True, text=True, timeout=30,
        )
        if result.returncode == 0:
            return True, result.stdout.strip()
        return False, f"exit={result.returncode} stderr={result.stderr[:500]}"
    except (subprocess.SubprocessError, OSError) as e:
        return False, f"{type(e).__name__}: {e}"


def _resolve_role(chat_id: str) -> str:
    """Returns sender role for chat_id via identify-sender. Used to detect owner
    on either phone-JID or LID side (F13 fix: bridge inbound notify shows owner
    chat as their LID, not the phone-JID configured in owner.self_chat_jid)."""
    try:
        result = subprocess.run(
            ["/usr/local/bin/identify-sender", chat_id],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode != 0:
            return "unknown"
        doc = json.loads(result.stdout)
        return doc.get("role", "unknown")
    except (subprocess.SubprocessError, json.JSONDecodeError, OSError):
        return "unknown"


def process_inbound(chat_id: str, message_id: str, owner_jid: str, inbound_seen_ts: float) -> None:
    # F13 2026-05-01: accept inbound from owner via EITHER phone-JID match
    # (owner.self_chat_jid from config) OR identify-sender → role=owner. The
    # bridge inbound notify often shows the owner's LID (e.g. 211390371475536@lid)
    # rather than the phone-JID, and the LID isn't in owner.self_chat_jid. Without
    # this fallback, owner #XXXXX commands on the LID side never reach this watchdog.
    if chat_id != owner_jid:
        role = _resolve_role(chat_id)
        if role != "owner":
            return  # Customer inbounds handled by F7 watchdog

    inbound_text = find_inbound_text_for(chat_id)
    if not inbound_text:
        time.sleep(2)
        inbound_text = find_inbound_text_for(chat_id)
    if not inbound_text:
        return

    parsed = parse_owner_action(inbound_text)
    if not parsed:
        return  # Not an action command — let other handlers take it
    code, action, trailing = parsed

    deadline = inbound_seen_ts + WATCHDOG_TIMEOUT_SECS
    while time.time() < deadline:
        if find_dispatcher_routed_for(chat_id, inbound_seen_ts):
            return  # SKILL ran successfully
        time.sleep(2)

    lead = lookup_lead_by_code(code)
    if not lead:
        emit_audit(_make_suppressed(
            ts=_now_iso(), type="catering_owner_action_watchdog_suppressed",
            chat_id=chat_id, message_id=message_id, code=code, action=action,
            reason="code_not_found",
            detail=f"no lead with owner_approval_code={code}",
        ))
        return

    if lead.get("status") not in {"AWAITING_OWNER_APPROVAL", "OWNER_EDITED"}:
        emit_audit(_make_suppressed(
            ts=_now_iso(), type="catering_owner_action_watchdog_suppressed",
            chat_id=chat_id, message_id=message_id, code=code, action=action,
            reason="lead_terminal_state",
            detail=f"lead.status={lead.get('status')!r} — not actionable",
        ))
        return

    if action in {"edit", "wait"}:
        emit_audit(_make_suppressed(
            ts=_now_iso(), type="catering_owner_action_watchdog_suppressed",
            chat_id=chat_id, message_id=message_id, code=code, action=action,
            reason="action_unsupported_by_watchdog",
            detail=f"action={action!r} requires LLM-side handling (no safe fallback)",
        ))
        return

    success, detail = trigger_apply_decision(
        code=code, decision=action, lead=lead, reason=trailing,
    )
    emit_audit(_make_fired(
        ts=_now_iso(), type="catering_owner_action_watchdog_fired",
        chat_id=chat_id, message_id=message_id, code=code, action=action,
        lead_id=lead.get("lead_id", ""), success=success, detail=detail[:2000],
    ))


def follow_bridge_log() -> None:
    seen_message_ids: set[str] = set()
    notify_pattern = re.compile(
        r'\{"event":"upsert","type":"notify","fromMe":(false|true),'
        r'"chatId":"([^"]+)","senderId":"([^"]+)","messageKeys":\[([^\]]+)\]\}'
    )

    if not BRIDGE_LOG.exists():
        sys.stderr.write(f"bridge log not found: {BRIDGE_LOG}\n")
        sys.exit(2)

    owner_jid = get_owner_self_chat_jid()
    if not owner_jid:
        sys.stderr.write(
            "WARN: owner.self_chat_jid not found in config — "
            "watchdog will be a no-op until configured\n"
        )

    with BRIDGE_LOG.open("r", encoding="utf-8", errors="replace") as f:
        f.seek(0, os.SEEK_END)
        while True:
            line = f.readline()
            if not line:
                time.sleep(POLL_INTERVAL_SECS)
                if not owner_jid:
                    owner_jid = get_owner_self_chat_jid()
                continue
            m = notify_pattern.search(line)
            if not m:
                continue
            from_me, chat_id, _sender_id, _keys = m.group(1), m.group(2), m.group(3), m.group(4)
            if chat_id == "status@broadcast" or chat_id.endswith("@g.us"):
                continue
            # F13 2026-05-01: accept either the configured owner.self_chat_jid
            # OR LID-shaped chat_ids (we'll filter to role=owner inside
            # process_inbound via identify-sender). Phone-JID match is fast-path;
            # LID requires the role lookup.
            if owner_jid and chat_id == owner_jid:
                pass  # fast path
            elif chat_id.endswith("@lid"):
                pass  # role check inside process_inbound
            else:
                continue
            message_id = f"bridge_owner_notify_{chat_id}_{int(time.time()*1000)}_{from_me}"
            if message_id in seen_message_ids:
                continue
            seen_message_ids.add(message_id)
            if len(seen_message_ids) > 1000:
                seen_message_ids = set(list(seen_message_ids)[-500:])
            try:
                process_inbound(chat_id, message_id, owner_jid, time.time())
            except Exception as e:
                sys.stderr.write(f"process_inbound failed (non-fatal): {e}\n")


def main() -> int:
    p = argparse.ArgumentParser(description=__doc__)
    p.add_argument("--text", help="(test mode) parse this text and exit")
    args = p.parse_args()

    if args.text is not None:
        parsed = parse_owner_action(args.text)
        print(json.dumps({"parsed": parsed}))
        return 0

    sys.stderr.write(
        f"catering-owner-action-watchdog starting; tailing {BRIDGE_LOG}, "
        f"timeout={WATCHDOG_TIMEOUT_SECS}s\n"
    )
    follow_bridge_log()
    return 0


if __name__ == "__main__":
    sys.exit(main())

