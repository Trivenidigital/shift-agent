#!/usr/bin/env python3
"""
log-decision-direct — append a Pydantic-validated entry to decisions.log.

Unlike the Phase-0 `log-decision` (which is invoked by skills via Hermes's terminal tool),
this is invoked directly by scripts (kill-switch, reconciler, health-check, etc.)
without any Hermes involvement.

Usage:
  log-decision-direct '<json-string-matching-schemas.LogEntry>'

The JSON must include a valid `type` field and pass Pydantic validation against
the discriminated union LogEntry. Invalid entries are REFUSED (exit 5) rather
than silently written — consistent with the "fail loudly" design invariant.

Exit codes:
  0 — written
  2 — bad input (not JSON, or missing args)
  5 — schema violation
"""

from __future__ import annotations
import sys
import json
from pathlib import Path

sys.path.insert(0, "/opt/shift-agent")
from schemas import LogEntry, _UnknownLogEntry  # noqa: E402
from safe_io import FileLock, ndjson_append  # noqa: E402
from exit_codes import EXIT_OK, EXIT_INVALID_INPUT, EXIT_SCHEMA_VIOLATION  # noqa: E402
from pydantic import TypeAdapter


LOG_PATH = Path("/opt/shift-agent/logs/decisions.log")
LOG_LOCK = Path("/opt/shift-agent/logs/decisions.log.lock")

_LOG_ENTRY_ADAPTER = TypeAdapter(LogEntry)


def main():
    if len(sys.argv) != 2:
        print("usage: log-decision-direct '<json-string>'", file=sys.stderr)
        return EXIT_INVALID_INPUT

    raw = sys.argv[1]
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError as e:
        print(f"ERROR: input is not valid JSON: {e}", file=sys.stderr)
        return EXIT_INVALID_INPUT

    try:
        entry = _LOG_ENTRY_ADAPTER.validate_python(parsed)
    except Exception as e:
        print(f"ERROR: entry does not match any LogEntry variant: {e}", file=sys.stderr)
        return EXIT_SCHEMA_VIOLATION

    # PR-D1 R5-HIGH-2: the forward-compat shim widens the union for READERS
    # (so old binaries can ingest rows from newer binaries during partial-
    # rollback windows) but writers must NEVER legitimately emit unknown
    # tags — that's what the schema-add PR is for. Reject _UnknownLogEntry
    # at the writer chokepoint so a typo'd `type` field is caught here
    # instead of silently landing in decisions.log.
    if isinstance(entry, _UnknownLogEntry):
        print(
            f"ERROR: refusing to write unrecognized type {entry.type!r}. "
            f"Writers must emit a known LogEntry variant; if this is a new "
            f"event, add the variant to schemas.py first.",
            file=sys.stderr,
        )
        return EXIT_SCHEMA_VIOLATION

    # Serialize back to compact single-line JSON via Pydantic (ensures canonical form)
    canonical = _LOG_ENTRY_ADAPTER.dump_json(entry).decode()

    with FileLock(LOG_LOCK):
        ndjson_append(LOG_PATH, canonical)

    print(f"logged ({len(canonical)}b) to {LOG_PATH}")
    return EXIT_OK


# Historical note: this script previously called _append_sha_chain() to write
# a SHA-256 chain file at /opt/shift-agent/logs/decisions.log.sha256 for
# "tamper-evidence." That chain was decoration — only ~3% of decisions.log
# entries went through this script (other writers in src/agents/*/scripts/
# called safe_io.ndjson_append directly), and there was never a verifier in
# the codebase. Removed 2026-04-28 (Option B per the audit-log-rotation
# review thread).
#
# If/when a real compliance need emerges for cryptographic tamper-evidence,
# the architecture is: move _append_sha_chain into safe_io.ndjson_append
# (the chokepoint every writer uses), add a verify-decisions-log script,
# add daily-cron verification, and run a one-time backfill for existing
# entries (with explicit "trust boundary" docs noting pre-backfill entries
# aren't cryptographically defensible). Total scope ~half-day. Logged in
# tasks/todo.md under "deferred until compliance need emerges."


if __name__ == "__main__":
    sys.exit(main())
