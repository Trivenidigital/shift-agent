#!/usr/bin/env python3
"""Extract dispatcher-replay fixtures from a decisions.log NDJSON file.

Pairs raw_inbound entries with their corresponding dispatcher_routed entries
(by message_id) and emits JSONL fixtures consumable by tests/_dispatcher_replay.py.

Run on a VPS where /opt/shift-agent/logs/decisions.log lives, OR locally against
a copy:

    extract-replay-fixtures \\
        --in /opt/shift-agent/logs/decisions.log \\
        --out tests/fixtures/dispatcher_traffic_real.jsonl \\
        --since 2026-05-01

The output schema matches the synthetic fixtures in tests/fixtures/dispatcher_traffic.jsonl.

Drift-check tag: extends-Hermes (reads NDJSON via the deployed audit-log convention).

Pairing logic: this script duplicates a slice of the pairing logic in
src/platform/scripts/dispatcher-accuracy-report (which also reads decisions.log
and pairs raw_inbound + dispatcher_routed by message_id). The duplication is
intentional in v0.1 because:
  1. dispatcher-accuracy-report is hyphen-named without a .py extension, so
     importing requires importlib + SourceFileLoader (the _b1_helpers.py
     pattern). Keeping a self-contained extractor avoids that complexity.
  2. The fixture-extraction case has different needs: stricter line-validation
     (corrupted lines = corrupted fixtures), PII redaction, fail-closed by
     default. The accuracy-report script silently skips bad lines (intentional
     for observability — see its load_entries docstring).
TODO: factor out a shared `src/platform/audit_pairing.py` helper that both
scripts import. Tracked in tasks/todo.md (P3 cleanup tier).

PII handling: extracted fixtures contain real phone numbers, names, and
WhatsApp IDs from production audit log. By default, all PII fields are
redacted to test-prefixed values. Pass --allow-pii to preserve real values
(use only for offline analysis; never commit real-PII fixtures to the repo).
Redaction is best-effort and can miss user-typed PII in unusual formats —
review extracted fixtures before commit (the summary surfaces residual-PII
warnings).

Caller contract for --strict mode (operator/CI must check exit code):

    extract-replay-fixtures --in /opt/.../decisions.log --out fixtures.jsonl --strict
    if [ $? -ne 0 ]; then
        echo "FATAL: fixture extraction failed strict mode" >&2
        exit 1
    fi

Or in Python: `subprocess.run([..., "--strict"], check=True)`. Without
exit-code checking, --strict is a latent safeguard with no actual
enforcement. Running without --strict warns to stderr + summary stdout
but exits 0 even on partial corruption.

Exit codes:
    0 = OK (or non-strict run with warnings)
    2 = input error (missing file, bad --since)
    3 = strict violation (malformed JSON lines, malformed timestamps,
        skipped pairs, or residual PII warnings)

Skipped pairs are written to <output>.skipped.jsonl alongside the main
fixture output for operator review (stderr WARN lines have the same
content but stderr is not always captured in deploy contexts).
"""
from __future__ import annotations

import argparse
import json
import re
import sys
from collections import defaultdict
from datetime import datetime, timezone
from pathlib import Path

# Exit codes
EXIT_OK = 0
EXIT_INPUT_ERROR = 2
EXIT_STRICT_VIOLATION = 3


def parse_iso_dt(s: str) -> datetime | None:
    if not s:
        return None
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00"))
    except (ValueError, TypeError):
        return None


def load_entries(path: Path, strict: bool = False) -> tuple[list[tuple[int, dict]], int, int]:
    """Yield parsed NDJSON entries from a decisions.log.

    Returns (entries, malformed_line_count, malformed_ts_count). When strict=True,
    raises on first malformed line; otherwise warns to stderr and continues.

    Read-while-append note: line-oriented JSONL with flock-protected appends in
    safe_io.ndjson_append is safe to read without coordination — the writer's
    fsync ordering ensures we see complete lines, and a torn write at the very
    tail manifests as a malformed line (counted, not silent).
    """
    entries: list[tuple[int, dict]] = []
    malformed_lines = 0
    malformed_ts = 0
    with path.open("r", encoding="utf-8") as fh:
        for line_num, line in enumerate(fh, 1):
            line = line.strip()
            if not line:
                continue
            try:
                e = json.loads(line)
            except json.JSONDecodeError as exc:
                malformed_lines += 1
                msg = f"line {line_num} malformed JSON: {exc}"
                if strict:
                    raise ValueError(msg) from exc
                print(f"WARN: {msg}", file=sys.stderr)
                continue
            entries.append((line_num, e))
    return entries, malformed_lines, malformed_ts


def pair_inbound_with_routing(entries):
    """Group entries by message_id; pair raw_inbound with routing decision.

    Mirrors dispatcher-accuracy-report's pair_inbounds() for the message_id
    case (we don't need the within-window fuzzy fallback for declines because
    fixture-extraction works fine on strict-id-pair matches only).

    Returns:
      paired: list of (raw_inbound_dict, routing_dict)
      unpaired_inbound_count: raw_inbounds with no routing partner
    """
    by_msg_id: dict[str, dict[str, dict]] = defaultdict(dict)
    inbound_total = 0
    for _, e in entries:
        t = e.get("type")
        if t == "raw_inbound":
            inbound_total += 1
        msg_id = e.get("message_id") or e.get("original_message_id")
        if not msg_id:
            continue
        if t in ("raw_inbound", "dispatcher_routed", "unknown_sender_declined"):
            by_msg_id[msg_id][t] = e
    pairs = []
    for _msg_id, types in by_msg_id.items():
        if "raw_inbound" not in types:
            continue
        if "dispatcher_routed" in types:
            pairs.append((types["raw_inbound"], types["dispatcher_routed"]))
        elif "unknown_sender_declined" in types:
            pairs.append((types["raw_inbound"], types["unknown_sender_declined"]))
    unpaired = inbound_total - len(pairs)
    return pairs, unpaired


# ──────────────────────────────────────────────────────────────────────────
# PII redaction
#
# Two-layer approach:
#   1. PRIMARY: substitute the EXACT structured-field values from sender_block
#      (phone, lid, chat_id) into raw_text. These are known-exact strings the
#      audit log captured, so substitution is precise.
#   2. SECONDARY (best-effort): scan post-substitution raw_text for residual
#      digit sequences that LOOK like phone numbers. We do NOT substitute these
#      (regex-based replacement was fragile — see prior review HIGH-1/M4 where
#      ISO timestamps and malformed inputs leaked through). Instead we surface
#      a residual-PII warning in the summary so a human curator reviews
#      before committing.
#
# **Operator contract:** real fixtures extracted by this tool MUST be
# reviewed by a human before commit, even with redaction ON. PII redaction
# is best-effort, not a security guarantee.
# ──────────────────────────────────────────────────────────────────────────

# Detects digit sequences ≥7 digits as a residual-PII warning signal.
# Designed to catch many phone formats: +1-555-555-1234, (555) 555-1234,
# 555.555.1234, 5551234567. We INTENTIONALLY use this only as a warning,
# never as a substitution — substitution-via-regex was the bug this fix
# replaces. ISO timestamps like 2026-05-01T12:34:56 contain ≥7 digits and
# will be flagged; that's expected (false-positive in warning, not in
# substitution behavior).
_RESIDUAL_DIGITS_RE = re.compile(r"\b\d[\d\s\-\.\(\)]{5,}\d\b")


def _synth_phone(idx: int) -> str:
    """Synthetic test-prefixed phone for fixture redaction.

    Wider index format (idx, not idx%100) avoids collision when extracting
    >100 fixtures.
    """
    return f"+15555{idx:06d}"


def _synth_lid(idx: int) -> str:
    return f"{1000000000000000 + idx}@lid"


def _synth_jid(idx: int) -> str:
    return f"15555{idx:06d}@s.whatsapp.net"


def _redact_text_from_structured_fields(
    text: str, sender_block: dict, idx: int
) -> tuple[str, int]:
    """Substitute exact phone/lid/chat_id values from sender_block into text.

    Returns (redacted_text, residual_digit_match_count). The residual count
    is non-zero when raw_text still contains digit sequences after
    substitution — typically because a USER typed their phone number into
    a message body (in any format). Caller surfaces this in the summary
    so curators know to manually review.
    """
    out = text
    real_phone = sender_block.get("phone")
    real_lid = sender_block.get("lid")
    real_jid = sender_block.get("chat_id")

    if real_phone:
        out = out.replace(real_phone, _synth_phone(idx))
        # Also substitute the variant without leading +.
        if real_phone.startswith("+"):
            out = out.replace(real_phone[1:], _synth_phone(idx)[1:])
    if real_lid:
        out = out.replace(real_lid, _synth_lid(idx))
    if real_jid:
        out = out.replace(real_jid, _synth_jid(idx))

    # Count residual digit sequences as a warning signal. Filter out matches
    # that are clearly the synthetic substitutions we just added.
    residuals = [
        m.group(0)
        for m in _RESIDUAL_DIGITS_RE.finditer(out)
        if not m.group(0).startswith("15555") and not m.group(0).startswith("+15555")
    ]
    return out, len(residuals)


def fixture_from_pair(
    raw_inbound: dict, routing: dict, idx: int, allow_pii: bool = False
) -> dict | None:
    """Build a fixture dict from a (raw_inbound, dispatcher_routed) pair.

    Returns None when required fields are missing — caller skips these with a
    logged reason rather than emitting a malformed fixture.

    Best-effort: state_files are not captured in the audit log, so they're
    left empty with a note. A human curator should fill them in for fixtures
    where the routing decision depends on state-file lookups (priority 1-5).

    PII redaction is applied unless allow_pii=True. Real production audit
    entries contain real customer/owner phone numbers, LIDs, JIDs, and
    free-form raw_text. Default-deny.
    """
    msg_id = raw_inbound.get("message_id") or raw_inbound.get("original_message_id", "")

    # Required fields — skip the pair (return None) rather than silently emit
    # a malformed fixture with empty defaults.
    expected_handler = (
        routing.get("routed_to")
        or routing.get("handler")
        or ("unknown_sender_declined" if routing.get("type") == "unknown_sender_declined" else None)
    )
    if not expected_handler:
        return None

    raw_text = raw_inbound.get("raw_text") or raw_inbound.get("body")
    if not raw_text:
        return None

    sender_role = raw_inbound.get("sender_role")
    if not sender_role:
        return None  # role is required by dispatcher contract; missing = corrupt entry

    # PII redaction
    sender_block_raw = raw_inbound.get("sender_block", {}) or {}
    residual_count = 0
    if not allow_pii:
        raw_text, residual_count = _redact_text_from_structured_fields(
            raw_text, sender_block_raw, idx
        )
        sender_block = {
            **sender_block_raw,
            "phone": _synth_phone(idx) if sender_block_raw.get("phone") else None,
            "lid": _synth_lid(idx) if sender_block_raw.get("lid") else None,
            "chat_id": _synth_jid(idx) if sender_block_raw.get("chat_id") else None,
        }
        sender_name = "RedactedName"
    else:
        sender_block = sender_block_raw
        sender_name = raw_inbound.get("sender_name")

    notes_parts = [
        "Auto-extracted from audit log; state_files + config are placeholders — review before committing.",
        f"PII {'PRESERVED (--allow-pii)' if allow_pii else 'redacted (best-effort).'}",
    ]
    if residual_count > 0:
        notes_parts.append(
            f"⚠ {residual_count} residual digit sequence(s) detected in raw_text after redaction "
            f"(may be user-typed phone/PII in unusual format) — manually review before commit."
        )

    return {
        "id": f"real-{idx:06d}-{msg_id[:8]}",
        "category": "real-traffic",
        "description": f"Captured from production audit log at {raw_inbound.get('ts', '')}",
        "source_row": "production",
        "input": {
            "raw_text": raw_text,
            "sender_block": sender_block,
            "identity": {
                "role": sender_role,
                "name": sender_name,
                "employee_id": raw_inbound.get("employee_id"),
            },
            "media_type": raw_inbound.get("media_type"),
            # State files NOT captured in audit log — curator must fill in if priority 1-5
            "state_files": {
                "catering-menu-pending.json": [],
                "catering-leads.json": [],
                "pending.json": [],
                "expense_leads.json": [],
            },
            "config": {},
            "_audit_timestamp": raw_inbound.get("ts"),
            "_message_id": msg_id,
            "_residual_pii_warnings": residual_count,
        },
        "expected_handler": expected_handler,
        "notes": " ".join(notes_parts),
    }


def main():
    p = argparse.ArgumentParser(description=__doc__)
    p.add_argument("--in", dest="input_path", required=True, type=Path,
                   help="Path to decisions.log (NDJSON)")
    p.add_argument("--out", dest="output_path", required=True, type=Path,
                   help="Path to write fixtures JSONL")
    p.add_argument("--since", type=str, default=None,
                   help="ISO date (YYYY-MM-DD) — skip entries before this")
    p.add_argument("--limit", type=int, default=None,
                   help="Max number of fixtures to emit")
    p.add_argument("--strict", action="store_true",
                   help="Fail-closed on any malformed JSON line; otherwise warn+continue")
    p.add_argument("--allow-pii", action="store_true",
                   help="Preserve real PII in extracted fixtures (default: redact). "
                        "DO NOT commit --allow-pii output to the repo.")
    args = p.parse_args()

    if not args.input_path.exists():
        print(f"ERROR: input file not found: {args.input_path}", file=sys.stderr)
        sys.exit(EXIT_INPUT_ERROR)

    since_dt = parse_iso_dt(args.since) if args.since else None
    if args.since and since_dt is None:
        print(f"ERROR: --since {args.since!r} is not a valid ISO date", file=sys.stderr)
        sys.exit(EXIT_INPUT_ERROR)

    try:
        entries, malformed_lines, _ = load_entries(args.input_path, strict=args.strict)
    except ValueError as e:
        print(f"ERROR (strict): {e}", file=sys.stderr)
        sys.exit(EXIT_STRICT_VIOLATION)

    # Always count malformed timestamps regardless of --since (so the summary
    # is honest even when no time filter is in effect).
    malformed_ts = 0
    filtered = []
    for n, e in entries:
        ts_raw = e.get("ts", "")
        if not ts_raw:
            # No timestamp at all — count and keep (entry may still be valid; some
            # types have ts in different fields). If --since is set, skip.
            if since_dt:
                continue
            filtered.append((n, e))
            continue
        ts = parse_iso_dt(ts_raw)
        if ts is None:
            malformed_ts += 1
            if since_dt:
                continue  # skip unparseable-ts entries when --since active
            filtered.append((n, e))  # keep for non-filter case (count surfaces in summary)
            continue
        if since_dt and ts < since_dt:
            continue
        filtered.append((n, e))
    entries = filtered

    pairs, unpaired_inbounds = pair_inbound_with_routing(entries)
    if args.limit:
        pairs = pairs[: args.limit]

    # Build fixtures, skipping any with missing required fields. Skipped pairs
    # are written to a sidecar .skipped.jsonl so operators don't need stderr
    # access to see what was dropped.
    args.output_path.parent.mkdir(parents=True, exist_ok=True)
    skipped_path = args.output_path.with_suffix(args.output_path.suffix + ".skipped.jsonl")
    written = 0
    skipped_missing_fields = 0
    total_residual_pii_warnings = 0
    with args.output_path.open("w", encoding="utf-8") as fh, \
         skipped_path.open("w", encoding="utf-8") as sfh:
        for idx, (raw, routing) in enumerate(pairs, 1):
            fixture = fixture_from_pair(raw, routing, idx, allow_pii=args.allow_pii)
            if fixture is None:
                skipped_missing_fields += 1
                skip_record = {
                    "idx": idx,
                    "message_id": raw.get("message_id", "?"),
                    "ts": raw.get("ts"),
                    "reason": "missing required field (raw_text/sender_role/expected_handler)",
                    "raw_inbound_keys": sorted(raw.keys()),
                    "routing_type": routing.get("type"),
                }
                sfh.write(json.dumps(skip_record, ensure_ascii=False) + "\n")
                print(
                    f"WARN: skipped pair idx={idx} msg_id={raw.get('message_id', '?')[:12]} "
                    f"— missing required field (raw_text/sender_role/expected_handler); "
                    f"see {skipped_path.name}",
                    file=sys.stderr,
                )
                continue
            total_residual_pii_warnings += fixture["input"].get("_residual_pii_warnings", 0)
            fh.write(json.dumps(fixture, ensure_ascii=False) + "\n")
            written += 1

    # Summary report (stdout — visible regardless of stderr handling).
    print(f"Wrote {written} fixtures to {args.output_path}")
    print(f"  Skipped pairs detail:            {skipped_path}")
    print(f"  Total entries scanned:           {len(entries)}")
    print(f"  Pairs found:                     {len(pairs)}")
    print(f"  Unpaired raw_inbound (no route): {unpaired_inbounds}")
    print(f"  Skipped (missing required field): {skipped_missing_fields}")
    print(f"  Malformed JSON lines:            {malformed_lines}")
    print(f"  Malformed timestamp lines:       {malformed_ts}")
    print(f"  PII redaction:                   {'OFF (--allow-pii)' if args.allow_pii else 'ON (default)'}")
    if total_residual_pii_warnings:
        print(
            f"  ⚠ Residual digit sequences in {total_residual_pii_warnings} fixture raw_text(s) — "
            f"MANUAL REVIEW REQUIRED before committing extracted fixtures."
        )
    if not pairs:
        print("  (No raw_inbound + dispatcher_routed pairs found. "
              "If production traffic is empty or audit-log rotation truncated history, "
              "this is expected — supplement with synthetic fixtures.)")

    # Strict mode: fail-closed if any malformed lines slipped through (--strict
    # already raised earlier; this catches malformed_ts + skipped_missing_fields
    # + residual PII warnings).
    if args.strict and (
        malformed_lines or malformed_ts or skipped_missing_fields or total_residual_pii_warnings
    ):
        print(
            f"STRICT VIOLATION: malformed_lines={malformed_lines} "
            f"malformed_ts={malformed_ts} skipped_missing={skipped_missing_fields} "
            f"residual_pii_warnings={total_residual_pii_warnings}",
            file=sys.stderr,
        )
        sys.exit(EXIT_STRICT_VIOLATION)


if __name__ == "__main__":
    main()
