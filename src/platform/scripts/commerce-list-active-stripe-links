#!/usr/bin/env python3
"""commerce-list-active-stripe-links — operator helper for slice-3 rollback.

Lists CommercePaymentIntent rows where status is in {minted, sent} (i.e.,
the customer has been sent a payment link but hasn't completed payment yet).
Used by the slice-3 runbook for cfg.commerce.provider flip-back: in-flight
Stripe Payment Links remain live unless the operator deactivates them in
the Stripe dashboard.

Usage:
  commerce-list-active-stripe-links                 # human-readable table
  commerce-list-active-stripe-links --format json   # machine-readable
  commerce-list-active-stripe-links --only-stripe   # exclude placeholder
"""
from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

sys.path.insert(0, "/opt/shift-agent")
_THIS = Path(__file__).resolve()
_REPO_ROOT = _THIS.parent.parent.parent.parent
sys.path.insert(0, str(_REPO_ROOT / "src" / "platform"))

from commerce import payment_link as commerce_payment_link  # noqa: E402


COMMERCE_INTENTS_PATH = Path(os.environ.get(
    "COMMERCE_INTENTS_PATH", "/opt/shift-agent/state/commerce/payment_intents.json",
))


_ACTIVE_STATUSES = {"minted", "sent"}


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--format", choices=["table", "json"], default="table")
    ap.add_argument(
        "--only-stripe", action="store_true",
        help="Exclude placeholder/other-provider intents (filter to provider='stripe')",
    )
    args = ap.parse_args()

    store = commerce_payment_link.load_intent_store(COMMERCE_INTENTS_PATH)
    active = [i for i in store.intents if i.status in _ACTIVE_STATUSES]
    if args.only_stripe:
        active = [i for i in active if i.provider == "stripe"]

    if args.format == "json":
        out = [
            {
                "intent_id": i.intent_id,
                "order_id": i.order_id,
                "provider": i.provider,
                "status": i.status,
                "amount_cents": i.amount_cents,
                "currency": i.currency,
                "checkout_url": i.checkout_url,
                "created_at": i.created_at.isoformat(),
                "updated_at": i.updated_at.isoformat(),
            }
            for i in active
        ]
        print(json.dumps(out, indent=2))
        return 0

    # Table format
    if not active:
        print("(no active commerce payment intents)")
        return 0

    print(f"{'INTENT':12} {'ORDER':10} {'PROVIDER':12} {'STATUS':10} {'AMOUNT':>12} {'URL':50}")
    print("-" * 110)
    for i in active:
        amount_str = f"${i.amount_cents / 100:.2f} {i.currency}"
        url_short = i.checkout_url[:50] if i.checkout_url else "(none)"
        print(f"{i.intent_id:12} {i.order_id:10} {i.provider:12} {i.status:10} {amount_str:>12} {url_short:50}")
    print(f"\nTotal: {len(active)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
