#!/usr/bin/env python3
"""
identify-sender — resolve a WhatsApp phone/JID to a role (employee/owner/unknown).

Usage:
  identify-sender +19045550101
  identify-sender 19045550101@s.whatsapp.net
  identify-sender --json +19045550101

Output (JSON to stdout):
  {"role": "employee", "employee_id": "e001", "name": "Ravi Kumar", "phone_normalized": "+19045550101"}
  {"role": "owner", "name": "Sally Patel", "phone_normalized": "+19045550100"}
  {"role": "unknown", "phone_normalized": "+19045559999"}

Exit codes:
  0 — resolved (even if unknown; the JSON indicates role)
  2 — state-file-load-failure (roster/config could not be loaded); caller should trigger dead-man
  5 — Pydantic schema violation in config/roster
"""

from __future__ import annotations
import argparse
import json
import os
import re
import sys
from pathlib import Path

sys.path.insert(0, "/opt/shift-agent")
from safe_io import load_model, validate_phone_input  # noqa: E402
from schemas import Config, Roster, E164Phone  # noqa: E402
from exit_codes import EXIT_OK, EXIT_INVALID_INPUT, EXIT_SCHEMA_VIOLATION  # noqa: E402
import yaml


# BEGIN shift-agent-sender-id (env-overridable so tests can run on temp fixtures)
CONFIG_PATH = Path(os.environ.get("SHIFT_AGENT_CONFIG_PATH", "/opt/shift-agent/config.yaml"))
ROSTER_PATH = Path(os.environ.get("SHIFT_AGENT_ROSTER_PATH", "/opt/shift-agent/roster.json"))

_LID_RE = re.compile(r"^\d{6,20}@lid$")
_PHONE_JID_RE = re.compile(r"^\d{6,20}@s\.whatsapp\.net$")
_E164_RE = re.compile(r"^\+\d{10,15}$")


def _classify_input(raw: str) -> tuple[str, str]:
    """Strict input dispatch — never coincidentally treat a LID as a phone.
    Returns (kind, normalized) where kind in {phone, lid, invalid}."""
    raw = (raw or "").strip()
    if _LID_RE.match(raw):
        return "lid", raw
    if _PHONE_JID_RE.match(raw):
        return "phone", "+" + raw.split("@")[0]
    if _E164_RE.match(raw):
        return "phone", raw
    return "invalid", raw
# END shift-agent-sender-id


def _emit_employee(emp, *, phone=None, lid=None) -> int:
    out = {
        "role": "employee",
        "employee_id": emp.id,
        "name": emp.name,
        "phone_normalized": phone if phone is not None else emp.phone,
        "primary_role": emp.role,
        "languages": emp.languages,
        "can_cover_roles": sorted(emp.can_cover_roles),
        # BEGIN shift-agent-sender-id
        "lid": lid if lid is not None else emp.lid,
        # END shift-agent-sender-id
    }
    print(json.dumps(out))
    return EXIT_OK


def _emit_owner(owner, *, phone=None, lid=None) -> int:
    out = {
        "role": "owner",
        "name": owner.name,
        "phone_normalized": phone if phone is not None else owner.phone,
        # BEGIN shift-agent-sender-id
        "lid": lid if lid is not None else owner.lid,
        # END shift-agent-sender-id
    }
    print(json.dumps(out))
    return EXIT_OK


def _emit_unknown(*, phone=None, lid=None) -> int:
    out = {
        "role": "unknown",
        "phone_normalized": phone,
        # BEGIN shift-agent-sender-id
        "lid": lid,
        # END shift-agent-sender-id
    }
    print(json.dumps(out))
    return EXIT_OK


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("input", help="phone (+E.164), LID (<digits>@lid), or phone-JID (<digits>@s.whatsapp.net)")
    ap.add_argument("--json", action="store_true", default=True, help="JSON output (default)")
    args = ap.parse_args()

    # BEGIN shift-agent-sender-id (strict classifier — phone vs lid vs invalid)
    kind, normalized = _classify_input(args.input)
    if kind == "invalid":
        # Fall back: legacy E164Phone canonicalization handles formatted
        # phones like `+1-904-555-0101`. validate_phone_input rejects shell
        # injection first.
        try:
            validate_phone_input(args.input)
            canonical = E164Phone.from_any(args.input)
        except ValueError as e:
            print(json.dumps({"role": "error", "error": str(e)}))
            return EXIT_INVALID_INPUT
        except Exception as e:
            print(json.dumps({"role": "error", "error": f"phone parse: {e}"}))
            return EXIT_INVALID_INPUT
        if not _E164_RE.match(canonical):
            print(json.dumps({"role": "error", "error": f"refusing input: {args.input!r}"}))
            return EXIT_INVALID_INPUT
        kind = "phone"
        normalized = canonical
    # END shift-agent-sender-id

    # Load config
    try:
        with CONFIG_PATH.open() as f:
            raw = yaml.safe_load(f)
        cfg = Config.model_validate(raw)
    except Exception as e:
        print(json.dumps({"role": "error", "error": f"config_load: {e}"}), file=sys.stdout)
        return EXIT_SCHEMA_VIOLATION

    # Load roster
    try:
        roster, status = load_model(ROSTER_PATH, Roster)
    except Exception as e:
        print(json.dumps({"role": "error", "error": f"roster_load: {e}"}))
        return EXIT_SCHEMA_VIOLATION
    if status != "ok":
        print(json.dumps({"role": "error", "error": f"roster_load_failed: {status}"}))
        return EXIT_INVALID_INPUT

    # BEGIN shift-agent-sender-id (LID branch)
    if kind == "lid":
        for e in roster.employees:
            if e.lid == normalized:
                return _emit_employee(e, lid=normalized)
        if cfg.owner.lid == normalized:
            return _emit_owner(cfg.owner, lid=normalized)
        return _emit_unknown(lid=normalized)
    # END shift-agent-sender-id

    # kind == "phone": preserved legacy behavior + populate lid in output
    canonical = normalized
    if canonical == cfg.owner.phone:
        return _emit_owner(cfg.owner, phone=canonical, lid=cfg.owner.lid)

    emp = roster.find_by_phone(canonical)
    if emp:
        return _emit_employee(emp, phone=canonical, lid=emp.lid)

    return _emit_unknown(phone=canonical)


if __name__ == "__main__":
    sys.exit(main())
