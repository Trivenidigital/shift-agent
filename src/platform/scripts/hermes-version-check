#!/usr/bin/env python3
"""
hermes-version-check — read-only Hermes version monitor (Track A durability).

Runs from a daily systemd timer as User=shift-agent. It is STRICTLY READ-ONLY:
it never updates Hermes, restarts the gateway, rewrites the baseline, installs
skills, enables auto-update, runs patch-hermes.py, or clones/fetches/checks-out
upstream. Its only writes are its own private report + state files under
/opt/shift-agent/ and (on alert) a subprocess call to shift-agent-notify-owner.

What it checks (every run):
  LOCAL (network-free, always):
    - live Hermes commit (git rev-parse HEAD, read-only) vs pinned baseline
    - live bridge.js sha256 vs pinned baseline
    - shift-agent patch markers present in run.py / whatsapp.py / bridge.js
    - baseline file readable
  UPSTREAM (best-effort, fail-safe; skip with --skip-upstream):
    - git ls-remote of the upstream Hermes repo (NO clone, NO fetch, NO
      patch-hermes dry-run — that heavy detection stays in the weekly CI
      workflow .github/workflows/hermes-drift-check.yml). Reports whether
      upstream is ahead of the pin → an *advisory* "patch-port review required"
      flag only. Any network/git error → upstream_status=unknown (never raises,
      never alarms beyond a throttled soft alert).

Alerts are notify-on-change (signature throttle) routed through the existing
shift-agent-notify-owner chokepoint. Monitor-process crashes are caught by the
systemd OnFailure handler (hermes-version-check-failure.service).

Exit codes:
  0 — monitor ran and wrote its report (drift is *reported*, not an error exit)
  6 — the monitor itself failed (could not write report/state, or unhandled
      exception) → systemd OnFailure fires the failure-notify service.
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path

# ── defaults (production paths; all overridable via CLI for tests) ───────────
DEFAULT_HERMES_HOME = "/root/.hermes/hermes-agent"
DEFAULT_BASELINE = "/opt/shift-agent/hermes-patch-baseline.txt"
DEFAULT_REPORT = "/opt/shift-agent/logs/hermes-version-report.json"
DEFAULT_STATE = "/opt/shift-agent/state/hermes-version-monitor.json"
DEFAULT_LOG = "/opt/shift-agent/logs/decisions.log"  # informational; monitor does not write it
DEFAULT_UPSTREAM = "https://github.com/NousResearch/hermes-agent.git"
DEFAULT_NOTIFY_BIN = "/usr/local/bin/shift-agent-notify-owner"
DEFAULT_UPSTREAM_TIMEOUT = 10
DEFAULT_NETWORK_FAIL_ALERT_AFTER = 3

EXIT_OK = 0
EXIT_MONITOR_FAILED = 6

# Marker the shift-agent patches inject into the 3 Hermes files (read-only grep).
PATCH_MARKER = "BEGIN shift-agent-sender-id"
MARKER_FILES = (
    ("gateway", "run.py"),
    ("gateway", "platforms", "whatsapp.py"),
    ("scripts", "whatsapp-bridge", "bridge.js"),
)
BRIDGE_REL = ("scripts", "whatsapp-bridge", "bridge.js")

HARD_CONDITIONS = frozenset({
    "runtime_commit_drift", "bridge_sha_drift", "bridge_missing",
    "patch_markers_missing", "baseline_unreadable", "hermes_home_unreadable",
    "unsafe_permissions",
})
# Report/state write failure is handled out-of-band (exit 6 → systemd OnFailure),
# not as a flowed condition, so it is deliberately NOT in HARD_CONDITIONS.
SOFT_CONDITIONS = frozenset({
    "upstream_ahead", "patch_port_review_required", "upstream_check_failed",
})


# ════════════════════════════════════════════════════════════════════════════
# Pure helpers (no I/O side effects) — unit-tested in-process
# ════════════════════════════════════════════════════════════════════════════

def read_baseline(path) -> dict | None:
    """Read the pinned baseline KEY=VALUE file. Returns
    {"commit","version","bridge_sha256"} or None if missing/unreadable/no commit.

    Mirrors tools/check-shift-agent-patch.sh _read_pin: tolerates CRLF and
    surrounding single/double quotes (so a quoted baseline value does not
    false-compare against a raw `git rev-parse` commit).
    """
    try:
        text = Path(path).read_text(encoding="utf-8", errors="replace")
    except OSError:
        return None

    def _read(key: str) -> str | None:
        for raw in text.splitlines():
            line = raw.strip()
            if line.startswith("#") or "=" not in line:
                continue
            k, _, v = line.partition("=")
            if k.strip() != key:
                continue
            v = v.strip()
            if len(v) >= 2 and v[0] == v[-1] and v[0] in ("'", '"'):
                v = v[1:-1]
            return v
        return None

    commit = _read("HERMES_COMMIT")
    if not commit:
        return None
    return {
        "commit": commit,
        "version": _read("HERMES_VERSION") or "",
        "bridge_sha256": _read("BRIDGE_POST_PATCH_SHA256") or "",
    }


def alert_signature(active) -> str:
    """Stable signature of the active-condition set (order-independent).
    Empty set → "" so 'no conditions' is distinguishable from any real set."""
    items = sorted(set(active or []))
    if not items:
        return ""
    return hashlib.sha256(",".join(items).encode("utf-8")).hexdigest()


def decide_alert(active, hard, soft, prev_state, *, now, network_fail_after) -> dict:
    """Notify-on-change decision (pure). Returns
    {action, reason, priority, notify, signature}.

    TWO INDEPENDENT CHANNELS so a transient network blip can never re-page a
    persistent hard/advisory condition (and a co-present hard condition can never
    defeat the network threshold):

    - STABLE channel = hard conditions + non-network advisories
      (upstream_ahead / patch_port_review_required). Notify-on-change by the
      signature of THIS set only — `upstream_check_failed` is EXCLUDED from the
      signature. Priority 1 if any hard condition is present, else 0.
    - NETWORK channel = `upstream_check_failed`. Count-throttled: page exactly on
      the run where the effective consecutive-failure count first reaches
      `network_fail_after`; recovery when it clears after having paged.

    `signature` returned is always the STABLE signature (what callers persist).
    """
    prev = prev_state or {}
    prev_sig = prev.get("last_alert_signature") or ""
    consec = int(prev.get("consecutive_network_failures") or 0)
    active = list(active or [])
    soft = list(soft or [])

    network_failed = "upstream_check_failed" in soft
    stable = sorted(c for c in active if c != "upstream_check_failed")
    stable_hard = [c for c in stable if c in HARD_CONDITIONS]
    sig = alert_signature(stable)
    stable_changed = sig != prev_sig

    effective = consec + 1 if network_failed else 0
    network_page = network_failed and effective == network_fail_after
    network_recovered = (not network_failed) and consec >= network_fail_after

    if stable and stable_changed:
        kind = "new hard condition(s): " if stable_hard else "new advisory: "
        return {"action": "sent", "reason": kind + ",".join(stable),
                "priority": 1 if stable_hard else 0, "notify": True, "signature": sig}
    if not stable and prev_sig:
        cleared = ",".join(prev.get("active_conditions") or []) or "(monitored conditions)"
        return {"action": "recovery", "reason": f"cleared: {cleared}",
                "priority": 0, "notify": True, "signature": sig}
    if network_page:
        return {"action": "sent",
                "reason": f"upstream unreachable for {effective} consecutive runs",
                "priority": 0, "notify": True, "signature": sig}
    if network_recovered:
        return {"action": "recovery", "reason": "upstream reachable again",
                "priority": 0, "notify": True, "signature": sig}
    if stable or network_failed:
        return {"action": "suppressed", "reason": "no change since last alert",
                "priority": 1 if stable_hard else 0, "notify": False, "signature": sig}
    return {"action": "not_needed", "reason": "no conditions",
            "priority": 0, "notify": False, "signature": sig}


# ════════════════════════════════════════════════════════════════════════════
# Local runtime reads (READ-ONLY: git rev-parse / sha256 / file grep). No write,
# no fetch, no checkout, no systemctl — ever.
# ════════════════════════════════════════════════════════════════════════════

def resolve_hermes_home(path):
    """Resolve symlinks (e.g. /root/.hermes/hermes-agent → /usr/local/lib/...),
    mirroring tools/check-shift-agent-patch.sh:67 so a shift-agent-readable real
    path is used."""
    try:
        return Path(os.path.realpath(str(path)))
    except OSError:
        return Path(str(path))


def live_commit(home):
    """`git rev-parse HEAD` of the live Hermes checkout (read-only). Returns the
    commit hash or None on any error. `safe.directory` set inline so a root-owned
    checkout is readable when running as shift-agent (gate precedent)."""
    home = str(home)
    try:
        r = subprocess.run(
            ["git", "-c", f"safe.directory={home}", "-C", home, "rev-parse", "HEAD"],
            capture_output=True, text=True, timeout=15,
        )
    except Exception:
        return None
    if r.returncode != 0:
        return None
    return r.stdout.strip() or None


def bridge_sha(home):
    """sha256 of the live bridge.js, or None if absent/unreadable."""
    p = Path(home).joinpath(*BRIDGE_REL)
    try:
        data = p.read_bytes()
    except OSError:
        return None
    return hashlib.sha256(data).hexdigest()


def markers_present(home):
    """True iff all 3 patched files exist and contain the shift-agent marker;
    False if a readable file lacks the marker; None if any file is unreadable
    (→ 'unknown', not a false 'missing')."""
    home = Path(home)
    for parts in MARKER_FILES:
        try:
            text = home.joinpath(*parts).read_text(encoding="utf-8", errors="replace")
        except OSError:
            return None
        if PATCH_MARKER not in text:
            return False
    return True


def gather_local(home, baseline):
    """Read live runtime state and compare to the pinned baseline. Pure reads;
    never mutates `home`. `baseline` is the dict from read_baseline() or None."""
    home = resolve_hermes_home(home)
    commit = live_commit(home)
    sha = bridge_sha(home)
    markers = markers_present(home)
    result = {
        "runtime": {"commit": commit or "", "bridge_sha256": sha or "", "markers_ok": markers is True},
        "conditions": [],
    }

    # runtime commit
    if commit is None:
        result["runtime_status"] = "unreadable"
        result["conditions"].append("hermes_home_unreadable")
    elif baseline and commit == baseline.get("commit"):
        result["runtime_status"] = "match"
    elif baseline:
        result["runtime_status"] = "drift"
        result["conditions"].append("runtime_commit_drift")
    else:
        result["runtime_status"] = "unknown"  # no baseline to compare against

    # bridge.js sha
    if sha is None:
        result["bridge_status"] = "missing"
        result["conditions"].append("bridge_missing")
    elif baseline and sha == baseline.get("bridge_sha256"):
        result["bridge_status"] = "match"
    elif baseline:
        result["bridge_status"] = "drift"
        result["conditions"].append("bridge_sha_drift")
    else:
        result["bridge_status"] = "unknown"

    # patch markers
    if markers is None:
        result["patch_markers_status"] = "unknown"
    elif markers:
        result["patch_markers_status"] = "present"
    else:
        result["patch_markers_status"] = "missing"
        result["conditions"].append("patch_markers_missing")

    return result


# ════════════════════════════════════════════════════════════════════════════
# Best-effort upstream check — `git ls-remote` ONLY. No clone, no fetch, no
# checkout, no patch-hermes dry-run (that heavy detection lives in the weekly CI
# workflow). Any error → status="unknown" (never raises, never alarms loudly).
# ════════════════════════════════════════════════════════════════════════════

def _highest_tag(tags):
    """Pick the highest semver-ish tag (strip leading 'v'); '' if none."""
    def key(t):
        nums = []
        for part in t.lstrip("vV").replace("-", ".").split("."):
            nums.append(int(part) if part.isdigit() else -1)
        return nums
    real = [t for t in tags if any(ch.isdigit() for ch in t)]
    if not real:
        return tags[0] if tags else ""
    return sorted(real, key=key)[-1]


def upstream_check(repo, *, timeout, pinned_commit, pinned_version):
    """Read upstream HEAD + tags via `git ls-remote` (read-only network). Returns
    {status, head_commit, latest_tag, reachable, ahead}. status:
      ok      — reachable, upstream HEAD == pinned commit
      ahead   — reachable, upstream HEAD != pinned commit
      unknown — unreachable / git error / timeout (fail-safe)
    """
    result = {"status": "unknown", "head_commit": "", "latest_tag": "",
              "reachable": False, "ahead": False}
    try:
        r = subprocess.run(
            ["git", "ls-remote", str(repo), "HEAD", "refs/tags/*"],
            capture_output=True, text=True, timeout=timeout,
        )
    except Exception:
        return result
    if r.returncode != 0:
        return result

    result["reachable"] = True
    head = ""
    tags = []
    for line in r.stdout.splitlines():
        if "\t" not in line:
            continue
        sha, ref = line.split("\t", 1)
        sha, ref = sha.strip(), ref.strip()
        if ref == "HEAD":
            head = sha
        elif ref.startswith("refs/tags/") and not ref.endswith("^{}"):
            tags.append(ref[len("refs/tags/"):])

    result["head_commit"] = head
    result["latest_tag"] = _highest_tag(tags)
    result["ahead"] = bool(head) and head != pinned_commit
    result["status"] = "ahead" if result["ahead"] else "ok"
    return result


# ════════════════════════════════════════════════════════════════════════════
# Evaluation brain (no notify I/O) — assembles the report + alert decision +
# next state from local reads + the upstream result. Read-only.
# ════════════════════════════════════════════════════════════════════════════

def evaluate(home, baseline, upstream, prev_state, *, now, network_fail_after,
             skip_upstream, extra_conditions=None):
    """Pure-ish: performs read-only local reads (git rev-parse / sha256 / grep)
    and assembles (report, decision, new_state). Never writes, never dispatches
    an alert. `upstream` is the upstream_check() result (ignored if
    skip_upstream). `extra_conditions` lets main() inject pre-computed hard
    conditions (e.g. unsafe_permissions)."""
    prev_state = prev_state or {}
    conditions = list(extra_conditions or [])

    if baseline is None:
        baseline_status = "unreadable"
        conditions.append("baseline_unreadable")
        local = {
            "runtime_status": "unknown", "bridge_status": "unknown",
            "patch_markers_status": "unknown",
            "runtime": {"commit": "", "bridge_sha256": "", "markers_ok": False},
            "conditions": [],
        }
    else:
        baseline_status = "ok"
        local = gather_local(home, baseline)
        conditions.extend(local["conditions"])

    up = {"head_commit": "", "latest_tag": "", "reachable": False}
    prev_consec = int(prev_state.get("consecutive_network_failures") or 0)
    if skip_upstream:
        upstream_status, upstream_ahead, patch_port = "skipped", False, "not_required"
        consec = prev_consec
    else:
        up = upstream or up
        status = up.get("status", "unknown")
        if status == "unknown":
            upstream_status, upstream_ahead, patch_port = "unknown", False, "not_required"
            conditions.append("upstream_check_failed")
            consec = prev_consec + 1
        elif status == "ahead":
            upstream_status, upstream_ahead, patch_port = "ahead", True, "required"
            conditions.append("upstream_ahead")
            conditions.append("patch_port_review_required")
            consec = 0
        else:  # ok
            upstream_status, upstream_ahead, patch_port = "ok", False, "not_required"
            consec = 0

    hard = [c for c in conditions if c in HARD_CONDITIONS]
    soft = [c for c in conditions if c in SOFT_CONDITIONS]
    decision = decide_alert(conditions, hard, soft, prev_state,
                            now=now, network_fail_after=network_fail_after)

    report = {
        "schema_version": 1,
        "generated_at": now.isoformat(),
        "runtime_status": local["runtime_status"],
        "baseline_status": baseline_status,
        "bridge_status": local["bridge_status"],
        "patch_markers_status": local["patch_markers_status"],
        "upstream_status": upstream_status,
        "upstream_ahead": upstream_ahead,
        "patch_port_review": patch_port,
        "pinned": {
            "commit": (baseline or {}).get("commit", ""),
            "version": (baseline or {}).get("version", ""),
            "bridge_sha256": (baseline or {}).get("bridge_sha256", ""),
        },
        "runtime": local["runtime"],
        "upstream": {
            "head_commit": up.get("head_commit", ""),
            "latest_tag": up.get("latest_tag", ""),
            "reachable": up.get("reachable", False),
        },
        "active_conditions": sorted(conditions),
        "alert_action": decision["action"],
        "alert_reason": decision["reason"],
        "alert_delivered": None,  # set by main() after dispatch (None when no alert)
        "consecutive_network_failures": consec,
        "mutation_performed": False,
        "note": "Patch-port validation is delegated to .github/workflows/hermes-drift-check.yml (weekly CI).",
    }

    # Alert-throttle fields (last_alert_signature / last_notified_at) are carried
    # forward unchanged here; main() advances them ONLY after a successful
    # delivery, so a failed page is retried next run instead of silently
    # suppressed. Observability fields update every run.
    new_state = {
        "schema_version": 1,
        "last_alert_signature": prev_state.get("last_alert_signature", ""),
        "active_conditions": sorted(conditions),
        "last_notified_at": prev_state.get("last_notified_at", ""),
        "last_successful_run_at": now.isoformat(),
        "consecutive_network_failures": consec,
        "last_upstream_head_seen": up.get("head_commit", "") or prev_state.get("last_upstream_head_seen", ""),
        "last_runtime_commit_seen": local["runtime"]["commit"],
        "last_bridge_sha256_seen": local["runtime"]["bridge_sha256"],
    }
    return report, decision, new_state


# ════════════════════════════════════════════════════════════════════════════
# I/O helpers (writes confined to the monitor's own report + state files)
# ════════════════════════════════════════════════════════════════════════════

def _load_state(path):
    try:
        return json.loads(Path(path).read_text(encoding="utf-8"))
    except (OSError, ValueError):
        return {}


def _atomic_write_json_pair(specs):
    """Write several JSON files as a near-atomic unit. `specs` is a list of
    (path, obj, mode). ALL temps are staged + fsync'd first; only then are they
    `os.replace`d in list order. If ANY serialization fails, nothing is replaced
    (no half-written pair). Callers put the report FIRST and the state LAST so a
    mid-replace failure on the report leaves the state untouched.

    Single-writer private files (only this daily timer writes them) → no flock."""
    staged = []  # [(tmp_path, final_path), ...] still needing cleanup
    try:
        for path, obj, mode in specs:
            path = Path(path)
            path.parent.mkdir(parents=True, exist_ok=True)
            fd, tmp = tempfile.mkstemp(dir=str(path.parent), prefix=path.name + ".", suffix=".tmp")
            with os.fdopen(fd, "w", encoding="utf-8") as f:
                json.dump(obj, f, indent=2, sort_keys=True)
                f.flush()
                os.fsync(f.fileno())
            try:
                os.chmod(tmp, mode)
            except OSError:
                pass
            staged.append((tmp, str(path)))
        for tmp, final in list(staged):
            os.replace(tmp, final)        # may raise (e.g. target is a directory)
            staged.remove((tmp, final))
    finally:
        for tmp, _ in staged:
            try:
                os.unlink(tmp)
            except OSError:
                pass


def _check_permissions(paths):
    """POSIX: flag world-writable state/report files (or their parent dir) as a
    hard 'unsafe_permissions' condition. No-op on non-POSIX."""
    if os.name != "posix":
        return []
    for p in paths:
        p = Path(p)
        target = p if p.exists() else p.parent
        try:
            mode = target.stat().st_mode
        except OSError:
            continue
        if mode & 0o002:  # world-writable
            return ["unsafe_permissions"]
    return []


def dispatch_alert(notify_bin, title, priority, message):
    """Invoke shift-agent-notify-owner (Pushover→WhatsApp). Returns (ok, detail).
    Never raises — alert delivery failure must not crash the monitor."""
    cmd = [str(notify_bin), "--title", title, "--priority", str(priority), message]
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        return r.returncode == 0, f"rc={r.returncode}"
    except Exception as e:  # noqa: BLE001 — best-effort delivery
        return False, f"notify_error:{e}"


def _alert_text(report, decision):
    """Plain-text (parse_mode-safe) title + body for the operator alert."""
    action = decision["action"]
    conds = ",".join(report["active_conditions"]) or "(none)"
    if action == "recovery":
        return ("Hermes version monitor: recovered",
                "All monitored Hermes conditions cleared. Read-only monitor; no action taken.")
    if decision["priority"] == 1:
        body = (
            f"Hermes drift detected: {conds}. "
            f"runtime={report['runtime_status']} bridge={report['bridge_status']} "
            f"markers={report['patch_markers_status']}. "
            f"pinned={report['pinned']['commit'][:12]} live={report['runtime']['commit'][:12]}. "
            "Read-only monitor; no automatic action taken."
        )
        return ("Hermes version monitor: DRIFT", body)
    body = (
        f"{report['alert_reason']}. upstream_status={report['upstream_status']} "
        f"upstream_head={report['upstream']['head_commit'][:12]} latest_tag={report['upstream']['latest_tag']}. "
        "Patch-port validation is delegated to the weekly CI drift workflow. No action taken."
    )
    return ("Hermes version monitor: advisory", body)


def _print_text(report):
    print(
        "runtime_status={runtime_status} baseline_status={baseline_status} "
        "bridge_status={bridge_status} markers_status={patch_markers_status} "
        "upstream_status={upstream_status} upstream_ahead={ua} "
        "patch_port_review={ppr} alert_action={alert_action} "
        "mutation_performed=0 conditions={conds}".format(
            ua=int(report["upstream_ahead"]),
            ppr=1 if report["patch_port_review"] == "required" else 0,
            conds=",".join(report["active_conditions"]),
            **report,
        )
    )


def parse_args(argv):
    ap = argparse.ArgumentParser(description="Read-only Hermes version monitor")
    ap.add_argument("--hermes-home", default=DEFAULT_HERMES_HOME)
    ap.add_argument("--baseline-path", default=DEFAULT_BASELINE)
    ap.add_argument("--report-path", default=DEFAULT_REPORT)
    ap.add_argument("--state-path", default=DEFAULT_STATE)
    ap.add_argument("--log-path", default=DEFAULT_LOG)  # informational; never written
    ap.add_argument("--upstream-repo", default=DEFAULT_UPSTREAM)
    ap.add_argument("--upstream-timeout", type=int, default=DEFAULT_UPSTREAM_TIMEOUT)
    ap.add_argument("--network-fail-alert-after", type=int, default=DEFAULT_NETWORK_FAIL_ALERT_AFTER)
    ap.add_argument("--skip-upstream", action="store_true")
    ap.add_argument(
        "--notify-owner-bin",
        default=os.environ.get("SHIFT_AGENT_NOTIFY_OWNER_BIN", DEFAULT_NOTIFY_BIN),
    )
    ap.add_argument("--dry-run", action="store_true")
    ap.add_argument("--text", action="store_true")
    ap.add_argument("--json", action="store_true")
    return ap.parse_args(argv)


def main(argv=None) -> int:
    args = parse_args(argv)
    now = datetime.now(timezone.utc)
    try:
        baseline = read_baseline(args.baseline_path)
        prev_state = _load_state(args.state_path)
        perm_conditions = _check_permissions([args.state_path, args.report_path])

        if args.skip_upstream:
            upstream = {"status": "skipped", "head_commit": "", "latest_tag": "",
                        "reachable": False, "ahead": False}
        else:
            upstream = upstream_check(
                args.upstream_repo, timeout=args.upstream_timeout,
                pinned_commit=(baseline or {}).get("commit", ""),
                pinned_version=(baseline or {}).get("version", ""),
            )

        report, decision, new_state = evaluate(
            args.hermes_home, baseline, upstream, prev_state,
            now=now, network_fail_after=args.network_fail_alert_after,
            skip_upstream=args.skip_upstream, extra_conditions=perm_conditions,
        )

        if args.dry_run:
            if args.text:
                _print_text(report)
            if args.json:
                print(json.dumps(report, indent=2, sort_keys=True))
            print("hermes_version_monitor dry_run=1 (no report/state written, no alert dispatched)",
                  file=sys.stderr)
            return EXIT_OK

        # 1. Dispatch the alert FIRST (before any disk write) so a later write
        #    failure cannot lose a real drift page. Persist the throttle signature
        #    ONLY on confirmed delivery → a failed page is retried next run.
        delivered = None
        if decision["notify"]:
            title, message = _alert_text(report, decision)
            print(f"hermes_version_monitor_alert_dispatched action={decision['action']} "
                  f"priority={decision['priority']} conditions={','.join(report['active_conditions'])}")
            delivered, detail = dispatch_alert(args.notify_owner_bin, title, decision["priority"], message)
            print(f"hermes_version_monitor_alert_delivered ok={int(delivered)} detail={detail}")
            report["alert_delivered"] = delivered
            if delivered:
                new_state["last_alert_signature"] = decision["signature"]
                new_state["last_notified_at"] = now.isoformat()

        # 2. Write report + state as a near-atomic pair (report first, state last).
        #    On failure: no in-process alert here (would double-page with
        #    OnFailure); just exit 6 so the OnFailure handler owns the page.
        try:
            _atomic_write_json_pair([
                (args.report_path, report, 0o640),
                (args.state_path, new_state, 0o640),
            ])
        except Exception as e:  # noqa: BLE001
            print(f"hermes-version-check: FAILED to write report/state: {e} "
                  "(OnFailure handler will alert the operator)", file=sys.stderr)
            return EXIT_MONITOR_FAILED

        if args.text:
            _print_text(report)
        if args.json:
            print(json.dumps(report, indent=2, sort_keys=True))

        # 3. Escalate an UNDELIVERED priority-1 (hard-drift) page via exit 6 →
        #    OnFailure, so a failed delivery is not silently swallowed.
        if decision["notify"] and delivered is False and decision["priority"] == 1:
            print("hermes-version-check: priority-1 alert delivery FAILED — escalating via OnFailure",
                  file=sys.stderr)
            return EXIT_MONITOR_FAILED
        return EXIT_OK

    except Exception as e:  # noqa: BLE001 — last-resort; OnFailure handler catches exit 6
        print(f"hermes-version-check: unhandled error: {e}", file=sys.stderr)
        return EXIT_MONITOR_FAILED


if __name__ == "__main__":
    sys.exit(main())
